        <h4 style="font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:600;color:var(--white);margin-bottom:8px;letter-spacing:0.03em;">${item.name}</h4>
        <div class="qty-ctrl" style="width:fit-content;">
          <button class="qty-btn" onclick="cartUpdate(${item.id},${item.qty-1})">−</button>
          <span class="qty-val">${item.qty}</span>
          <button class="qty-btn" onclick="cartUpdate(${item.id},${item.qty+1})">+</button>
        </div>
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <p class="font-mono" style="font-size:13px;margin-bottom:12px;">${formatPrice(item.price*item.qty)}</p>
        <button onclick="cartRemove(${item.id})" style="background:none;border:none;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--wire);text-decoration:underline;transition:color 0.2s;" onmouseover="this.style.color='var(--blood)'" onmouseout="this.style.color='var(--wire)'">Remove</button>
      </div>
