/* ════════════════════
   TOAST
════════════════════ */
function showToast(msg, type = "success") {
  const tc = document.getElementById("toast-container");
  const el = document.createElement("div");
  el.className = `toast ${type}`;
  el.textContent = msg;
  tc.appendChild(el);
  setTimeout(() => el.remove(), 3200);
}

/* ════════════════════
   CART
════════════════════ */
const cart = {
  items: JSON.parse(localStorage.getItem("rd_cart") || "[]"),
  appliedDiscount: null,
  save() { localStorage.setItem("rd_cart", JSON.stringify(this.items)); this.updateBadge(); window.dispatchEvent(new CustomEvent("cart-updated")); },
  add(product, qty = 1) {
    const e = this.items.find(i => i.id === product.id);
    if (e) e.qty = Math.min(e.qty + qty, product.stock);
    else this.items.push({ ...product, qty });
    this.save(); showToast(`${product.name} added`, "success");
  },
  update(id, qty) { const i = this.items.find(x => x.id === id); if (!i) return; i.qty = Math.max(0, qty); if (i.qty === 0) this.remove(id); else this.save(); },
  remove(id) { this.items = this.items.filter(i => i.id !== id); this.save(); },
  clear() { this.items = []; this.appliedDiscount = null; this.save(); },
  subtotal() { return this.items.reduce((s, i) => s + i.price * i.qty, 0); },
  count() { return this.items.reduce((s, i) => s + i.qty, 0); },
  applyCode(code, discounts) {
    const d = discounts.find(d => d.code.toUpperCase() === code.toUpperCase() && d.active);
    if (!d) return null;
    this.appliedDiscount = { code: d.code, pct: d.percentage, amount: this.subtotal() * (d.percentage / 100) };
    return this.appliedDiscount;
  },
  updateBadge() {
    const c = this.count();
    document.querySelectorAll("[data-cart-count]").forEach(el => { el.textContent = c; el.style.display = c > 0 ? "flex" : "none"; });
  }
};
cart.updateBadge();

