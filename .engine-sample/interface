<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>e(__SITE_TITLE__)</title>
  <meta name="description" content="e(__SHOP_DESCRIPTION__)" />
  <meta property="og:title" content="e(__SITE_TITLE__)" />
  <meta property="og:description" content="e(__SHOP_DESCRIPTION__)" />
  <meta property="og:image" content="e(__SITE_LOGO__)" />
  <link rel="icon" href="e(__SITE_LOGO__)" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Barlow+Condensed:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet" />

  <style>
    :root {
      --void:    #080808;
      --pit:     #111111;
      --shaft:   #1a1a1a;
      --steel:   #252525;
      --wire:    #333333;
      --ash:     #888888;
      --bone:    #cccccc;
      --white:   #f0f0f0;
      --blood:   #c0000a;
      --crimson: #e8000f;
      --ember:   #ff4444;
      --glow:    rgba(192,0,10,0.15);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Barlow', sans-serif;
      background: var(--void);
      color: var(--bone);
      font-weight: 300;
      letter-spacing: 0.01em;
      overflow-x: hidden;
    }

    /* ── NOISE TEXTURE OVERLAY ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
    }

    /* ── TYPOGRAPHY ── */
    .font-display    { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }
    .font-condensed  { font-family: 'Barlow Condensed', sans-serif; }
    .font-mono       { font-family: 'IBM Plex Mono', monospace; }

    /* ── VIEWS ── */
    .view-section { display: none; position: relative; z-index: 1; }
    .view-section.active { display: block; }

    /* ── ANNOUNCEMENT BAR ── */
    #announcement-bar {
      background: var(--blood);
      color: var(--white);
      text-align: center;
      padding: 9px 16px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      position: relative; z-index: 101;
    }

    /* ── HEADER ── */
    #site-header {
      background: rgba(8,8,8,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--wire);
      position: sticky; top: 0; z-index: 100;
    }
    #site-header nav {
      max-width: 1440px; margin: 0 auto;
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 30px; letter-spacing: 0.12em;
      color: var(--white); text-decoration: none;
      position: relative;
    }
    .nav-logo span { color: var(--blood); }
    .nav-links { display: flex; gap: 36px; align-items: center; }
    .nav-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 12px; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ash); text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--white); }
    .nav-links a.sale-link { color: var(--crimson); }
    .nav-icons { display: flex; gap: 18px; align-items: center; }
    .nav-icon-btn {
      background: none; border: none; cursor: pointer;
      color: var(--ash); font-size: 18px;
      transition: color 0.2s; position: relative; padding: 4px;
    }
    .nav-icon-btn:hover { color: var(--white); }
    .cart-badge {
      position: absolute; top: -3px; right: -5px;
      background: var(--blood); color: var(--white);
      border-radius: 50%; width: 16px; height: 16px;
      font-size: 9px; display: none; align-items: center; justify-content: center;
      font-family: 'IBM Plex Mono', monospace;
    }
    .hamburger {
      display: none; background: none; border: none;
      cursor: pointer; flex-direction: column; gap: 5px; padding: 4px;
    }
    .hamburger span { display: block; width: 22px; height: 1.5px; background: var(--bone); transition: all 0.3s; }

    /* ── MOBILE NAV ── */
    #mobile-nav {
      display: none; position: fixed; inset: 0; z-index: 200;
      background: var(--void); flex-direction: column;
      padding: 40px 32px; border-right: 1px solid var(--wire);
    }
    #mobile-nav.open { display: flex; }
    #mobile-nav .mob-close { align-self: flex-end; background: none; border: none; color: var(--ash); font-size: 24px; cursor: pointer; margin-bottom: 40px; }
    #mobile-nav a { font-family: 'Bebas Neue', sans-serif; font-size: 40px; color: var(--bone); text-decoration: none; border-bottom: 1px solid var(--wire); padding: 14px 0; letter-spacing: 0.05em; transition: color 0.2s; }
    #mobile-nav a:hover { color: var(--crimson); }

    /* ── CART DRAWER ── */
    #cart-drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 300; }
    #cart-drawer-overlay.open { display: block; }
    #cart-drawer {
      position: fixed; top: 0; right: -520px; width: 100%; max-width: 520px;
      height: 100%; background: var(--pit); z-index: 301;
      display: flex; flex-direction: column;
      transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
      border-left: 1px solid var(--wire);
    }
    #cart-drawer.open { right: 0; }
    .drawer-header { padding: 28px 32px; border-bottom: 1px solid var(--wire); display: flex; align-items: center; justify-content: space-between; }
    .drawer-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 0.1em; color: var(--white); }
    .drawer-close { background: none; border: none; cursor: pointer; font-size: 20px; color: var(--ash); transition: color 0.2s; }
    .drawer-close:hover { color: var(--crimson); }
    .drawer-items { flex: 1; overflow-y: auto; padding: 24px 32px; }
    .drawer-footer { padding: 24px 32px; border-top: 1px solid var(--wire); }

    /* ── SEARCH OVERLAY ── */
    #search-overlay { display: none; position: fixed; inset: 0; background: rgba(8,8,8,0.97); z-index: 400; align-items: flex-start; justify-content: center; padding-top: 100px; }
    #search-overlay.open { display: flex; }
    .search-inner { width: 100%; max-width: 700px; padding: 0 24px; }
    .search-inner input { width: 100%; border: none; border-bottom: 2px solid var(--blood); background: transparent; font-family: 'Bebas Neue', sans-serif; font-size: 48px; color: var(--white); padding: 16px 0; outline: none; letter-spacing: 0.05em; }
    .search-inner input::placeholder { color: var(--wire); }
    #search-close { position: absolute; top: 32px; right: 40px; background: none; border: none; font-size: 28px; cursor: pointer; color: var(--ash); transition: color 0.2s; }
    #search-close:hover { color: var(--crimson); }

    /* ── TOAST ── */
    #toast-container { position: fixed; bottom: 32px; right: 32px; z-index: 500; display: flex; flex-direction: column; gap: 10px; pointer-events: none; }
    .toast { padding: 12px 20px; font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.1em; pointer-events: auto; animation: toastIn 0.3s ease; border-left: 3px solid; }
    .toast.success { background: var(--shaft); color: var(--white); border-color: var(--blood); }
    .toast.error   { background: var(--shaft); color: var(--ember); border-color: var(--ember); }
    .toast.info    { background: var(--shaft); color: var(--bone); border-color: var(--ash); }
    @keyframes toastIn { from { opacity:0; transform: translateX(20px); } to { opacity:1; transform: translateX(0); } }

    /* ── BUTTONS ── */
    .btn-primary { display: inline-block; background: var(--blood); color: var(--white); padding: 13px 36px; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; border: none; text-decoration: none; transition: background 0.2s; }
    .btn-primary:hover { background: var(--crimson); }
    .btn-outline { display: inline-block; border: 1px solid var(--wire); color: var(--bone); padding: 12px 36px; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; background: transparent; text-decoration: none; transition: all 0.2s; }
    .btn-outline:hover { border-color: var(--blood); color: var(--white); }
    .btn-ghost { display: inline-block; background: transparent; color: var(--ash); padding: 10px 20px; font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; border: 1px solid var(--wire); text-decoration: none; transition: all 0.2s; }
    .btn-ghost:hover { color: var(--white); border-color: var(--ash); }

    /* ── PRODUCT CARD ── */
    .product-card { background: var(--pit); cursor: pointer; transition: transform 0.3s, box-shadow 0.3s; position: relative; overflow: hidden; border: 1px solid var(--shaft); }
    .product-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px var(--blood); }
    .product-card-img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; background: var(--shaft); transition: transform 0.5s; }
    .product-card:hover .product-card-img { transform: scale(1.03); }
    .product-card-img-placeholder { width: 100%; aspect-ratio: 3/4; background: var(--shaft); display: flex; align-items: center; justify-content: center; color: var(--wire); font-size: 11px; letter-spacing: 0.15em; font-family: 'IBM Plex Mono', monospace; }
    .product-card-body { padding: 16px 18px 20px; }
    .product-card-cat { font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blood); margin-bottom: 6px; }
    .product-card-name { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 500; color: var(--white); margin-bottom: 8px; line-height: 1.2; letter-spacing: 0.03em; }
    .product-card-price { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--ash); }
    .product-card-overlay { position: absolute; inset: 0; background: rgba(192,0,10,0); display: flex; align-items: center; justify-content: center; opacity: 0; transition: all 0.3s; }
    .product-card:hover .product-card-overlay { opacity: 1; }
    .product-card-add { background: var(--blood); color: var(--white); padding: 10px 24px; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; border: none; cursor: pointer; transform: translateY(8px); transition: transform 0.3s; }
    .product-card:hover .product-card-add { transform: translateY(0); }

    /* ── FORM ── */
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ash); margin-bottom: 8px; }
    .form-input { width: 100%; border: 1px solid var(--wire); background: var(--shaft); padding: 11px 14px; font-family: 'Barlow', sans-serif; font-size: 14px; color: var(--white); outline: none; transition: border-color 0.2s; }
    .form-input:focus { border-color: var(--blood); }
    .form-input::placeholder { color: var(--wire); }
    select.form-input option { background: var(--shaft); }

    /* ── QTY ── */
    .qty-ctrl { display: flex; align-items: center; border: 1px solid var(--wire); }
    .qty-btn { background: none; border: none; width: 36px; height: 36px; cursor: pointer; font-size: 18px; color: var(--bone); display: flex; align-items: center; justify-content: center; transition: background 0.2s, color 0.2s; }
    .qty-btn:hover { background: var(--blood); color: var(--white); }
    .qty-val { width: 44px; text-align: center; font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: var(--white); }

    /* ── ACCORDION ── */
    .accordion-item { border-bottom: 1px solid var(--wire); }
    .accordion-btn { width: 100%; background: none; border: none; text-align: left; padding: 20px 0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .accordion-q { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 500; color: var(--white); letter-spacing: 0.03em; }
    .accordion-icon { font-size: 20px; color: var(--blood); transition: transform 0.3s; flex-shrink: 0; font-family: 'IBM Plex Mono', monospace; }
    .accordion-item.open .accordion-icon { transform: rotate(45deg); }
    .accordion-body { display: none; padding: 0 0 20px; color: var(--ash); line-height: 1.7; font-size: 14px; }
    .accordion-item.open .accordion-body { display: block; }

    /* ── CHECKOUT STEPS ── */
    .step-indicator { display: flex; align-items: center; gap: 8px; margin-bottom: 40px; }
    .step-dot { width: 30px; height: 30px; border-radius: 0; display: flex; align-items: center; justify-content: center; font-family: 'IBM Plex Mono', monospace; font-size: 11px; border: 1px solid var(--wire); color: var(--ash); transition: all 0.3s; flex-shrink: 0; }
    .step-dot.active { background: var(--blood); color: var(--white); border-color: var(--blood); }
    .step-dot.done { background: var(--shaft); color: var(--blood); border-color: var(--blood); }
    .step-line { flex: 1; height: 1px; background: var(--wire); }

    /* ── TRACK STEPS ── */
    .track-step { display: flex; gap: 20px; align-items: flex-start; padding-bottom: 28px; position: relative; }
    .track-step-dot { width: 12px; height: 12px; background: var(--wire); border: 2px solid var(--wire); flex-shrink: 0; margin-top: 4px; position: relative; z-index: 1; }
    .track-step.done .track-step-dot { background: var(--blood); border-color: var(--blood); box-shadow: 0 0 8px var(--glow); }
    .track-step::after { content:''; position: absolute; left: 5px; top: 16px; bottom: 0; width: 2px; background: var(--wire); }
    .track-step:last-child::after { display: none; }
    .track-step.done::after { background: var(--blood); opacity: 0.4; }

    /* ── SECTION ── */
    .page-inner { max-width: 1440px; margin: 0 auto; padding: 0 40px; }
    .page-section { padding: 80px 0; }
    .section-eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--blood); margin-bottom: 12px; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(40px,6vw,80px); color: var(--white); letter-spacing: 0.04em; line-height: 0.95; }

    /* ── DIVIDER ── */
    .divider { height: 1px; background: linear-gradient(90deg, transparent, var(--wire), transparent); margin: 0; }

    /* ── FOOTER ── */
    footer { background: var(--pit); border-top: 1px solid var(--wire); padding: 64px 40px 32px; margin-top: 0; position: relative; z-index: 1; }
    .footer-grid { max-width: 1440px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer-col h4 { font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--blood); margin-bottom: 20px; }
    .footer-col a { display: block; color: var(--ash); font-size: 13px; margin-bottom: 10px; text-decoration: none; letter-spacing: 0.02em; transition: color 0.2s; }
    .footer-col a:hover { color: var(--white); }
    .footer-brand { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 0.1em; color: var(--white); margin-bottom: 10px; }
    .footer-brand span { color: var(--blood); }
    .footer-bottom { max-width: 1440px; margin: 0 auto; padding-top: 24px; border-top: 1px solid var(--wire); display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--wire); font-family: 'IBM Plex Mono', monospace; }

    /* ── SKELETON ── */
    .skeleton { background: linear-gradient(90deg, var(--shaft) 25%, var(--steel) 50%, var(--shaft) 75%); background-size: 400% 100%; animation: shimmer 1.4s ease infinite; }
    @keyframes shimmer { 0%{background-position:100% 0} 100%{background-position:-100% 0} }

    /* ── HERO ── */
    .hero-wrap { min-height: 94vh; background: var(--void); display: flex; align-items: stretch; position: relative; overflow: hidden; }
    .hero-left { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; padding: 80px 80px 80px 10%; position: relative; z-index: 2; }
    .hero-right { width: 42%; position: relative; overflow: hidden; flex-shrink: 0; }
    .hero-right-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; filter: grayscale(20%) contrast(1.1); }
    .hero-right-img-placeholder { width: 100%; height: 100%; background: linear-gradient(180deg,var(--shaft) 0%,var(--void) 100%), url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900') center/cover; }
    .hero-right::before { content:''; position:absolute; left:0; top:0; bottom:0; width:120px; background:linear-gradient(90deg,var(--void),transparent); z-index:1; }
    .hero-eye { font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--blood); margin-bottom: 20px; }
    .hero-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(72px,10vw,140px); line-height: 0.9; color: var(--white); margin-bottom: 28px; }
    .hero-title .red { color: var(--blood); }
    .hero-sub { font-size: 15px; color: var(--ash); line-height: 1.7; margin-bottom: 40px; max-width: 420px; letter-spacing: 0.02em; }
    .hero-scan { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--blood), transparent); animation: scan 4s ease-in-out infinite; opacity: 0.6; }
    @keyframes scan { 0%,100%{top:0;opacity:0} 10%{opacity:0.6} 90%{opacity:0.6} 95%{top:100%;opacity:0} }

    /* ── VALUE BAR ── */
    .value-bar { background: var(--blood); padding: 20px 40px; }
    .value-bar-inner { max-width: 1440px; margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); gap: 0; }
    .value-prop { display: flex; align-items: center; gap: 12px; color: var(--white); padding: 0 24px; border-right: 1px solid rgba(255,255,255,0.15); }
    .value-prop:first-child { padding-left: 0; }
    .value-prop:last-child { border-right: none; }
    .value-prop-icon { font-size: 16px; flex-shrink: 0; }
    .value-prop-text { font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; }

    /* ── COLLECTION CARD ── */
    .coll-card { position: relative; overflow: hidden; aspect-ratio: 3/4; cursor: pointer; border: 1px solid var(--shaft); }
    .coll-card-bg { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; display: block; background: var(--shaft); filter: grayscale(30%); }
    .coll-card:hover .coll-card-bg { transform: scale(1.06); filter: grayscale(0%); }
    .coll-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 55%); display: flex; flex-direction: column; justify-content: flex-end; padding: 28px; }
    .coll-card-overlay h3 { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--white); letter-spacing: 0.05em; margin-bottom: 4px; }
    .coll-card-overlay span { font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.2em; color: var(--blood); text-transform: uppercase; }
    .coll-card::before { content:''; position:absolute; inset:0; border:2px solid var(--blood); opacity:0; transition:opacity 0.3s; z-index:1; }
    .coll-card:hover::before { opacity:1; }

    /* ── DISCOUNT CARD ── */
    .discount-card { background: var(--shaft); border: 1px dashed var(--blood); padding: 24px 28px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .discount-code { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 0.15em; color: var(--white); }
    .discount-pct { font-family: 'Bebas Neue', sans-serif; font-size: 40px; color: var(--blood); letter-spacing: 0.05em; }

    /* ── BREADCRUMB ── */
    .breadcrumb { display: flex; gap: 8px; align-items: center; font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--ash); margin-bottom: 36px; }
    .breadcrumb a { color: var(--ash); text-decoration: none; cursor: pointer; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--blood); }
    .breadcrumb span { color: var(--blood); }

    /* ══════════════════════════
       CUSTOMER AUTH & DASHBOARD
    ══════════════════════════ */

    /* ── AUTH MODAL ── */
    #auth-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 600; align-items: center; justify-content: center; }
    #auth-modal-overlay.open { display: flex; }
    #auth-modal {
      background: var(--pit); border: 1px solid var(--wire);
      width: 100%; max-width: 460px; padding: 48px;
      position: relative;
      box-shadow: 0 40px 100px rgba(0,0,0,0.8), 0 0 0 1px var(--shaft);
    }
    #auth-modal-close { position: absolute; top: 20px; right: 20px; background: none; border: none; cursor: pointer; color: var(--ash); font-size: 20px; transition: color 0.2s; }
    #auth-modal-close:hover { color: var(--crimson); }
    .auth-tabs { display: flex; border-bottom: 1px solid var(--wire); margin-bottom: 32px; }
    .auth-tab { flex: 1; padding: 12px 0; text-align: center; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; color: var(--ash); border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.2s; background: none; border-top: none; border-left: none; border-right: none; }
    .auth-tab.active { color: var(--white); border-bottom-color: var(--blood); }
    .auth-panel { display: none; }
    .auth-panel.active { display: block; }
    .auth-divider { display: flex; align-items: center; gap: 16px; margin: 24px 0; }
    .auth-divider::before, .auth-divider::after { content:''; flex:1; height:1px; background:var(--wire); }
    .auth-divider span { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--wire); letter-spacing: 0.1em; }
    .auth-forgot { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--ash); text-decoration: none; letter-spacing: 0.1em; transition: color 0.2s; cursor: pointer; }
    .auth-forgot:hover { color: var(--blood); }

    /* ── DASHBOARD LAYOUT ── */
    #view-dashboard { background: var(--void); }
    .dashboard-layout { display: grid; grid-template-columns: 260px 1fr; min-height: calc(100vh - 128px); }
    .dashboard-sidebar {
      background: var(--pit); border-right: 1px solid var(--wire);
      padding: 40px 0; position: sticky; top: 64px;
      height: calc(100vh - 64px); overflow-y: auto;
    }
    .sidebar-user { padding: 0 28px 32px; border-bottom: 1px solid var(--wire); margin-bottom: 24px; }
    .sidebar-avatar { width: 52px; height: 52px; background: var(--blood); display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--white); margin-bottom: 14px; }
    .sidebar-name { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 600; color: var(--white); letter-spacing: 0.05em; }
    .sidebar-email { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--ash); letter-spacing: 0.08em; margin-top: 4px; }
    .sidebar-nav { display: flex; flex-direction: column; }
