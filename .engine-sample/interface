function copyCode(code) { navigator.clipboard.writeText(code).then(() => showToast(`"${code}" copied!`)); }

function renderCart() {
  const el = document.getElementById("cart-page-items");
  const disc = cart.appliedDiscount;
  if (!cart.items.length) { el.innerHTML = `<div style="text-align:center;padding:80px 0;"><div style="font-family:'Bebas Neue',sans-serif;font-size:80px;color:var(--wire);margin-bottom:16px;">EMPTY</div><h2 style="font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--white);margin-bottom:16px;">Nothing in your cart</h2><a href="#shop" class="btn-primary">Shop Now</a></div>`; document.getElementById("cart-sub").textContent = formatPrice(0); document.getElementById("cart-total").textContent = formatPrice(0); return; }
  el.innerHTML = cart.items.map(item => `
    <div style="display:flex;gap:20px;padding:24px 0;border-bottom:1px solid var(--shaft);align-items:center;">
      <img src="${item.image}" style="width:80px;height:100px;object-fit:cover;background:var(--shaft);flex-shrink:0;" />
      <div style="flex:1;min-width:0;">
