/* ════════════════════
   CART DRAWER
════════════════════ */
function openCartDrawer() { renderCartDrawer(); document.getElementById("cart-drawer").classList.add("open"); document.getElementById("cart-drawer-overlay").classList.add("open"); document.body.style.overflow="hidden"; }
function closeCartDrawer() { document.getElementById("cart-drawer").classList.remove("open"); document.getElementById("cart-drawer-overlay").classList.remove("open"); document.body.style.overflow=""; }

function renderCartDrawer() {
  const el = document.getElementById("cart-drawer-items");
  const sub = document.getElementById("cart-drawer-subtotal");
  if (!cart.items.length) { el.innerHTML = `<div style="text-align:center;padding:48px 0;font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--wire);letter-spacing:0.05em;">EMPTY CART</div>`; if(sub) sub.textContent=formatPrice(0); return; }
  el.innerHTML = cart.items.map(item => `
    <div style="display:flex;gap:14px;padding:16px 0;border-bottom:1px solid var(--shaft);align-items:center;">
      <img src="${item.image}" style="width:60px;height:76px;object-fit:cover;background:var(--shaft);" />
      <div style="flex:1;min-width:0;">
        <p style="font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:600;color:var(--white);margin-bottom:3px;letter-spacing:0.03em;">${item.name}</p>
        <p class="font-mono" style="font-size:10px;color:var(--ash);margin-bottom:8px;">${formatPrice(item.price)} × ${item.qty}</p>
        <div class="qty-ctrl" style="width:fit-content;">
          <button class="qty-btn" style="width:28px;height:28px;font-size:14px;" onclick="drawerUpd(${item.id},${item.qty-1})">−</button>
          <span class="qty-val" style="width:30px;font-size:12px;">${item.qty}</span>
          <button class="qty-btn" style="width:28px;height:28px;font-size:14px;" onclick="drawerUpd(${item.id},${item.qty+1})">+</button>
        </div>
      </div>
      <button onclick="drawerRem(${item.id})" style="background:none;border:none;cursor:pointer;color:var(--wire);font-size:16px;transition:color 0.2s;flex-shrink:0;" onmouseover="this.style.color='var(--blood)'" onmouseout="this.style.color='var(--wire)'">✕</button>
    </div>`).join("");
  if(sub) sub.textContent = formatPrice(cart.subtotal());
}

function drawerUpd(id, qty) { cart.update(id, qty); renderCartDrawer(); }
function drawerRem(id) { cart.remove(id); renderCartDrawer(); }

/* ════════════════════
   SEARCH OVERLAY
════════════════════ */
let searchDebounce;
async function doSearch(q) {
  const res = document.getElementById("search-results");
  if (!q) { res.innerHTML = ""; return; }
  const results = await fetchStore("search", { q });
  if (!results.length) { res.innerHTML = `<p class="font-mono" style="font-size:11px;color:var(--wire);letter-spacing:0.1em;">No results for "${q}"</p>`; return; }
  res.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">${results.slice(0,6).map(p => `<div style="cursor:pointer;" onclick="closeSearch();router.navigate('product',{id:${p.id}})"><img src="${p.image}" style="width:100%;aspect-ratio:1;object-fit:cover;background:var(--shaft);display:block;margin-bottom:8px;"/><p style="font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:600;color:var(--white);">${p.name}</p><p class="font-mono" style="font-size:10px;color:var(--blood);">${formatPrice(p.price)}</p></div>`).join("")}</div>`;
}

function closeSearch() { document.getElementById("search-overlay").classList.remove("open"); document.body.style.overflow=""; }

/* ════════════════════
   MOBILE NAV
════════════════════ */
function openMobileNav() { document.getElementById("mobile-nav").classList.add("open"); document.body.style.overflow="hidden"; }
function closeMobileNav() { document.getElementById("mobile-nav").classList.remove("open"); document.body.style.overflow=""; }

/* ════════════════════
   AUTH SYSTEM
════════════════════ */
function openAuthModal(tab = "login") {
  switchAuthTab(tab);
  document.getElementById("auth-modal-overlay").classList.add("open");
  document.body.style.overflow = "hidden";
}

function closeAuthModal() { document.getElementById("auth-modal-overlay").classList.remove("open"); document.body.style.overflow=""; }

function switchAuthTab(tab) {
  ["login","register","forgot"].forEach(t => {
    document.getElementById(`panel-${t}`)?.classList.remove("active");
    document.getElementById(`tab-${t}`)?.classList.remove("active");
  });
  document.getElementById(`panel-${tab}`)?.classList.add("active");
  document.getElementById(`tab-${tab}`)?.classList.add("active");
}

function showForgot() { switchAuthTab("forgot"); document.getElementById("tab-login")?.classList.remove("active"); }

function doLogin() {
  const email = document.getElementById("login-email").value.trim();
  const pass = document.getElementById("login-pass").value;
  if (!email || !pass) { showToast("Please enter your email and password","error"); return; }
  // Check if user exists in localStorage
  let users = JSON.parse(localStorage.getItem("rd_users") || "[]");
  const user = users.find(u => u.email === email && u.password === pass);
  if (!user) {
    // Auto-create for demo purposes if not found
    const newUser = { email, password: pass, fname: "Member", lname: "", phone: "", orders: [], joinDate: new Date().toLocaleDateString(), memberSince: "2024" };
    users.push(newUser); localStorage.setItem("rd_users", JSON.stringify(users));
    auth.setUser(newUser);
  } else { auth.setUser(user); }
  closeAuthModal();
  showToast(`Welcome back, ${auth.getUser().fname}!`);
  updateAccountBtn();
  router.navigate("dashboard");
}

function doRegister() {
  const fname = document.getElementById("reg-fname").value.trim();
  const lname = document.getElementById("reg-lname").value.trim();
  const email = document.getElementById("reg-email").value.trim();
  const pass = document.getElementById("reg-pass").value;
  const pass2 = document.getElementById("reg-pass2").value;
  if (!fname || !email || !pass) { showToast("Please fill all fields","error"); return; }
  if (pass !== pass2) { showToast("Passwords do not match","error"); return; }
  if (pass.length < 8) { showToast("Password must be at least 8 characters","error"); return; }
  const newUser = { email, password: pass, fname, lname, phone: "", orders: [], joinDate: new Date().toLocaleDateString(), memberSince: new Date().getFullYear().toString() };
  let users = JSON.parse(localStorage.getItem("rd_users") || "[]");
  if (users.find(u => u.email === email)) { showToast("An account with this email already exists","error"); return; }
  users.push(newUser); localStorage.setItem("rd_users", JSON.stringify(users));
  auth.setUser(newUser); closeAuthModal();
  showToast(`Welcome to REIDROP, ${fname}!`);
  updateAccountBtn();
  router.navigate("dashboard");
}

function doForgot() {
  const email = document.getElementById("forgot-email").value.trim();
  if (!email) { showToast("Please enter your email","error"); return; }
  showToast("Reset link sent to your email","info");
  switchAuthTab("login");
}

function doLogout() {
  auth.clearUser(); updateAccountBtn();
  showToast("You've been signed out","info");
  router.navigate("home");
}

function updateAccountBtn() {
  const btn = document.getElementById("account-btn");
  const u = auth.getUser();
  if (u) { btn.style.color = "var(--blood)"; btn.title = `${u.fname} — Dashboard`; }
  else { btn.style.color = "var(--ash)"; btn.title = "Account"; }
}

function confirmDeleteAccount() {
  if (confirm("Are you sure you want to permanently delete your account? This cannot be undone.")) {
    auth.clearUser();
    updateAccountBtn();
    showToast("Account deleted","info");
    router.navigate("home");
  }
}

/* ════════════════════
   DASHBOARD
════════════════════ */
function renderDashboard() {
  const u = auth.getUser();
  if (!u) { openAuthModal("login"); return; }

  document.getElementById("sidebar-name").textContent = `${u.fname} ${u.lname}`.trim();
  document.getElementById("sidebar-email").textContent = u.email;
  document.getElementById("sidebar-avatar").textContent = `${u.fname.charAt(0)}${u.lname?u.lname.charAt(0):''}`.toUpperCase();
  document.getElementById("dash-welcome-name").textContent = u.fname;

  // Pre-fill account form
  document.getElementById("acc-fname").value = u.fname || "";
  document.getElementById("acc-lname").value = u.lname || "";
  document.getElementById("acc-email").value = u.email || "";
  document.getElementById("acc-phone").value = u.phone || "";

  // Stats
  const userOrders = u.orders || [];
  document.getElementById("stat-orders").textContent = userOrders.length;
  document.getElementById("stat-spent").textContent = formatPrice(userOrders.reduce((s,o) => s + (o.total||0), 0));
  document.getElementById("stat-wishlist").textContent = wishlist.items.length;
  document.getElementById("stat-addresses").textContent = addresses.list.length;

  // Recent Orders (overview)
  renderOverviewOrders(userOrders);

  // Make sure default panel is shown
  switchDashPanel("overview");
}

function renderOverviewOrders(orders) {
  const el = document.getElementById("overview-recent-orders");
  if (!orders.length) { el.innerHTML = `<p class="font-mono" style="font-size:11px;color:var(--wire);letter-spacing:0.1em;text-align:center;padding:24px 0;">No orders yet. <a href="#shop" style="color:var(--blood);text-decoration:none;">Start shopping →</a></p>`; return; }
  el.innerHTML = `<table class="orders-table"><thead><tr><th>Order ID</th><th>Date</th><th>Total</th><th>Status</th></tr></thead><tbody>${orders.slice(0,5).map(o=>`<tr><td class="font-mono" style="font-size:12px;">#${o.id}</td><td style="color:var(--ash);">${o.date||'—'}</td><td>${formatPrice(o.total||0)}</td><td><span class="order-status status-${(o.status||'pending').toLowerCase()}">${o.status||'Processing'}</span></td></tr>`).join("")}</tbody></table>`;
}

function switchDashPanel(name) {
  document.querySelectorAll(".dash-panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".sidebar-nav-item").forEach(b => b.classList.remove("active"));
  const panel = document.getElementById(`panel-${name}`);
  if (panel) panel.classList.add("active");
  const navBtn = document.getElementById(`nav-${name}`);
  if (navBtn) navBtn.classList.add("active");

  // Render sub-panel content
  const u = auth.getUser();
  if (name === "orders" && u) renderDashOrders(u.orders || []);
  if (name === "addresses") renderAddresses();
  if (name === "wishlist") renderWishlist();
}

function renderDashOrders(orders) {
  const el = document.getElementById("dash-orders-table");
  if (!orders.length) { el.innerHTML = `<div style="text-align:center;padding:64px 0;"><div style="font-family:'Bebas Neue',sans-serif;font-size:40px;color:var(--wire);margin-bottom:12px;">NO ORDERS</div><p style="color:var(--ash);margin-bottom:24px;font-size:14px;">You haven't placed any orders yet.</p><a href="#shop" class="btn-primary">Shop Now</a></div>`; return; }
  el.innerHTML = `<div style="background:var(--pit);border:1px solid var(--wire);overflow:hidden;"><table class="orders-table"><thead><tr><th>Order ID</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th></tr></thead><tbody>${orders.map(o=>`<tr><td class="font-mono" style="font-size:12px;color:var(--blood);">#${o.id}</td><td style="color:var(--ash);">${o.date||'—'}</td><td style="color:var(--ash);">${(o.items||[]).length} item${(o.items||[]).length!==1?'s':''}</td><td>${formatPrice(o.total||0)}</td><td><span class="order-status status-${(o.status||'pending').toLowerCase()}">${o.status||'Processing'}</span></td></tr>`).join("")}</tbody></table></div>`;
}

function renderAddresses() {
  const grid = document.getElementById("addresses-grid");
  if (!addresses.list.length) { grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:48px 0;font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--wire);letter-spacing:0.05em;">NO SAVED ADDRESSES</div>`; return; }
  grid.innerHTML = addresses.list.map(a => `
    <div class="address-card ${a.isDefault?'default-card':''}">
      ${a.isDefault ? '<span class="address-default-badge">Default</span>' : ''}
      <p style="font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:600;color:var(--white);margin-bottom:8px;">${a.fname} ${a.lname}</p>
      <p style="font-size:13px;color:var(--ash);line-height:1.7;">${a.street}<br>${a.city}, ${a.province} ${a.postal}<br>${a.country}</p>
      <div style="display:flex;gap:10px;margin-top:16px;">
        ${!a.isDefault ? `<button onclick="setDefaultAddress(${a.id})" class="btn-ghost" style="padding:5px 14px;font-size:9px;">Set Default</button>` : ''}
        <button onclick="removeAddress(${a.id})" style="background:none;border:1px solid var(--wire);color:var(--wire);padding:5px 14px;font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.1em;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--blood)';this.style.color='var(--blood)'" onmouseout="this.style.borderColor='var(--wire)';this.style.color='var(--wire)'">Remove</button>
      </div>
    </div>`).join("");
  document.getElementById("stat-addresses").textContent = addresses.list.length;
}

function showAddressForm() { document.getElementById("address-form").style.display = "block"; }
function hideAddressForm() { document.getElementById("address-form").style.display = "none"; }

function saveAddress() {
  const addr = {
    fname: document.getElementById("addr-fname").value.trim(),
    lname: document.getElementById("addr-lname").value.trim(),
    street: document.getElementById("addr-street").value.trim(),
    city: document.getElementById("addr-city").value.trim(),
    province: document.getElementById("addr-prov").value.trim(),
    postal: document.getElementById("addr-post").value.trim(),
    country: document.getElementById("addr-country").value.trim() || "South Africa",
    isDefault: document.getElementById("addr-default").checked
  };
  if (!addr.fname || !addr.street || !addr.city) { showToast("Please fill in required address fields","error"); return; }
  if (addr.isDefault) addresses.list.forEach(a => a.isDefault = false);
  addresses.add(addr); hideAddressForm(); renderAddresses(); showToast("Address saved");
}

function setDefaultAddress(id) { addresses.setDefault(id); renderAddresses(); showToast("Default address updated"); }
function removeAddress(id) { addresses.remove(id); renderAddresses(); showToast("Address removed","info"); }

function renderWishlist() {
  const el = document.getElementById("wishlist-items");
  if (!wishlist.items.length) { el.innerHTML = `<div style="text-align:center;padding:64px 0;"><div style="font-family:'Bebas Neue',sans-serif;font-size:40px;color:var(--wire);margin-bottom:12px;">WISHLIST EMPTY</div><p style="color:var(--ash);margin-bottom:24px;font-size:14px;">Browse the collection and save items you love.</p><a href="#shop" class="btn-primary">Shop Now</a></div>`; return; }
  el.innerHTML = wishlist.items.map(p => `
    <div class="wishlist-item">
      <img src="${p.image}" style="width:72px;height:88px;object-fit:cover;background:var(--shaft);flex-shrink:0;" />
      <div style="flex:1;min-width:0;">
        <p class="font-mono" style="font-size:9px;color:var(--blood);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:4px;">${MOCK.categories.find(c=>c.id===p.category_id)?.name||''}</p>
        <h4 style="font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:600;color:var(--white);margin-bottom:4px;">${p.name}</h4>
        <p class="font-mono" style="font-size:12px;color:var(--ash);">${formatPrice(p.price)}</p>
      </div>
      <div style="display:flex;gap:10px;align-items:center;">
        <button onclick="quickAddWishItem(${p.id})" class="btn-primary" style="padding:9px 18px;font-size:10px;">Add to Cart</button>
        <button onclick="removeWishItem(${p.id})" style="background:none;border:1px solid var(--wire);color:var(--wire);padding:9px 12px;cursor:pointer;font-size:14px;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--blood)';this.style.color='var(--blood)'" onmouseout="this.style.borderColor='var(--wire)';this.style.color='var(--wire)'">✕</button>
      </div>
    </div>`).join("");
  document.getElementById("stat-wishlist").textContent = wishlist.items.length;
}

async function quickAddWishItem(id) { const p = await fetchStore("product",{id}); if(p&&p.stock>0){cart.add(p,1);openCartDrawer();} else showToast("Out of stock","error"); }
function removeWishItem(id) { const p = wishlist.items.find(i=>i.id===id); if(p) wishlist.toggle(p); renderWishlist(); }

function saveAccountInfo() {
  const u = auth.getUser(); if (!u) return;
  u.fname = document.getElementById("acc-fname").value.trim();
  u.lname = document.getElementById("acc-lname").value.trim();
  u.email = document.getElementById("acc-email").value.trim();
  u.phone = document.getElementById("acc-phone").value.trim();
  auth.setUser(u);
  document.getElementById("sidebar-name").textContent = `${u.fname} ${u.lname}`.trim();
  document.getElementById("sidebar-email").textContent = u.email;
  document.getElementById("sidebar-avatar").textContent = `${u.fname.charAt(0)}${u.lname?u.lname.charAt(0):''}`.toUpperCase();
  // Update in users array
  let users = JSON.parse(localStorage.getItem("rd_users")||"[]");
  const idx = users.findIndex(x => x.email === u.email);
  if (idx > -1) { users[idx] = u; localStorage.setItem("rd_users", JSON.stringify(users)); }
  showToast("Profile updated");
}

function savePreferences() { showToast("Preferences saved"); }

function changePassword() {
  const cur = document.getElementById("pw-current").value;
  const nw = document.getElementById("pw-new").value;
  const conf = document.getElementById("pw-confirm").value;
  if (!cur || !nw || !conf) { showToast("Please fill all password fields","error"); return; }
  if (nw.length < 8) { showToast("New password must be at least 8 characters","error"); return; }
  if (nw !== conf) { showToast("Passwords do not match","error"); return; }
  const u = auth.getUser(); if (!u) return;
  if (u.password !== cur) { showToast("Current password is incorrect","error"); return; }
  u.password = nw; auth.setUser(u);
  let users = JSON.parse(localStorage.getItem("rd_users")||"[]");
  const idx = users.findIndex(x => x.email === u.email);
  if (idx > -1) { users[idx] = u; localStorage.setItem("rd_users", JSON.stringify(users)); }
  document.getElementById("pw-current").value = "";
  document.getElementById("pw-new").value = "";
  document.getElementById("pw-confirm").value = "";
  showToast("Password updated");
}

/* ════════════════════
   RESPONSIVE
════════════════════ */
function updateGrids() {
  const w = window.innerWidth;
  const shopGrid = document.getElementById("shop-grid");
  if (shopGrid) shopGrid.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(3,1fr)";
  const homeProds = document.getElementById("home-products");
  if (homeProds) homeProds.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
  const homeCols = document.getElementById("home-collections");
  if (homeCols) homeCols.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
  const colGrid = document.getElementById("collections-grid");
  if (colGrid) colGrid.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
  const saleProds = document.getElementById("sale-products");
  if (saleProds) saleProds.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
  const relProds = document.getElementById("related-products");
  if (relProds) relProds.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : "repeat(4,1fr)";
  const sgPg = document.getElementById("search-pg-grid");
  if (sgPg) sgPg.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
  const prodLayout = document.querySelector("#view-product .page-inner > div:nth-child(2)");
  if (prodLayout) prodLayout.style.gridTemplateColumns = w < 768 ? "1fr" : "1fr 1fr";
  const cartLayout = document.querySelector("#view-cart .page-inner > div:nth-child(2)");
  if (cartLayout) cartLayout.style.gridTemplateColumns = w < 1024 ? "1fr" : "1fr 360px";
  const coLayout = document.querySelector("#view-checkout .page-inner > div");
  if (coLayout) coLayout.style.gridTemplateColumns = w < 1024 ? "1fr" : "1fr 380px";
  const addrGrid = document.getElementById("addresses-grid");
  if (addrGrid) addrGrid.style.gridTemplateColumns = w < 640 ? "1fr" : "repeat(2,1fr)";
  const saleDis = document.getElementById("sale-discounts");
  if (saleDis) saleDis.style.gridTemplateColumns = w < 640 ? "1fr" : "repeat(2,1fr)";
}
window.addEventListener("resize", updateGrids);

/* ════════════════════
   EVENT LISTENERS
════════════════════ */
document.getElementById("cart-toggle").addEventListener("click", openCartDrawer);
document.getElementById("cart-drawer-close").addEventListener("click", closeCartDrawer);
document.getElementById("cart-drawer-overlay").addEventListener("click", closeCartDrawer);
document.getElementById("drawer-checkout-btn").addEventListener("click", closeCartDrawer);
document.getElementById("hamburger-btn").addEventListener("click", openMobileNav);
document.getElementById("mob-close").addEventListener("click", closeMobileNav);
document.querySelectorAll("#mobile-nav a").forEach(a => a.addEventListener("click", closeMobileNav));

document.getElementById("account-btn").addEventListener("click", () => {
  if (auth.isLoggedIn()) router.navigate("dashboard");
  else openAuthModal("login");
});

document.getElementById("auth-modal-close").addEventListener("click", closeAuthModal);
document.getElementById("auth-modal-overlay").addEventListener("click", (e) => { if (e.target === document.getElementById("auth-modal-overlay")) closeAuthModal(); });

document.getElementById("search-toggle").addEventListener("click", () => {
  document.getElementById("search-overlay").classList.add("open");
  document.body.style.overflow = "hidden";
  setTimeout(() => document.getElementById("search-input").focus(), 100);
});
document.getElementById("search-close").addEventListener("click", closeSearch);

document.getElementById("search-input").addEventListener("input", (e) => {
  clearTimeout(searchDebounce);
  searchDebounce = setTimeout(() => doSearch(e.target.value.trim()), 300);
});

document.addEventListener("keydown", (e) => {
  if (e.key === "Escape") { closeSearch(); closeCartDrawer(); closeMobileNav(); closeAuthModal(); }
});

window.addEventListener("cart-updated", renderCartDrawer);

/* ════════════════════
   INIT
════════════════════ */
window.addEventListener("DOMContentLoaded", async () => {
  try { const site = await fetchStore("site"); CURRENCY = site.currency || "R"; } catch {}
  cart.updateBadge();
  updateAccountBtn();
  updateGrids();
  renderFaq();
  router.init();
});
</script>
