  getUser() { try { return JSON.parse(localStorage.getItem("rd_user")); } catch { return null; } },
  setUser(u) { localStorage.setItem("rd_user", JSON.stringify(u)); },
  clearUser() { localStorage.removeItem("rd_user"); },
  isLoggedIn() { return !!this.getUser(); }
};

/* ════════════════════
   WISHLIST
════════════════════ */
const wishlist = {
  items: JSON.parse(localStorage.getItem("rd_wishlist") || "[]"),
  save() { localStorage.setItem("rd_wishlist", JSON.stringify(this.items)); },
  toggle(product) {
    const idx = this.items.findIndex(i => i.id === product.id);
    if (idx > -1) { this.items.splice(idx, 1); showToast("Removed from wishlist", "info"); }
    else { this.items.push(product); showToast("Added to wishlist", "success"); }
    this.save();
  },
  has(id) { return this.items.some(i => i.id === id); }
};

/* ════════════════════
   ADDRESSES
════════════════════ */
const addresses = {
  list: JSON.parse(localStorage.getItem("rd_addresses") || "[]"),
  save() { localStorage.setItem("rd_addresses", JSON.stringify(this.list)); },
  add(addr) { this.list.push({ ...addr, id: Date.now() }); this.save(); },
  remove(id) { this.list = this.list.filter(a => a.id !== id); this.save(); },
  setDefault(id) { this.list.forEach(a => a.isDefault = (a.id === id)); this.save(); }
};

/* ════════════════════
   PRODUCT CARD
════════════════════ */
function productCard(p) {
  const cat = MOCK.categories.find(c => c.id === p.category_id);
  return `
    <div class="product-card" data-product-id="${p.id}">
      ${p.image
        ? `<img src="${p.image}" alt="${p.name}" class="product-card-img" loading="lazy" />`
        : `<div class="product-card-img-placeholder">No Image</div>`}
      <div class="product-card-overlay">
        <button class="product-card-add" onclick="quickAddToCart(${p.id}, event)">Quick Add</button>
      </div>
      <div class="product-card-body">
        <p class="product-card-cat">${cat ? cat.name : ''}</p>
        <h3 class="product-card-name">${p.name}</h3>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <p class="product-card-price">${formatPrice(p.price)}</p>
          <button onclick="wishlist.toggle(${JSON.stringify(p).replace(/"/g,'&quot;')});event.stopPropagation();" style="background:none;border:none;cursor:pointer;color:${wishlist.has(p.id)?'var(--blood)':'var(--wire)'};font-size:14px;transition:color 0.2s;" title="Wishlist">♡</button>
        </div>
      </div>
    </div>`;
}

function bindProductCards() {
  document.querySelectorAll(".product-card[data-product-id]").forEach(card => {
    card.onclick = (e) => {
      if (e.target.tagName === "BUTTON" || e.target.closest("button")) return;
      router.navigate("product", { id: card.dataset.productId });
    };
  });
}

async function quickAddToCart(id, e) {
  e.stopPropagation();
  const p = await fetchStore("product", { id });
  if (p && p.stock > 0) { cart.add(p, 1); openCartDrawer(); }
  else showToast("Out of stock", "error");
}

/* ════════════════════
   ROUTER
════════════════════ */
let currentStep = 1;
let shopCatId = null;
let shopProducts = [];
let currentProductObj = null;
let currentQty = 1;

const router = {
  init() { window.addEventListener("hashchange", () => this.resolve()); this.resolve(); },
  navigate(view, params = {}) {
    let hash = `#${view}`;
    const qs = new URLSearchParams(params).toString();
    if (qs) hash += `?${qs}`;
    window.location.hash = hash;
  },
  resolve() {
    const raw = window.location.hash.slice(1) || "home";
    const [view, qs] = raw.split("?");
    const params = Object.fromEntries(new URLSearchParams(qs || ""));
    document.querySelectorAll(".view-section").forEach(s => s.classList.remove("active"));
    const target = document.getElementById(`view-${view}`);
    if (target) target.classList.add("active");
    else document.getElementById("view-home").classList.add("active");
    document.title = `REIDROP — ${view.charAt(0).toUpperCase() + view.slice(1)}`;
    window.scrollTo({ top: 0, behavior: "instant" });
    closeCartDrawer(); closeMobileNav();
    this.onRoute(view, params);
  },
  onRoute(view, params) {
    switch(view) {
      case "home":        renderHome(); break;
      case "shop":        renderShop(params.category); break;
      case "product":     renderProduct(params.id); break;
      case "collections": renderCollections(); break;
      case "sale":        renderSale(); break;
      case "cart":        renderCart(); break;
      case "checkout":    renderCheckout(); break;
      case "search":      renderSearchPage(params.q); break;
      case "faq":         renderFaq(); break;
      case "dashboard":   renderDashboard(); break;
      case "orders":      if(params.email){document.getElementById("orders-email").value=params.email;lookupOrders();} break;
    }
  }
};

