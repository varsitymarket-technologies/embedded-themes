async function renderShop(category) {
  const [products, cats] = await Promise.all([fetchStore("products"), fetchStore("categories")]);
  shopProducts = products;
  const fEl = document.getElementById("shop-cat-filter");
  fEl.innerHTML = `<button onclick="shopFilter(null)" style="display:block;width:100%;text-align:left;background:none;border:none;cursor:pointer;padding:8px 0;font-size:13px;font-family:'Barlow',sans-serif;border-bottom:1px solid var(--wire);color:${shopCatId===null?'var(--white)':'var(--ash)'};transition:color 0.2s;">All Products</button>`
    + cats.map(c => `<button onclick="shopFilter(${c.id})" style="display:block;width:100%;text-align:left;background:none;border:none;cursor:pointer;padding:8px 0;font-size:13px;font-family:'Barlow',sans-serif;border-bottom:1px solid var(--wire);color:${shopCatId===c.id?'var(--white)':'var(--ash)'};transition:color 0.2s;">${c.name}</button>`).join("");
  if (category) shopCatId = parseInt(category);
  buildShopGrid();
}

function shopFilter(id) { shopCatId = id; buildShopGrid(); }

function buildShopGrid() {
  let list = shopCatId ? shopProducts.filter(p => p.category_id === shopCatId) : shopProducts;
  const sort = document.getElementById("shop-sort")?.value || "default";
  if (sort === "price-asc") list = [...list].sort((a,b) => a.price - b.price);
  if (sort === "price-desc") list = [...list].sort((a,b) => b.price - a.price);
  const ct = document.getElementById("shop-count");
  if (ct) ct.textContent = `${list.length} ITEMS`;
  const grid = document.getElementById("shop-grid");
  if (!grid) return;
  if (!list.length) { grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:80px 0;color:var(--wire);font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:0.05em;">No Products Found</div>`; return; }
  grid.innerHTML = list.map(productCard).join("");
  bindProductCards();
}

