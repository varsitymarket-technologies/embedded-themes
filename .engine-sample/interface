  currentQty = 1;
  document.getElementById("product-qty").textContent = 1;
  const p = await fetchStore("product", { id });
  if (!p) { showToast("Product not found", "error"); router.navigate("shop"); return; }
  currentProductObj = p;
  const cat = MOCK.categories.find(c => c.id === p.category_id);
  document.getElementById("prod-bc").textContent = p.name;
  document.getElementById("product-cat").textContent = cat ? cat.name : "";
  document.getElementById("product-name").textContent = p.name;
  document.getElementById("product-price").textContent = formatPrice(p.price);
