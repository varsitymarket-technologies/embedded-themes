  else { sb.innerHTML = `<span style="background:var(--shaft);color:var(--ash);border:1px solid var(--wire);padding:4px 12px;font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.15em;text-transform:uppercase;">Sold Out</span>`; addBtn.disabled = true; addBtn.style.opacity = "0.4"; }
