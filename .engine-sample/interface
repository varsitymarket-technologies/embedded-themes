function cartUpdate(id, qty) { cart.update(id, qty); renderCart(); renderCartDrawer(); }
function cartRemove(id) { cart.remove(id); renderCart(); renderCartDrawer(); }

async function applyDiscount() {
  const code = document.getElementById("discount-input").value.trim();
  const discounts = await fetchStore("discounts");
  const result = cart.applyCode(code, discounts);
  const res = document.getElementById("discount-result");
  if (result) { res.textContent = `✓ ${result.pct}% off applied — saving ${formatPrice(result.amount)}`; res.style.color="var(--blood)"; showToast(`${result.pct}% discount applied!`); renderCart(); }
  else { res.textContent = "✕ Invalid or expired code"; res.style.color="var(--ember)"; }
}

function renderCheckout() {
  currentStep = 1; showCheckoutStep(1);
  const items = document.getElementById("co-order-items");
  items.innerHTML = cart.items.map(i => `<div style="display:flex;gap:12px;align-items:center;margin-bottom:12px;"><img src="${i.image}" style="width:48px;height:60px;object-fit:cover;background:var(--shaft);flex-shrink:0;"/><div style="flex:1;min-width:0;"><div style="font-size:12px;color:var(--white);">${i.name}</div><div class="font-mono" style="font-size:10px;color:var(--ash);">× ${i.qty}</div></div><div class="font-mono" style="font-size:12px;">${formatPrice(i.price*i.qty)}</div></div>`).join("");
  const sub = cart.subtotal();
  document.getElementById("co-sub").textContent = formatPrice(sub);
  document.getElementById("co-ship").textContent = formatPrice(80);
  document.getElementById("co-total").textContent = formatPrice(sub + 80);
}

function showCheckoutStep(n) {
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById(`co-step-${i}`);
    if (el) el.style.display = i === n ? "block" : "none";
    const dot = document.getElementById(`step-dot-${i}`);
    if (dot) { dot.classList.remove("active","done"); if (i < n) dot.classList.add("done"); else if (i === n) dot.classList.add("active"); }
  }
}

function checkoutNext() {
  if (currentStep === 1) { const e = document.getElementById("co-email").value, f = document.getElementById("co-fname").value; if (!e || !f) { showToast("Please fill required fields","error"); return; } }
  currentStep++; showCheckoutStep(currentStep);
}
function checkoutBack() { currentStep--; showCheckoutStep(currentStep); }

async function placeOrder() {
  const orderId = "RD-" + Math.floor(10000 + Math.random() * 90000);
  const body = { name: `${document.getElementById("co-fname").value} ${document.getElementById("co-lname").value}`, email: document.getElementById("co-email").value, total: cart.subtotal(), items: JSON.stringify(cart.items.map(i=>({id:i.id,name:i.name,qty:i.qty,price:i.price}))) };
  try { const url = new URL("api.php?state=order", window.location.href); await fetch(url, { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify(body), signal: AbortSignal.timeout(5000) }); } catch {}

  // Add to user's mock order history
  const u = auth.getUser();
  if (u) {
    u.orders = u.orders || [];
    u.orders.unshift({ id: orderId, date: new Date().toLocaleDateString(), total: cart.subtotal(), status: "processing", items: cart.items });
    auth.setUser(u);
  }

  document.getElementById("co-order-num").textContent = `Order Reference: ${orderId}`;
  currentStep = 4; showCheckoutStep(4);
  cart.clear();
}

