    }
    .sidebar-nav-item:hover { color: var(--white); background: var(--shaft); }
    .sidebar-nav-item.active { color: var(--white); background: var(--shaft); border-left-color: var(--blood); }
    .sidebar-nav-icon { font-size: 15px; flex-shrink: 0; }
    .sidebar-logout { margin-top: auto; padding: 14px 28px; display: flex; align-items: center; gap: 14px; cursor: pointer; color: var(--blood); font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: all 0.2s; background: none; border: none; width: 100%; text-align: left; border-top: 1px solid var(--wire); margin-top: 16px; }
    .sidebar-logout:hover { color: var(--crimson); background: rgba(192,0,10,0.08); }

    /* ── DASHBOARD CONTENT ── */
    .dashboard-content { padding: 48px; }
    .dash-panel { display: none; }
    .dash-panel.active { display: block; }
    .dash-page-title { font-family: 'Bebas Neue', sans-serif; font-size: 42px; color: var(--white); letter-spacing: 0.05em; margin-bottom: 8px; }
    .dash-page-sub { font-family: 'IBM Plex Mono', monospace; font-size: 10px; color: var(--ash); letter-spacing: 0.1em; margin-bottom: 36px; }
    .dash-stat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-bottom: 40px; }
    .dash-stat { background: var(--pit); border: 1px solid var(--wire); padding: 24px; }
    .dash-stat-label { font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ash); margin-bottom: 10px; }
    .dash-stat-value { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--white); letter-spacing: 0.05em; }
    .dash-stat-value.highlight { color: var(--blood); }

    /* ── ORDERS TABLE ── */
    .orders-table { width: 100%; border-collapse: collapse; }
    .orders-table th { padding: 12px 16px; text-align: left; font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blood); border-bottom: 1px solid var(--wire); }
    .orders-table td { padding: 16px; border-bottom: 1px solid var(--shaft); font-size: 13px; color: var(--bone); vertical-align: middle; }
    .orders-table tr:hover td { background: var(--shaft); }
    .order-status { display: inline-block; padding: 3px 10px; font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; }
    .status-delivered { background: rgba(0,180,0,0.12); color: #4ade80; border: 1px solid rgba(0,180,0,0.25); }
    .status-processing { background: rgba(192,0,10,0.12); color: var(--ember); border: 1px solid rgba(192,0,10,0.25); }
    .status-shipped { background: rgba(100,100,255,0.12); color: #93c5fd; border: 1px solid rgba(100,100,255,0.25); }
    .status-pending { background: var(--shaft); color: var(--ash); border: 1px solid var(--wire); }

    /* ── ADDRESS CARDS ── */
    .address-card { background: var(--pit); border: 1px solid var(--wire); padding: 24px; position: relative; }
    .address-card.default-card { border-color: var(--blood); }
    .address-default-badge { position: absolute; top: -1px; right: 20px; background: var(--blood); color: var(--white); font-family: 'IBM Plex Mono', monospace; font-size: 9px; letter-spacing: 0.15em; padding: 3px 10px; text-transform: uppercase; }

    /* ── WISHLIST ── */
    .wishlist-item { display: flex; gap: 20px; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--shaft); }

    /* ── ACCOUNT EDIT FORM ── */
    .account-section { background: var(--pit); border: 1px solid var(--wire); padding: 32px; margin-bottom: 24px; }
    .account-section-title { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--white); margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid var(--wire); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .hero-right { display: none; }
      .hero-left { padding: 80px 40px; }
      .dashboard-layout { grid-template-columns: 1fr; }
      .dashboard-sidebar { position: static; height: auto; border-right: none; border-bottom: 1px solid var(--wire); padding: 24px 0; }
      .sidebar-nav { flex-direction: row; flex-wrap: wrap; padding: 0 16px; gap: 8px; }
      .sidebar-nav-item { border-left: none; border-bottom: 3px solid transparent; padding: 10px 16px; }
      .sidebar-nav-item.active { border-bottom-color: var(--blood); border-left: none; }
      .dashboard-content { padding: 32px 24px; }
      .dash-stat-grid { grid-template-columns: repeat(2,1fr); }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
      .value-bar-inner { grid-template-columns: repeat(2,1fr); }
      #site-header nav { padding: 0 20px; }
      .page-inner { padding: 0 20px; }
      footer { padding: 48px 20px 24px; }
      .dash-stat-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
      .value-bar-inner { grid-template-columns: 1fr; }
      .dash-stat-grid { grid-template-columns: 1fr 1fr; }
      .dashboard-content { padding: 24px 16px; }
    }
  </style>
</head>
