            route() {
                const raw = window.location.hash.slice(1) || "home";
                const [view, qs] = raw.split("?");
                const params = Object.fromEntries(new URLSearchParams(qs || ""));

                document.querySelectorAll(".view-section").forEach(s => s.classList.remove("active"));
                const target = document.getElementById(`view-${view}`);
                if (target) {
                    target.classList.add("active");
                } else {
                    document.getElementById("view-home")?.classList.add("active");
                }

                // Update document title and meta
                updatePageMeta(view, params);

                this.onRoute(view, params);
                window.scrollTo({ top: 0, behavior: "instant" });
                closeMobileMenu();
            },

            onRoute(view, params) {
                currentPage = view;
                
                if (view === "home") renderHome();
                else if (view === "shop") renderShop();
                else if (view === "product") renderProductDetail(params.id);
                else if (view === "collections") renderCollections();
                else if (view === "sale") renderSale();
                else if (view === "cart") renderCart();
                else if (view === "checkout") renderCheckout();
                else if (view === "search") renderSearch(params.q);
                else if (view === "orders") renderOrderHistory();
                else if (view === "account") renderAccount();
                else if (view === "about") renderAbout();
                else if (view === "contact") renderContact();
                else if (view === "faq") renderFAQ();
                else if (view === "track") renderTrack();
                else if (view === "terms") renderTerms();
            }
