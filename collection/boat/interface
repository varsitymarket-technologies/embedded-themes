        function sortProducts(sortBy) {
            currentSort = sortBy;
            if (sortBy === 'price-low') {
                filteredProducts.sort((a, b) => a.price - b.price);
            } else if (sortBy === 'price-high') {
                filteredProducts.sort((a, b) => b.price - a.price);
            } else if (sortBy === 'popular') {
                // Mock popularity sort
                filteredProducts.sort((a, b) => b.stock - a.stock);
            } else {
                // newest (default)
                filteredProducts = [...allProducts];
            }
            currentPage_pagination = 1;
            renderProducts(filteredProducts);
        }

        function renderProducts(products) {
            const start = (currentPage_pagination - 1) * PRODUCTS_PER_PAGE;
            const end = start + PRODUCTS_PER_PAGE;
            const paginatedProducts = products.slice(start, end);

            const container = document.getElementById("shop-products");
            container.innerHTML = paginatedProducts.map(p => createProductCard(p)).join("");

            // Render pagination
            const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);
            const paginationContainer = document.getElementById("pagination");
            let paginationHTML = '';

            if (currentPage_pagination > 1) {
                paginationHTML += `<button onclick="goToPage(${currentPage_pagination - 1})">← Previous</button>`;
            }

            for (let i = 1; i <= totalPages; i++) {
                if (i === currentPage_pagination) {
                    paginationHTML += `<button class="active">${i}</button>`;
                } else {
                    paginationHTML += `<button onclick="goToPage(${i})">${i}</button>`;
                }
            }

            if (currentPage_pagination < totalPages) {
                paginationHTML += `<button onclick="goToPage(${currentPage_pagination + 1})">Next →</button>`;
            }

            paginationContainer.innerHTML = paginationHTML;
        }

        function goToPage(page) {
            currentPage_pagination = page;
            renderProducts(filteredProducts);
            window.scrollTo({ top: 400, behavior: "smooth" });
