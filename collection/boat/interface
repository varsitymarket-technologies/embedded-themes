                <div style="margin-bottom: 16px;">
                    <div style="display: flex; gap: 12px; margin-bottom: 8px;">
                        <div style="width: 20px; height: 20px; background: var(--success); border-radius: 50%; flex-shrink: 0;"></div>
                        <div>
                            <div style="font-weight: 600;">Order Placed</div>
                            <div style="color: var(--muted); font-size: 0.9rem;">June 1, 2024</div>
