                    </div>
                    <button class="btn btn-sm btn-secondary" onclick="cart.remove(${item.id})">✕</button>
                </div>
            `).join("");

            const subtotal = cart.subtotal();
            const discount = appliedDiscount ? appliedDiscount.amount : 0;
            const shipping = subtotal > 100 ? 0 : 10;
            const total = subtotal - discount + shipping;

            document.getElementById("cart-drawer-total").textContent = formatPrice(total);
        }

        function applyDiscount() {
            const code = document.getElementById("discount-code").value.toUpperCase();
            const discount = cart.applyDiscount(code, MOCK.discounts);
            if (discount) {
                appliedDiscount = discount;
                showToast(`Discount applied: ${discount.code}`, "success");
                renderCart();
            } else {
                showToast("Invalid discount code", "error");
            }
        }

        // ====== CHECKOUT PAGE ======
        function renderCheckout() {
            if (cart.items.length === 0) {
                goTo("cart");
                return;
            }

            renderCheckoutForm();
            renderCheckoutItems();
        }

        function renderCheckoutForm() {
            const container = document.getElementById("checkout-form-container");
            const forms = {
                1: `
                    <h2 style="margin-bottom: 24px; font-weight: 700;">Shipping Information</h2>
                    <form onsubmit="nextCheckoutStep(event)">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" required>
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" required>
                        </div>
                        <div class="form-group">
                            <label>Phone</label>
                            <input type="tel" required>
                        </div>
                        <div class="form-group">
                            <label>Address</label>
                            <input type="text" required>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div class="form-group">
                                <label>City</label>
                                <input type="text" required>
                            </div>
                            <div class="form-group">
                                <label>State</label>
                                <input type="text" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Zip Code</label>
                            <input type="text" required>
                        </div>
                        <button type="submit" class="btn btn-primary" style="color: white;">Continue to Shipping</button>
                    </form>
                `,
                2: `
                    <h2 style="margin-bottom: 24px; font-weight: 700;">Shipping Method</h2>
                    <form onsubmit="nextCheckoutStep(event)">
                        <div style="margin-bottom: 16px;">
                            <label style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--surface); border-radius: 6px; cursor: pointer;">
                                <input type="radio" name="shipping" value="standard" checked>
                                <div>
                                    <div style="font-weight: 600;">Standard Shipping (5-7 days)</div>
                                    <div style="color: var(--muted); font-size: 0.9rem;">e(__SYSTEM_CURRENCY__) 10.00</div>
                                </div>
                            </label>
                        </div>
                        <div style="margin-bottom: 16px;">
                            <label style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--surface); border-radius: 6px; cursor: pointer;">
                                <input type="radio" name="shipping" value="express">
                                <div>
                                    <div style="font-weight: 600;">Express Shipping (2-3 days)</div>
                                    <div style="color: var(--muted); font-size: 0.9rem;">e(__SYSTEM_CURRENCY__) 25.00</div>
                                </div>
                            </label>
                        </div>
                        <button type="submit" class="btn btn-primary" style="color: white;">Continue to Payment</button>
                    </form>
                `,
                3: `
                    <h2 style="margin-bottom: 24px; font-weight: 700;">Payment Information</h2>
                    <form onsubmit="nextCheckoutStep(event)">
                        <div class="form-group">
                            <label>Card Number</label>
                            <input type="text" placeholder="1234 5678 9012 3456" required>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div class="form-group">
                                <label>Expiry Date</label>
                                <input type="text" placeholder="MM/YY" required>
                            </div>
                            <div class="form-group">
                                <label>CVC</label>
                                <input type="text" placeholder="123" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" style="color: white;">Complete Order</button>
                    </form>
                `,
                4: `
                    <div style="text-align: center; padding: 60px 0;">
                        <div style="font-size: 3rem; margin-bottom: 20px;">✓</div>
                        <h2 style="margin-bottom: 12px; font-weight: 700;">Order Confirmed!</h2>
                        <p style="color: var(--muted); margin-bottom: 24px;">Thank you for your purchase. Your order has been placed successfully.</p>
                        <p style="margin-bottom: 24px;">Order Number: <strong>ORD-${Date.now().toString().slice(-6)}</strong></p>
                        <a href="#home" class="btn btn-primary" style="color: white;">Continue Shopping</a>
                    </div>
                `
            };

            container.innerHTML = forms[currentCheckoutStep] || forms[1];
        }

        function renderCheckoutItems() {
            const container = document.getElementById("checkout-items");
            container.innerHTML = cart.items.map(item => `
                <div style="display: flex; gap: 12px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border);">
                    <img src="${item.images?.[0] || item.image}" alt="${item.name}" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px;">
                    <div style="flex: 1;">
                        <div style="font-weight: 600; margin-bottom: 4px;">${item.name}</div>
                        <div style="color: var(--muted); font-size: 0.9rem;">Qty: ${item.qty}</div>
                    </div>
                    <div style="font-weight: 700;">${formatPrice(item.price * item.qty)}</div>
                </div>
            `).join("");

            const subtotal = cart.subtotal();
            const discount = appliedDiscount ? appliedDiscount.amount : 0;
            const shipping = subtotal > 100 ? 0 : 10;
            const total = subtotal - discount + shipping;

            document.getElementById("checkout-total").textContent = formatPrice(total);
        }

        function nextCheckoutStep(e) {
            e.preventDefault();
            if (currentCheckoutStep < 4) {
                currentCheckoutStep++;
                updateCheckoutSteps();
                renderCheckout();
            } else {
                // Submit order to API
                submitOrder();
            }
        }

        function updateCheckoutSteps() {
            document.querySelectorAll(".step").forEach(step => {
                const stepNum = parseInt(step.dataset.step);
                step.classList.toggle("active", stepNum === currentCheckoutStep);
                step.querySelector(".step-number").style.background = stepNum <= currentCheckoutStep ? "var(--accent)" : "var(--surface)";
                step.querySelector(".step-number").style.color = stepNum <= currentCheckoutStep ? "white" : "var(--text)";
            });
        }

        async function submitOrder() {
            try {
                // Try to submit to API
                const response = await fetch('/api/store/order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        items: cart.items,
                        discount: appliedDiscount,
                        total: cart.subtotal() - (appliedDiscount?.amount || 0) + 10
                    })
                });

                if (!response.ok) throw new Error('Order submission failed');
            } catch (error) {
                console.warn('API order submission failed, using local completion:', error);
            }

            // Complete checkout locally
            cart.clear();
            appliedDiscount = null;
            currentCheckoutStep = 4;
            renderCheckout();
            showToast("Order placed successfully!", "success");
        }

        // ====== SEARCH PAGE ======
        let searchTimeout;
        function handleSearch(query) {
            clearTimeout(searchTimeout);
            if (!query) {
                document.getElementById("search-results").innerHTML = '';
                return;
            }

            searchTimeout = setTimeout(() => {
                const results = MOCK.products.filter(p =>
                    p.name.toLowerCase().includes(query.toLowerCase()) ||
                    p.description.toLowerCase().includes(query.toLowerCase())
                );

                const resultsContainer = document.getElementById("search-results");
                if (results.length === 0) {
                    resultsContainer.innerHTML = '<p style="padding: 20px; text-align: center; color: var(--muted);">No products found</p>';
                } else {
                    resultsContainer.innerHTML = results.map(p => `
                        <div class="search-result-item" onclick="goTo('product?id=${p.id}'); toggleSearch()">
                            <div style="font-weight: 600;">${p.name}</div>
                            <div style="color: var(--muted); font-size: 0.9rem;">${formatPrice(p.price)}</div>
                        </div>
                    `).join("");
                }
            }, 300);
        }

        function renderSearch(query) {
            if (!query) {
                document.getElementById("search-page-results").innerHTML = '';
                document.getElementById("search-no-results").style.display = 'block';
                return;
            }

            const results = MOCK.products.filter(p =>
                p.name.toLowerCase().includes(query.toLowerCase()) ||
                p.description.toLowerCase().includes(query.toLowerCase())
            );

            document.getElementById("search-title").textContent = `Search Results for "${query}"`;

            if (results.length === 0) {
                document.getElementById("search-page-results").innerHTML = '';
                document.getElementById("search-no-results").style.display = 'block';
            } else {
                document.getElementById("search-page-results").innerHTML = results.map(p => createProductCard(p)).join("");
                document.getElementById("search-no-results").style.display = 'none';
            }
        }

        // ====== ORDER HISTORY PAGE ======
        function handleOrderLookup(e) {
            e.preventDefault();
            const email = document.getElementById("orders-email").value;
            // Mock: show sample orders
            const orders = MOCK.orders;
            document.getElementById("orders-results").style.display = 'block';
            document.getElementById("orders-list").innerHTML = orders.map(order => `
                <div style="background: var(--surface); padding: 20px; border-radius: 12px; margin-bottom: 16px;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                        <div>
                            <div style="color: var(--muted); font-size: 0.9rem;">Order Number</div>
                            <div style="font-weight: 700;">${order.id}</div>
                        </div>
                        <div>
                            <div style="color: var(--muted); font-size: 0.9rem;">Date</div>
                            <div style="font-weight: 700;">${order.date}</div>
                        </div>
                        <div>
                            <div style="color: var(--muted); font-size: 0.9rem;">Status</div>
                            <div style="font-weight: 700; color: var(--success);">${order.status}</div>
                        </div>
                    </div>
                    <div style="padding-top: 16px; border-top: 1px solid var(--border);">
                        <div style="margin-bottom: 8px;"><strong>Items:</strong></div>
                        ${order.items.map(item => `
                            <div style="color: var(--muted); font-size: 0.9rem; margin-bottom: 4px;">
                                ${item.name} (Qty: ${item.qty}) - ${formatPrice(item.price * item.qty)}
                            </div>
                        `).join('')}
                        <div style="margin-top: 12px; font-weight: 700; font-size: 1.1rem;">Total: ${formatPrice(order.total)}</div>
                    </div>
                </div>
            `).join("");
        }

        // ====== ACCOUNT PAGE ======
        function renderAccount() {
            renderAccountOrders();
            renderAccountAddresses();
        }

        function renderAccountOrders() {
            const container = document.getElementById("account-orders-list");
            container.innerHTML = MOCK.orders.map(order => `
                <div style="background: var(--bg); padding: 16px; border-radius: 6px; margin-bottom: 12px; border: 1px solid var(--border);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <div><strong>${order.id}</strong></div>
                        <div style="color: var(--success);">${order.status}</div>
                    </div>
                    <div style="color: var(--muted); font-size: 0.9rem; margin-bottom: 8px;">${order.date}</div>
                    <div style="font-weight: 700;">${formatPrice(order.total)}</div>
                </div>
            `).join("");
        }

        function renderAccountAddresses() {
            const container = document.getElementById("account-addresses-list");
            const addresses = JSON.parse(localStorage.getItem("vm_addresses") || '[]');
            if (addresses.length === 0) {
                addresses.push({
                    id: 1,
                    name: "Home",
                    address: "123 Main Street",
                    city: "New York",
                    state: "NY",
                    zip: "10001"
                });
            }
            container.innerHTML = addresses.map(addr => `
                <div style="background: var(--bg); padding: 16px; border-radius: 6px; margin-bottom: 12px; border: 1px solid var(--border);">
                    <div style="font-weight: 700; margin-bottom: 8px;">${addr.name}</div>
                    <div style="color: var(--muted); font-size: 0.9rem; margin-bottom: 8px;">
                        ${addr.address}<br>${addr.city}, ${addr.state} ${addr.zip}
                    </div>
                    <button class="btn btn-sm btn-secondary" onclick="editAddress(${addr.id})">Edit</button>
                </div>
            `).join("");
        }

        function showAddAddressForm() {
            showToast("Address management feature coming soon", "info");
        }

        function editAddress(id) {
            showToast("Address editing feature coming soon", "info");
        }

        function switchAccountTab(tab, button) {
            document.querySelectorAll(".account-tab").forEach(t => t.style.display = "none");
            document.getElementById(`account-${tab}`).style.display = "block";
            document.querySelectorAll(".account-menu-link").forEach(b => b.classList.remove("active"));
            button.classList.add("active");
        }

        function handleProfileUpdate(e) {
            e.preventDefault();
            showToast("Profile updated successfully", "success");
        }

        function handleSettingsUpdate(e) {
            e.preventDefault();
            showToast("Settings saved successfully", "success");
        }

        // ====== OTHER PAGES ======
        function renderAbout() {}
        function renderContact() {}
        function renderFAQ() {}
        function renderTrack() {}
        function renderTerms() {}

        function handleContactForm(e) {
            e.preventDefault();
            showToast("Message sent successfully", "success");
            e.target.reset();
        }

        function handleNewsletterSignup(e) {
            e.preventDefault();
