<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MAKHESA | Neo-African Luxury</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --mks-bone: #FDFBF7;
            --mks-dark: #131A26;
            --mks-muted: #626A75;
            --mks-saffron: #E09F3E;
            --mks-border: #E5E0D8;
        }
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
            background-color: var(--mks-bone); 
            color: var(--mks-dark); 
            -webkit-font-smoothing: antialiased;
        }
        .font-display { font-family: 'Syne', sans-serif; font-weight: 800; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: geoFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        
        @keyframes geoFade {
            from { opacity: 0; transform: scale(0.99) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Minimalist Structural Inputs */
        .mks-input { 
            border: 1px solid var(--mks-border); 
            background-color: transparent;
            color: var(--mks-dark);
            padding: 16px;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        .mks-input:focus { 
            outline: none; 
            border-color: var(--mks-dark);
            background-color: #FFFFFF;
        }
        
        /* Sculptural Buttons */
        .btn-mks-dark {
            background-color: var(--mks-dark);
            color: var(--mks-bone);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s ease;
        }
        .btn-mks-dark:hover {
            background-color: #232D3F;
            letter-spacing: 0.15em;
        }

        .btn-mks-outline {
            border: 1px solid var(--mks-dark);
            background-color: transparent;
            color: var(--mks-dark);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.2s ease;
        }
        .btn-mks-outline:hover {
            background-color: var(--mks-dark);
            color: var(--mks-bone);
        }

        /* Custom Scrollbar styling */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--mks-bone); }
        ::-webkit-scrollbar-thumb { background: var(--mks-dark); }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[#131A26] selection:text-white">

    <div class="bg-[var(--mks-dark)] text-[var(--mks-bone)] text-center py-2 text-[11px] tracking-[0.2em] uppercase font-medium border-b border-white/10 px-4 overflow-hidden whitespace-nowrap">
        MAKHESA AUTUMN/WINTER '26 RUNWAY COLLECTION • COMPLIMENTARY DHL EXPRESS DELIVERY
    </div>

    <header class="sticky top-0 bg-[var(--mks-bone)]/90 backdrop-blur-md z-40 border-b border-[var(--mks-border)]">
        <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-10 text-xs font-medium tracking-[0.15em] uppercase">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--mks-saffron)] transition-colors">Collections</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--mks-saffron)] transition-colors">Lineage</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="text-center group">
                <span class="font-display text-3xl tracking-[-0.03em] text-[var(--mks-dark)] block group-hover:opacity-80 transition-opacity">M A K H E S A</span>
            </a>

            <div class="flex items-center space-x-6">
                <button class="hover:text-[var(--mks-saffron)] transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search">
                    <i data-lucide="align-left" class="w-5 h-5 rotate-180"></i>
                </button>
                <button class="hover:text-[var(--mks-saffron)] transition-colors flex items-center relative" onclick="app.ui.toggleCartDrawer()" aria-label="Cart">
                    <i data-lucide="shopping-cart" class="w-5 h-5 stroke-[1.5]"></i>
                    <span id="global-cart-count" class="absolute -top-2 -right-2 text-[9px] bg-[var(--mks-dark)] text-white w-4 h-4 rounded-none flex items-center justify-center opacity-0 transition-opacity font-bold">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="max-w-7xl mx-auto px-6 py-6">
                <div class="relative w-full h-[78vh] min-h-[550px] bg-[#EAE5DF] overflow-hidden flex items-center">
                    <img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?q=80&w=1600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover object-top filter grayscale contrast-110" alt="High-Fashion Editorial Portrait">
                    <div class="absolute inset-0 bg-gradient-to-r from-[var(--mks-dark)]/90 via-[var(--mks-dark)]/40 to-transparent"></div>
                    
                    <div class="relative z-10 max-w-2xl pl-8 md:pl-16 text-[var(--mks-bone)]">
                        <span class="text-xs font-medium tracking-[0.3em] uppercase text-[var(--mks-saffron)] mb-4 block">Chapter III: Geometric Ancestry</span>
                        <h1 class="font-display text-5xl sm:text-7xl leading-[0.95] mb-8 uppercase">Symmetry<br>In Motion.</h1>
                        <p class="text-[var(--mks-bone)]/80 text-sm leading-relaxed mb-10 max-w-sm font-light">A contemporary dialogue between structural Southern African knitwear matrices and razor-sharp modern tailoring.</p>
                        <button onclick="app.router.navigate('shop')" class="px-10 py-5 btn-mks-dark text-xs">
                            View Lookbook Edit
                        </button>
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-6 mt-20 mb-8 flex justify-between items-end">
                <div>
                    <span class="text-xs uppercase tracking-widest text-[var(--mks-muted)]">Immediate Access</span>
                    <h2 class="font-display text-2xl uppercase mt-1">Signature Garments</h2>
                </div>
                <a href="#shop" onclick="app.router.navigate('shop')" class="text-xs uppercase tracking-wider font-semibold border-b border-black pb-1 hover:text-[var(--mks-saffron)] hover:border-[var(--mks-saffron)] transition-colors">See All Work</a>
            </div>

            <div class="max-w-7xl mx-auto px-6 mb-24 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="group cursor-pointer" onclick="app.router.navigate('product', {id: 'mks-01'})">
                    <div class="bg-white border border-[var(--mks-border)] aspect-[3/4] overflow-hidden p-4 mb-4 flex items-center justify-center">
                        <img src="https://images.unsplash.com/photo-1618335829737-2228915674e0?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700">
                    </div>
                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Koko Structural Cardigan</span>
                        <span class="text-[var(--mks-muted)]">$310</span>
                    </div>
                </div>
                <div class="group cursor-pointer" onclick="app.router.navigate('product', {id: 'mks-02'})">
                    <div class="bg-white border border-[var(--mks-border)] aspect-[3/4] overflow-hidden p-4 mb-4 flex items-center justify-center">
                        <img src="https://images.unsplash.com/photo-1544816155-12df9643f363?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700">
                    </div>
                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Symmetry Geometric Tote</span>
                        <span class="text-[var(--mks-muted)]">$185</span>
                    </div>
                </div>
                <div class="group cursor-pointer" onclick="app.router.navigate('product', {id: 'mks-03'})">
                    <div class="bg-white border border-[var(--mks-border)] aspect-[3/4] overflow-hidden p-4 mb-4 flex items-center justify-center">
                        <img src="https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700">
                    </div>
                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Lefa Tailored Trouser</span>
                        <span class="text-[var(--mks-muted)]">$240</span>
