                    <span class="text-xs uppercase tracking-widest text-[var(--mks-muted)]">Estimated Settlement</span>
                    <span id="cart-drawer-subtotal" class="font-display text-xl">$0.00</span>
                </div>
                <button onclick="app.checkout.initiateCheckout()" class="w-full py-5 btn-mks-dark text-xs">
                    Transfer to Execution
                </button>
            </div>
        </div>
