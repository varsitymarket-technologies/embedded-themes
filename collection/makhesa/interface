    <div id="search-overlay" class="fixed inset-0 bg-[var(--mks-dark)] z-50 hidden flex-col px-8 py-12 transition-all duration-300">
        <div class="max-w-3xl mx-auto w-full flex items-center relative border-b border-[var(--mks-bone)]/20 pb-4">
            <input type="text" id="live-search-input" oninput="app.store.handleSearch(this.value)" placeholder="INPUT DESIGN QUERIES..." class="w-full bg-transparent text-xl sm:text-3xl font-display text-[var(--mks-bone)] focus:outline-none placeholder:text-white/10 uppercase tracking-widest">
            <button onclick="app.ui.toggleSearchOverlay()" class="text-[var(--mks-bone)]/50 hover:text-white">
                <i data-lucide="corner-right-down" class="w-6 h-6"></i>
            </button>
        </div>
        <div class="max-w-3xl mx-auto w-full mt-12">
            <div id="search-results-output" class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[65vh] overflow-y-auto"></div>
        </div>
    </div>

    <div id="toast-notif" class="fixed bottom-6 right-6 bg-[var(--mks-dark)] text-[var(--mks-bone)] text-xs font-semibold uppercase tracking-wider py-4 px-8 rounded-none shadow-2xl z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none border border-white/10">
        <span id="toast-notif-message">Allocation Indexed.</span>
    </div>

    <footer class="bg-[var(--mks-dark)] text-[var(--mks-bone)] pt-20 pb-10 border-t border-white/5 text-xs font-light">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 mb-20">
            <div class="md:col-span-5 space-y-4">
                <span class="font-display text-2xl tracking-tighter block text-[var(--mks-bone)]">M A K H E S A</span>
                <p class="text-white/60 leading-relaxed max-w-sm">An architectural fashion system preserving southern structural lineages through premium, sustainable textile expressions. Handcrafted iteratively.</p>
            </div>
            <div class="md:col-span-3 space-y-2">
                <h4 class="text-white/30 uppercase tracking-[0.2em] text-[10px] font-bold mb-4">Navigation Index</h4>
                <a href="#shop" onclick="app.router.navigate('shop')" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Seasonal Showroom</a>
                <a href="#" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Global Logistics Policy</a>
                <a href="#" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Sartorial Inquiries</a>
            </div>
            <div class="md:col-span-4 space-y-4">
                <h4 class="text-white/30 uppercase tracking-[0.2em] text-[10px] font-bold mb-2">Studio Communications</h4>
                <form onsubmit="event.preventDefault(); app.ui.triggerToast('Subscribed To Digital Dossier');" class="flex border-b border-white/20 pb-1">
                    <input type="email" placeholder="YOUR EMAIL ADDRESS" required class="flex-grow bg-transparent text-xs py-2 text-white placeholder:text-white/20 uppercase tracking-widest focus:outline-none">
                    <button type="submit" class="text-white/40 hover:text-white text-[10px] font-bold tracking-widest uppercase">Register</button>
                </form>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-6 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center text-white/40 text-[11px] gap-4">
            <p>&copy; 2026 MAKHESA Luxury Houses Group. All structural rights retained.</p>
            <div class="flex space-x-6">
                <a href="#" class="hover:text-white">Autonomy Agreements</a>
                <a href="#" class="hover:text-white">Privacy Architecture</a>
            </div>
        </div>
    </footer>

    <script>
        /**
         * Curated Avant-Garde Structural Inventory
         */
        const INVENTORY_DB = [
            { id: 'mks-01', name: 'Koko Structural Knit Cardigan', price: 310.00, category: 'Apparel', material: '100% Merino Blend', images: ['https://images.unsplash.com/photo-1618335829737-2228915674e0?q=80&w=800&auto=format&fit=crop'], desc: 'Engineered with signature high-density structural weight weaving, illustrating regional geometric formations along the spatial torso panels.' },
            { id: 'mks-02', name: 'Symmetry Geometric Tote', price: 185.00, category: 'Accessories', material: 'Sculpted Organic Canvas & Calfskin', images: ['https://images.unsplash.com/photo-1544816155-12df9643f363?q=80&w=800&auto=format&fit=crop'], desc: 'An ultra-rigid geometric carryall mapping out high contrast lineal expressions. Fitted with an interior brushed nickel authentication badge.' },
            { id: 'mks-03', name: 'Lefa Pleated Tailored Trouser', price: 240.00, category: 'Apparel', material: 'Raw Flax Mercerized Linen', images: ['https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?q=80&w=800&auto=format&fit=crop'], desc: 'Crisp, structural dual pleat construction with specialized asymmetrical fastening layers designed to cascade elegantly across high-profile footwear profiles.' },
            { id: 'mks-04', name: 'Lineage Merino Knit Shawl', price: 150.00, category: 'Accessories', material: 'Extra-Fine Merino Wool', images: ['https://images.unsplash.com/photo-1601924994987-69e26d50dc26?q=80&w=800&auto=format&fit=crop'], desc: 'A heavily dense graphic overlay format piece showcasing historical modular repeating motifs in monochromatic layout presentation.' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1, chosenSize: null },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- SINGLE PAGE APPARATUS ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                
                if (view === '#shop') { app.store.filterCatalog('all'); } 
                else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } 
                else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0, behavior: 'auto'});
            }
        };

        // --- PRODUCTION LOGISTICS CATALOG ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="group cursor-pointer flex flex-col bg-white border border-[var(--mks-border)] p-4 relative" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[3/4] w-full overflow-hidden bg-[var(--mks-bone)] mb-4 relative">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700">
                        </div>
                        <div class="flex justify-between items-baseline mt-2">
                            <h3 class="text-sm font-medium text-[var(--mks-dark)] group-hover:text-[var(--mks-saffron)] transition-colors">${item.name}</h3>
                            <span class="text-xs font-semibold text-[var(--mks-muted)] ml-2">$${item.price.toFixed(2)}</span>
                        </div>
                        <span class="text-[10px] text-[var(--mks-muted)] uppercase tracking-widest mt-1">${item.material}</span>
                    </div>`).join('');
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB];
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            selectSize: function(sz) {
                app.state.chosenSize = sz;
                document.querySelectorAll('.btn-sz-node').forEach(b => b.className = "btn-sz-node border border-[var(--mks-border)] py-3 font-medium text-xs text-center transition-all bg-transparent");
                event.target.className = "btn-sz-node border border-[var(--mks-dark)] py-3 font-medium text-xs text-center transition-all bg-[var(--mks-dark)] text-[var(--mks-bone)]";
                document.getElementById('sz-err-prompt').classList.add('hidden');
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                app.state.chosenSize = null;

                const sizingNodes = ['STUDIO SIZE 01 / XS', 'STUDIO SIZE 02 / S', 'STUDIO SIZE 03 / M', 'STUDIO SIZE 04 / L', 'STUDIO SIZE 05 / XL'];

                document.getElementById('product-detail-target').innerHTML = `
                    <div class="w-full lg:col-span-7 bg-white border border-[var(--mks-border)] p-4">
                        <div class="aspect-[3/4] overflow-hidden bg-[var(--mks-bone)]">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-700">
                        </div>
                    </div>
                    <div class="w-full lg:col-span-5 flex flex-col justify-center">
                        <span class="text-[10px] font-bold text-[var(--mks-saffron)] tracking-[0.25em] uppercase mb-2 block">${item.category} // ${item.material}</span>
                        <h1 class="font-display text-3xl sm:text-4xl text-[var(--mks-dark)] uppercase leading-tight mb-4">${item.name}</h1>
                        <p class="text-xl font-semibold mb-8">$${item.price.toFixed(2)}</p>
                        
                        <div class="mb-8">
                            <span class="text-xs font-semibold tracking-widest uppercase text-[var(--mks-muted)] block mb-3">Measurement Metric</span>
                            <div class="grid grid-cols-1 gap-2">
                                ${sizingNodes.map(sz => `<button onclick="app.store.selectSize('${sz}')" class="btn-sz-node border border-[var(--mks-border)] py-3 font-medium text-xs text-center transition-all hover:border-black">${sz}</button>`).join('')}
                            </div>
                            <span id="sz-err-prompt" class="text-red-600 text-xs font-medium mt-2 hidden">Explicit silhouette allocation size is required.</span>
                        </div>

                        <button onclick="app.store.executeCartInsertion('${item.id}')" class="w-full py-5 btn-mks-dark text-xs mb-8 flex justify-center items-center gap-2">
                            Index Selection Box
                        </button>
                        
                        <p class="text-[var(--mks-muted)] text-xs sm:text-sm leading-relaxed pb-6 border-b border-[var(--mks-border)]">
                            ${item.desc}
                        </p>
                    </div>`;
                lucide.createIcons();
            },
            executeCartInsertion: function(id) {
                if(!app.state.chosenSize) {
                    document.getElementById('sz-err-prompt').classList.remove('hidden');
                    return;
                }
                app.cart.addItem(id, app.state.chosenSize);
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="flex items-center space-x-4 p-4 bg-white border border-[var(--mks-border)] hover:border-black cursor-pointer transition-all">
                        <img src="${i.images[0]}" class="w-12 h-16 object-cover filter grayscale shrink-0">
                        <div class="flex-grow">
                            <span class="block font-display text-sm uppercase text-[var(--mks-dark)]">${i.name}</span>
                            <span class="block text-[10px] text-[var(--mks-muted)] uppercase mt-0.5">${i.material}</span>
                        </div>
                        <span class="text-sm font-semibold">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- LOCALIZED DATA ASSET LEDGER ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('mks_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id, size) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id && item.size === size);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1, size: size });
                this.sync(); app.ui.triggerToast(`GARMENT RECOGNIZED.`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(index, val) { 
                const item = app.state.cart[index]; 
                if (!item) return; 
                item.qty += val; 
                if (item.qty <= 0) app.state.cart.splice(index, 1); 
                this.sync(); 
            },
            sync: function() { localStorage.setItem('mks_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const counterText = document.getElementById('drawer-item-count');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                if (totalItems > 0) { badge.classList.remove('opacity-0'); badge.innerText = totalItems; } else { badge.classList.add('opacity-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                counterText.innerText = `${totalItems} Matrix Units Documented`;
                
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-center text-[var(--mks-muted)] text-xs py-20 uppercase tracking-widest">Registry Vacuum.</div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map((item, idx) => `
                        <div class="flex space-x-4 bg-white border border-[var(--mks-border)] p-4 relative">
                            <img src="${item.product.images[0]}" class="w-16 h-20 object-cover filter grayscale shrink-0">
                            <div class="flex flex-col justify-between flex-grow">
                                <div>
                                    <h4 class="text-sm font-medium text-[var(--mks-dark)] leading-tight mb-0.5">${item.product.name}</h4>
                                    <span class="text-[10px] text-[var(--mks-muted)] block uppercase">${item.size}</span>
                                </div>
                                <div class="flex justify-between items-center mt-2">
                                    <div class="flex items-center space-x-3 border border-[var(--mks-border)] px-2 py-0.5 text-xs">
                                        <button onclick="app.cart.updateQty(${idx}, -1)" class="text-[var(--mks-muted)] hover:text-black">&minus;</button>
                                        <span class="font-medium text-xs w-4 text-center">${item.qty}</span>
                                        <button onclick="app.cart.updateQty(${idx}, 1)" class="text-[var(--mks-muted)] hover:text-black">&plus;</button>
                                    </div>
                                    <span class="text-xs font-semibold">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>`).join('');
                }
            }
        };

        // --- TRANSACTION PLATFORM GATEWAY ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-sub').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex justify-between items-center py-2 text-xs">
                        <span class="text-[var(--mks-dark)] truncate max-w-[180px]">${i.product.name} (x${i.qty})</span>
                        <span class="text-[var(--mks-muted)] font-medium">$${(i.product.price * i.qty).toFixed(2)}</span>
                    </div>`).join('');
                
                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <input type="email" required placeholder="DIGITAL COMMS EMAIL" class="w-full mks-input">
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" required placeholder="FIRST INSCRIPTION" class="w-full mks-input">
                            <input type="text" required placeholder="SURNAME MATRIC" class="w-full mks-input">
                        </div>
                        <input type="text" required placeholder="DESTINATION STREET LOCATION" class="w-full mks-input">
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" required placeholder="CITY CENTRIC" class="w-full mks-input">
                            <input type="text" required placeholder="ROUTING POSTAL ZIP" class="w-full mks-input">
                        </div>`; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <div class="p-4 bg-[var(--mks-dark)] text-[var(--mks-bone)] text-xs tracking-widest uppercase mb-4">
                            Logistics Mapping Cleared Securely.
                        </div>
                        <input type="text" required placeholder="REMITTANCE CARD ACCT NUMBER" class="w-full mks-input">
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" required placeholder="EXPIRY BOUND (MM/YY)" class="w-full mks-input">
                            <input type="text" required placeholder="SECURITY ACCESS TRIAD (CVC)" class="w-full mks-input">
                        </div>`; 
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                    document.querySelector('#view-checkout button[type="submit"]').innerText = "Finalize Settlement Link";
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    alert("Acquisition documented successfully. Archive allocation verified."); 
                    app.router.navigate('home'); 
                } 
            }
        };

        // --- INTERACTIVE SCREEN INTERFACES ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    return; 
                }
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                }
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); 
                if(msg) document.getElementById('toast-notif-message').innerText = msg;
                t.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none'); 
                }, 3000);
            }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
