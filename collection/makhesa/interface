                <div class="group cursor-pointer" onclick="app.router.navigate('product', {id: 'mks-04'})">
                    <div class="bg-white border border-[var(--mks-border)] aspect-[3/4] overflow-hidden p-4 mb-4 flex items-center justify-center">
                        <img src="https://images.unsplash.com/photo-1601924994987-69e26d50dc26?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700">
                    </div>
                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Lineage Merino Shawl</span>
                        <span class="text-[var(--mks-muted)]">$150</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-6 py-12">
            <div class="flex flex-col sm:flex-row justify-between items-baseline mb-12 border-b border-[var(--mks-border)] pb-6">
                <h2 class="font-display text-3xl uppercase">The Collection Vault</h2>
                <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="bg-transparent text-xs font-semibold uppercase tracking-widest text-[var(--mks-dark)] focus:outline-none cursor-pointer border-0">
                    <option value="featured">Default Ordering</option>
                    <option value="price-low">Price Structure: Low to High</option>
                    <option value="price-high">Price Structure: High to Low</option>
                </select>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-16">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-6 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
                </div>
        </section>

        <section id="view-checkout" class="view-section max-w-4xl mx-auto px-6 py-16">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                
                <div class="lg:col-span-7">
                    <h2 class="font-display text-2xl uppercase mb-8">Consignment Mapping</h2>
                    <form id="checkout-form" onsubmit="app.checkout.handleStepSubmit(event)" class="space-y-4 flex flex-col">
                        <div id="checkout-step-container" class="space-y-4"></div>
                        <button type="submit" class="w-full py-5 btn-mks-dark text-xs mt-6">
                            Authorize Placement
                        </button>
                    </form>
                </div>
                
                <div class="lg:col-span-5 bg-white border border-[var(--mks-border)] p-8 h-fit">
                    <h3 class="text-xs uppercase tracking-[0.2em] font-semibold text-[var(--mks-muted)] mb-6">Selection Statement</h3>
                    <div id="checkout-summary-items" class="space-y-4 mb-6 max-h-[240px] overflow-y-auto split-scrollbar"></div>
                    <div class="space-y-3 pt-6 border-t border-[var(--mks-border)] text-sm">
                        <div class="flex justify-between text-[var(--mks-muted)]"><span>Items Cumulative</span><span id="chk-sub">$0.00</span></div>
                        <div class="flex justify-between text-[var(--mks-muted)]"><span>Secure Logistics</span><span class="text-[var(--mks-dark)] font-medium">Free</span></div>
                        <div class="flex justify-between items-center pt-4 font-display border-t border-[var(--mks-border)] text-lg uppercase">
                            <span>Aggregate</span>
                            <span id="chk-total" class="text-xl">$0.00</span>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-[var(--mks-dark)]/20 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-opacity duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-[440px] bg-[var(--mks-bone)] border-l border-[var(--mks-border)] flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" onclick="event.stopPropagation()">
            
            <div class="p-8 border-b border-[var(--mks-border)] flex items-center justify-between bg-white">
                <div>
                    <h3 class="font-display text-lg uppercase tracking-tight">Cart Registry</h3>
                    <span id="drawer-item-count" class="text-xs text-[var(--mks-muted)]">0 Items Selected</span>
                </div>
                <button onclick="app.ui.toggleCartDrawer()" class="text-[var(--mks-muted)] hover:text-black p-1.5 border border-[var(--mks-border)]">
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </div>
            
            <div id="cart-drawer-items" class="flex-grow overflow-y-auto p-8 space-y-6"></div>
            
            <div class="p-8 bg-white border-t border-[var(--mks-border)]">
