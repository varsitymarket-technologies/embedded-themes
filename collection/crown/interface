                    <span id="global-cart-count" class="absolute -top-1.5 -right-2 text-[9px] bg-[var(--cr-gold)] text-white w-4 h-4 flex items-center justify-center rounded-full opacity-0 font-bold">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

