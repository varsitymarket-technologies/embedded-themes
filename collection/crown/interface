                    <p class="text-sm md:text-base leading-relaxed mb-10 max-w-md font-light text-gray-100">Experience 100% raw virgin hair. Pre-plucked HD lace fronts designed to melt seamlessly into your skin.</p>
                    <button onclick="app.router.navigate('shop')" class="px-10 py-4 bg-[var(--cr-white)] text-[var(--cr-text)] text-xs font-bold uppercase tracking-widest hover:bg-[var(--cr-gold)] hover:text-white transition-colors duration-300">
                        Shop The Look
                    </button>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-2 md:grid-cols-4 gap-8 text-center border-b border-[var(--cr-border)]">
                <div class="space-y-3">
                    <i data-lucide="sparkles" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">100% Virgin Hair</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Cuticle aligned, completely unprocessed human hair.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="scissors" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Pre-Plucked Hairlines</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Ready to wear out of the box with natural baby hairs.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="eye" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Invisible HD Lace</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Ultra-thin Swiss lace that melts into all skin tones.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="truck" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Express Shipping</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Fast, reliable delivery straight to your doorstep.</p>
