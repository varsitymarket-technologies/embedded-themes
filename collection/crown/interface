                <p class="text-sm text-gray-500 mb-12">The pieces everyone is wearing this season.</p>
                <div id="featured-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-left">
                    </div>
                <button onclick="app.router.navigate('shop')" class="mt-12 px-12 py-4 btn-outline text-xs font-bold tracking-widest">
                    View Entire Collection
                </button>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 py-12">
            <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6">
                <h2 class="font-serif-elegant text-4xl">The Boutique</h2>
                <div class="flex gap-4">
                    <button onclick="app.store.filterCatalog('all')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">All</button>
                    <button onclick="app.store.filterCatalog('Wigs')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">HD Wigs</button>
                    <button onclick="app.store.filterCatalog('Bundles')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">Bundles</button>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-12">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                </div>
        </section>

        <section id="view-checkout" class="view-section max-w-5xl mx-auto px-4 py-12">
            <div class="text-center mb-10">
                <h2 class="font-serif-elegant text-4xl mb-2">Secure Checkout</h2>
                <p class="text-gray-500 text-sm">Almost yours.</p>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-7">
                    <div class="flex items-center justify-center space-x-6 text-xs font-bold uppercase tracking-widest mb-10 border-b border-[var(--cr-border)] pb-4">
                        <span id="step-nav-1" class="text-[var(--cr-gold)] border-b border-[var(--cr-gold)] pb-1">1. Shipping</span>
                        <span class="text-gray-300">/</span>
                        <span id="step-nav-2" class="text-gray-400">2. Payment</span>
                    </div>

                    <form id="checkout-form" onsubmit="app.checkout.handleStepSubmit(event)" class="space-y-6">
                        <div id="checkout-step-container" class="space-y-4 min-h-[300px]"></div>
                        
                        <div class="flex justify-between items-center pt-8 border-t border-[var(--cr-border)]">
                            <a href="#shop" onclick="app.router.navigate('shop')" class="text-xs uppercase tracking-widest text-gray-500 hover:text-[var(--cr-text)]">Return to Cart</a>
                            <button type="submit" class="px-10 py-4 btn-gold text-xs tracking-widest">
                                Continue
                            </button>
                        </div>
                    </form>
                </div>
                
                <div class="lg:col-span-5 bg-[var(--cr-white)] p-8 border border-[var(--cr-border)] shadow-sm h-fit">
                    <h3 class="font-serif-elegant text-2xl mb-6 border-b border-[var(--cr-border)] pb-4">Order Summary</h3>
                    <div id="checkout-summary-items" class="space-y-4 max-h-[300px] overflow-y-auto mb-6"></div>
                    <div class="space-y-3 text-sm text-gray-600">
                        <div class="flex justify-between"><span>Subtotal</span><span id="chk-sub">$0.00</span></div>
                        <div class="flex justify-between"><span>Shipping</span><span class="text-[var(--cr-gold)]">Calculated at next step</span></div>
                        <div class="flex justify-between items-center pt-6 text-lg border-t border-[var(--cr-border)] text-[var(--cr-text)] font-serif-elegant">
                            <span>Total</span>
                            <span id="chk-total">$0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 pointer-events-none opacity-0 transition-opacity duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-[450px] bg-[var(--cr-white)] shadow-2xl flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-500 ease-in-out" onclick="event.stopPropagation()">
            
            <div class="p-6 md:p-8 border-b border-[var(--cr-border)] flex items-center justify-between">
                <h3 class="font-serif-elegant text-2xl">Your Cart</h3>
                <button onclick="app.ui.toggleCartDrawer()" class="text-gray-400 hover:text-[var(--cr-text)] transition-colors">
                    <i data-lucide="x" class="w-6 h-6 stroke-[1.5]"></i>
                </button>
            </div>
            
            <div id="cart-drawer-items" class="flex-grow overflow-y-auto p-6 md:p-8 space-y-6"></div>
            
            <div class="p-6 md:p-8 border-t border-[var(--cr-border)] bg-[var(--cr-bg)]">
                <div class="flex justify-between items-center mb-6">
                    <span class="text-sm uppercase tracking-widest text-gray-500">Subtotal</span>
                    <span id="cart-drawer-subtotal" class="font-serif-elegant text-2xl">$0.00</span>
                </div>
                <p class="text-xs text-center text-gray-500 mb-6">Taxes and shipping calculated at checkout.</p>
                <button onclick="app.checkout.initiateCheckout()" class="w-full py-4 btn-gold text-xs tracking-widest">
                    Checkout Securely
                </button>
            </div>
        </div>
    </div>

    <div id="search-overlay" class="fixed inset-0 bg-[var(--cr-white)]/98 backdrop-blur-md z-50 hidden flex-col justify-center items-center px-4 transition-all">
        <button onclick="app.ui.toggleSearchOverlay()" class="absolute top-8 right-8 text-gray-400 hover:text-[var(--cr-text)] transition-colors">
            <i data-lucide="x" class="w-8 h-8 stroke-[1.5]"></i>
        </button>
        <div class="w-full max-w-2xl flex flex-col items-center">
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--cr-gold)] mb-4">What are you looking for?</span>
            <input type="text" id="live-search-input" oninput="app.store.handleSearch(this.value)" placeholder="Search wigs, lengths, textures..." class="w-full bg-transparent border-b-2 border-[var(--cr-border)] focus:border-[var(--cr-gold)] py-4 text-2xl md:text-4xl text-center text-[var(--cr-text)] font-serif-elegant focus:outline-none placeholder:text-gray-300 transition-colors">
            <div id="search-results-output" class="mt-12 w-full space-y-4 max-h-[50vh] overflow-y-auto pr-2"></div>
        </div>
    </div>

    <div id="toast-notif" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-[var(--cr-text)] text-white text-xs font-bold uppercase tracking-widest py-4 px-8 shadow-xl z-50 opacity-0 translate-y-10 transition-all duration-400 pointer-events-none flex items-center gap-3">
        <i data-lucide="check" class="w-4 h-4 text-[var(--cr-gold)] stroke-2"></i>
        <span id="toast-notif-message">Added to cart.</span>
    </div>

    <footer class="bg-[var(--cr-white)] border-t border-[var(--cr-border)] pt-20 pb-10">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
            <div class="md:col-span-1 space-y-6">
                <span class="font-serif-elegant text-3xl text-[var(--cr-text)] block">CROWN.</span>
                <p class="text-sm text-gray-500 leading-relaxed">Providing the highest quality 100% virgin human hair to empower women to feel flawless every single day.</p>
            </div>
            <div class="space-y-4">
                <h4 class="text-xs uppercase font-bold tracking-widest text-[var(--cr-text)] mb-6">Shop</h4>
                <a href="#shop" onclick="app.router.navigate('shop', {filter: 'wigs'})" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">HD Lace Wigs</a>
                <a href="#shop" onclick="app.router.navigate('shop', {filter: 'bundles'})" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">Raw Bundles</a>
                <a href="#" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">Lace Frontals & Closures</a>
            </div>
            <div class="space-y-4">
                <h4 class="text-xs uppercase font-bold tracking-widest text-[var(--cr-text)] mb-6">Support</h4>
                <a href="#" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">Track Order</a>
                <a href="#" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">Shipping & Returns</a>
                <a href="#" class="block text-sm text-gray-500 hover:text-[var(--cr-gold)] transition-colors">Hair Care Guide</a>
            </div>
            <div class="space-y-6">
                <h4 class="text-xs uppercase font-bold tracking-widest text-[var(--cr-text)] mb-2">The Insider List</h4>
                <p class="text-sm text-gray-500 leading-relaxed">Subscribe to receive updates, access to exclusive deals, and more.</p>
                <form onsubmit="event.preventDefault(); app.ui.triggerToast('Subscribed to the newsletter.');" class="flex border-b border-[var(--cr-text)] pb-2">
                    <input type="email" placeholder="Enter your email address" required class="flex-grow bg-transparent text-sm text-[var(--cr-text)] focus:outline-none placeholder:text-gray-400">
                    <button type="submit" class="text-xs font-bold uppercase tracking-widest hover:text-[var(--cr-gold)] transition-colors">Subscribe</button>
                </form>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 pt-8 border-t border-[var(--cr-border)] flex flex-col md:flex-row justify-between items-center text-xs text-gray-400 gap-4">
            <p>&copy; 2026 Crown Hair Co. All Rights Reserved.</p>
            <div class="flex space-x-6">
                <a href="#" class="hover:text-[var(--cr-text)]">Privacy Policy</a>
                <a href="#" class="hover:text-[var(--cr-text)]">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script>
        const INVENTORY_DB = [
            { id: 'cr-01', name: 'The Naomi • Deep Wave', price: 285.00, category: 'Wigs', image: 'https://images.unsplash.com/photo-1631214500115-598fc2cb8d2d?q=80&w=800&auto=format&fit=crop', desc: 'Lush, voluminous deep wave texture. 13x4 HD Lace Frontal with a pre-plucked hairline. Knots bleached for ultimate realism.', lengths: ['18"', '20"', '22"', '24"', '26"'] },
            { id: 'cr-02', name: 'Raw Indian Straight Bundles', price: 115.00, category: 'Bundles', image: 'https://images.unsplash.com/photo-1620025732296-8566d5811029?q=80&w=800&auto=format&fit=crop', desc: '100% Raw Indian Temple Hair. Bone straight texture with natural luster. Thick from root to ends. Price per bundle.', lengths: ['16"', '18"', '20"', '22"', '24"', '26"', '28"'] },
            { id: 'cr-03', name: 'The Chloe • Body Wave', price: 260.00, category: 'Wigs', image: 'https://images.unsplash.com/photo-1580618672591-eb180b1a973f?q=80&w=800&auto=format&fit=crop', desc: 'Our best-selling soft body wave texture. 5x5 HD Lace Closure wig. Glueless, easy to install, and perfect for everyday wear.', lengths: ['14"', '16"', '18"', '20"', '22"'] },
            { id: 'cr-04', name: 'Yaki Straight Clip-Ins', price: 145.00, category: 'Extensions', image: 'https://images.unsplash.com/photo-1608682276510-928cc29f6356?q=80&w=800&auto=format&fit=crop', desc: 'Textured straight clip-in extensions that mimic a silk press on natural hair. 7 pieces per set (120g).', lengths: ['16"', '18"', '20"'] },
            { id: 'cr-05', name: 'The Aaliyah • Sleek Straight', price: 295.00, category: 'Wigs', image: 'https://images.unsplash.com/photo-1610427848419-75a894a4c6a4?q=80&w=800&auto=format&fit=crop', desc: 'Silky smooth, bone straight 13x6 HD Lace Frontal Wig. Offers maximum parting space and effortless styling.', lengths: ['20"', '22"', '24"', '26"', '28"', '30"'] },
            { id: 'cr-06', name: 'Brazilian Water Wave Bundles', price: 95.00, category: 'Bundles', image: 'https://images.unsplash.com/photo-1605980413988-9ff23418ffd0?q=80&w=800&auto=format&fit=crop', desc: 'Bouncy, tight water wave texture. Low maintenance and perfect for wet looks. 100% Virgin Hair. Price per bundle.', lengths: ['14"', '16"', '18"', '20"', '22"', '24"'] }
        ];

        const app = {
            state: { cart: [], currentSort: 'featured', activeCheckoutStep: 1, selectedLength: null },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                
                if (view === '#shop') { 
                    app.store.filterCatalog(queryParams.filter ? queryParams.filter.charAt(0).toUpperCase() + queryParams.filter.slice(1) : 'all'); 
                } 
                else if (view === '#home') {
                    app.store.renderFeatured();
                }
                else if (view === '#product' && queryParams.id) { 
                    app.store.renderProductDetail(queryParams.id); 
                } 
                else if (view === '#checkout') { 
                    app.checkout.renderCurrentStep(); 
                }
                window.scrollTo({top:0, behavior: 'smooth'});
            }
        };

        app.store = {
            renderFeatured: function() {
                const grid = document.getElementById('featured-items-grid');
                if(!grid) return;
                const featured = INVENTORY_DB.slice(0, 4);
                grid.innerHTML = featured.map(item => this.createProductCard(item)).join('');
            },
            renderCatalog: function(items = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = items.map(item => this.createProductCard(item)).join('');
            },
            createProductCard: function(item) {
                return `
                    <div class="group cursor-pointer flex flex-col" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[3/4] w-full overflow-hidden bg-[var(--cr-border)] mb-4 relative">
                            <img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover img-soft">
                            <div class="absolute bottom-0 left-0 right-0 bg-white/90 backdrop-blur-sm py-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300 text-center">
                                <span class="text-xs font-bold uppercase tracking-widest text-[var(--cr-text)]">Quick View</span>
                            </div>
                        </div>
                        <div class="text-center">
                            <span class="text-[10px] uppercase tracking-widest text-gray-400 mb-1 block">${item.category}</span>
                            <h3 class="font-serif-elegant text-lg text-[var(--cr-text)] mb-2">${item.name}</h3>
                            <span class="text-sm text-gray-600">From $${item.price.toFixed(2)}</span>
                        </div>
                    </div>`;
            },
            filterCatalog: function(category) {
                if(category === 'all') {
                    this.renderCatalog(INVENTORY_DB);
                } else {
                    const filtered = INVENTORY_DB.filter(i => i.category === category);
                    this.renderCatalog(filtered);
                }
            },
            selectLength: function(length, priceMultiplier) {
                app.state.selectedLength = { length, multiplier: priceMultiplier };
                document.querySelectorAll('.btn-length').forEach(b => b.className = "btn-length border border-[var(--cr-border)] bg-transparent text-gray-500 hover:border-[var(--cr-text)] hover:text-[var(--cr-text)] py-3 px-2 text-sm text-center transition-all cursor-pointer");
                event.target.className = "btn-length border border-[var(--cr-text)] bg-[var(--cr-text)] text-white py-3 px-2 text-sm text-center transition-all cursor-pointer";
                document.getElementById('sz-error').classList.add('hidden');
                
                // Update displayed price
                const basePrice = parseFloat(document.getElementById('base-price-data').value);
                const newPrice = basePrice + (priceMultiplier * 15); // Add $15 per length step
                document.getElementById('display-price').innerText = `$${newPrice.toFixed(2)}`;
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                app.state.selectedLength = null;

                document.getElementById('product-detail-target').innerHTML = `
                    <div class="w-full bg-[var(--cr-border)] relative">
                        <img src="${item.image}" alt="${item.name}" class="w-full h-auto object-cover">
                    </div>
                    <div class="w-full flex flex-col justify-center lg:py-10 lg:pl-8">
                        <span class="text-xs uppercase tracking-[0.2em] text-[var(--cr-gold)] mb-3 block">${item.category}</span>
                        <h1 class="font-serif-elegant text-4xl sm:text-5xl text-[var(--cr-text)] leading-tight mb-4">${item.name}</h1>
                        <input type="hidden" id="base-price-data" value="${item.price}">
                        <p class="text-2xl text-gray-600 mb-8" id="display-price">$${item.price.toFixed(2)}</p>
                        
                        <div class="mb-10">
                            <div class="flex justify-between items-center mb-4">
                                <span class="text-sm font-bold text-[var(--cr-text)] uppercase tracking-widest">Length:</span>
                                <span class="text-xs text-gray-400 underline cursor-pointer hover:text-[var(--cr-gold)]">Size Guide</span>
                            </div>
                            <div class="grid grid-cols-4 sm:grid-cols-5 gap-3">
                                ${item.lengths.map((len, idx) => `<button onclick="app.store.selectLength('${len}', ${idx})" class="btn-length border border-[var(--cr-border)] bg-transparent text-gray-500 hover:border-[var(--cr-text)] hover:text-[var(--cr-text)] py-3 px-2 text-sm text-center transition-all cursor-pointer">${len}</button>`).join('')}
                            </div>
                            <span id="sz-error" class="text-red-500 text-xs mt-3 hidden">Please select a length.</span>
                        </div>

                        <button onclick="app.store.executeCartInsertion('${item.id}')" class="w-full py-5 btn-gold text-sm mb-10">
                            Add to Cart
                        </button>
                        
                        <div class="border-t border-[var(--cr-border)] pt-8">
                            <h4 class="font-serif-elegant text-lg mb-3">Product Details</h4>
                            <p class="text-sm text-gray-600 leading-relaxed">${item.desc}</p>
                        </div>
                    </div>`;
                lucide.createIcons();
            },
            executeCartInsertion: function(id) {
                if(!app.state.selectedLength) {
                    document.getElementById('sz-error').classList.remove('hidden');
                    return;
                }
                const prod = INVENTORY_DB.find(p => p.id === id);
                const finalPrice = prod.price + (app.state.selectedLength.multiplier * 15);
                app.cart.addItem(id, app.state.selectedLength.length, finalPrice);
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                const results = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase()) || i.category.toLowerCase().includes(term.toLowerCase()));
                
                if (results.length === 0) {
                    out.innerHTML = `<div class="text-center text-gray-500 text-sm mt-8">No results found for "${term}"</div>`;
                    return;
                }

                out.innerHTML = results.map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="flex items-center space-x-6 p-4 hover:bg-[var(--cr-bg)] cursor-pointer transition-colors rounded-sm">
                        <img src="${i.image}" class="w-20 h-24 object-cover">
                        <div class="flex-grow">
                            <span class="block text-lg font-serif-elegant text-[var(--cr-text)]">${i.name}</span>
                            <span class="block text-xs text-[var(--cr-gold)] uppercase tracking-widest mt-1">${i.category}</span>
                        </div>
                        <span class="text-lg text-gray-600">$${i.price.toFixed(2)}</span>
                    </div>`).join('');
            }
        };

        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('cr_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id, length, priceAtLength) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id && item.length === length);
                if (exist) {
                    exist.qty += 1; 
                } else {
                    // Store a clone of product to keep the specific price logic separated
                    const cartProd = {...prod, price: priceAtLength};
                    app.state.cart.push({ product: cartProd, qty: 1, length: length });
                }
                this.sync(); 
                app.ui.triggerToast(`Added to cart.`); 
                app.ui.toggleCartDrawer(true);
            },
            updateQty: function(index, val) { 
                const item = app.state.cart[index]; 
                if (!item) return; 
                item.qty += val; 
                if (item.qty <= 0) app.state.cart.splice(index, 1); 
                this.sync(); 
            },
            sync: function() { localStorage.setItem('cr_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                if (totalItems > 0) { badge.classList.remove('opacity-0'); badge.innerText = totalItems; } else { badge.classList.add('opacity-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-center text-gray-400 text-sm py-20">Your cart is currently empty.</div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map((item, idx) => `
                        <div class="flex space-x-6">
                            <img src="${item.product.image}" class="w-24 h-32 object-cover">
                            <div class="flex flex-col justify-between flex-grow py-1">
                                <div>
                                    <h4 class="text-base font-serif-elegant text-[var(--cr-text)] leading-tight hover:text-[var(--cr-gold)] transition-colors cursor-pointer" onclick="app.router.navigate('product', {id: '${item.product.id}'}); app.ui.toggleCartDrawer();">${item.product.name}</h4>
                                    <span class="text-xs text-gray-500 block mt-2">Length: ${item.length}</span>
                                </div>
                                <div class="flex justify-between items-center mt-4">
                                    <div class="flex items-center border border-[var(--cr-border)]">
                                        <button onclick="app.cart.updateQty(${idx}, -1)" class="px-3 py-1 text-gray-500 hover:text-[var(--cr-text)] transition-colors">&minus;</button>
                                        <span class="w-6 text-center text-sm">${item.qty}</span>
                                        <button onclick="app.cart.updateQty(${idx}, 1)" class="px-3 py-1 text-gray-500 hover:text-[var(--cr-text)] transition-colors">&plus;</button>
                                    </div>
                                    <span class="text-sm text-[var(--cr-text)]">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>`).join('');
                }
            }
        };

        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-sub').innerText = `$${sub.toFixed(2)}`;
                
                // If subtotal over $200, free shipping
                let shipping = sub > 200 ? 0 : 15;
                let total = sub + shipping;
                
                document.getElementById('chk-total').innerText = `$${total.toFixed(2)}`;
                
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex space-x-4 py-2">
                        <div class="relative w-16 h-20 bg-gray-100 shrink-0">
                            <img src="${i.product.image}" class="w-full h-full object-cover">
                            <span class="absolute -top-2 -right-2 bg-gray-500 text-white w-5 h-5 flex items-center justify-center rounded-full text-[10px]">${i.qty}</span>
                        </div>
                        <div class="flex flex-col justify-center flex-grow">
                            <span class="text-sm text-[var(--cr-text)] font-serif-elegant">${i.product.name}</span>
                            <span class="text-xs text-gray-500 mt-1">${i.length}</span>
                        </div>
                        <div class="flex items-center">
                            <span class="text-sm text-[var(--cr-text)]">$${(i.product.price * i.qty).toFixed(2)}</span>
                        </div>
                    </div>`).join('');
                
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-[var(--cr-gold)] border-b border-[var(--cr-gold)] pb-1" : "text-gray-300";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-[var(--cr-gold)] border-b border-[var(--cr-gold)] pb-1" : "text-gray-300";

                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <div class="mb-4 text-sm text-[var(--cr-text)]">Contact Information</div>
                        <input type="email" required placeholder="Email Address" class="w-full cr-input">
                        <div class="mt-8 mb-4 text-sm text-[var(--cr-text)]">Shipping Address</div>
                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" required placeholder="First Name" class="w-full cr-input">
                            <input type="text" required placeholder="Last Name" class="w-full cr-input">
                        </div>
                        <input type="text" required placeholder="Address" class="w-full cr-input">
                        <input type="text" placeholder="Apartment, suite, etc. (optional)" class="w-full cr-input">
                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" required placeholder="City" class="w-full cr-input">
                            <input type="text" required placeholder="Postal Code" class="w-full cr-input">
                        </div>`; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <div class="p-4 bg-[var(--cr-bg)] border border-[var(--cr-border)] text-sm text-gray-600 mb-6 flex justify-between items-center">
                            <div><span class="text-gray-400 mr-2">Contact</span> user@email.com</div>
                            <button type="button" onclick="app.state.activeCheckoutStep=1; app.checkout.renderCurrentStep()" class="text-xs text-[var(--cr-gold)] underline">Change</button>
                        </div>
                        <div class="mb-4 text-sm text-[var(--cr-text)]">Payment</div>
                        <input type="text" required placeholder="Card Number" class="w-full cr-input">
                        <input type="text" required placeholder="Name on Card" class="w-full cr-input">
                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" required placeholder="Expiration Date (MM/YY)" class="w-full cr-input">
                            <input type="text" required placeholder="Security Code" class="w-full cr-input">
                        </div>`; 
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    alert("Thank you for your order! Your hair is being prepped for shipment."); 
                    app.router.navigate('home'); 
                } 
            }
        };

        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    return; 
                }
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                } else {
                    document.getElementById('live-search-input').value = '';
                    document.getElementById('search-results-output').innerHTML = '';
                }
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); 
                if(msg) document.getElementById('toast-notif-message').innerText = msg;
                t.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none'); 
                }, 3000);
            }
        };

        // Initialize app
        window.addEventListener('DOMContentLoaded', () => {
            app.init();
            app.store.renderFeatured();
        });
    </script>
</body>
</html>
