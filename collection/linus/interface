            <button onclick="app.ui.toggleSearchOverlay()" class="text-neutral-500 hover:text-white text-xs font-mono">[CLOSE_CONSOLES]</button>
        </div>
        <div class="w-full max-w-4xl mx-auto flex-grow flex flex-col">
            <input type="text" id="live-search-input" oninput="app.store.handleSearch(this.value)" placeholder="KEYWORD INDEX SEARCH..." class="w-full bg-[var(--panel-bg)] border border-[#4A4655] px-6 py-4 text-2xl font-display font-bold tracking-wide text-white focus:outline-none focus:border-[var(--neon-purple)] placeholder-neutral-700 uppercase">
            <div id="search-results-output" class="mt-6 space-y-2 max-h-[65vh] overflow-y-auto"></div>
        </div>
    </div>

    <div id="toast-notif" class="fixed bottom-6 right-6 bg-[#00FF66] text-black font-mono text-xs font-bold tracking-widest py-3 px-5 shadow-lg z-50 opacity-0 translate-y-6 transition-all duration-300 pointer-events-none border border-black">
        &gt;&gt; <span id="toast-notif-message">LOGGED</span>
    </div>

    <footer class="border-t border-[#4A4655]/40 bg-[var(--panel-bg)] pt-12 pb-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-4 gap-8 mb-12 text-xs text-neutral-500 font-mono">
            <div class="space-y-3">
                <div class="text-white font-display font-bold text-[11px] tracking-wider"> -  ARTIFACT DIRECTORIES</div>
                <a href="#shop" onclick="app.router.navigate('shop')" class="block hover:text-[var(--neon-green)] transition-colors">&gt; DEPLOYED GEAR</a>
                <a href="#about" onclick="app.router.navigate('about')" class="block hover:text-[var(--neon-purple)] transition-colors">&gt; SECTOR RECON LOGS</a>
            </div>
            <div class="space-y-3">
                <div class="text-white font-display font-bold text-[11px] tracking-wider"> -  CONSOLE ASSIST</div>
                <a href="#" class="block hover:text-white transition-colors">&gt; ROUTING FREIGHT</a>
                <a href="#" class="block hover:text-white transition-colors">&gt; DECOMMISSION MATRIX</a>
            </div>
            <div class="md:col-span-2 space-y-4">
                <div class="text-white font-display font-bold text-[11px] tracking-wider"> -  COMMS INTEL NODE LINK</div>
                <p class="text-[11px] normal-case tracking-normal">Inject your digital comms node coordinate into our databanks to harvest private batch links and drop allocations.</p>
                <form onsubmit="event.preventDefault(); app.ui.triggerToast('NODE COMPILED');" class="flex gap-2">
                    <input type="email" placeholder="COORDINATE@DOMAIN.XYZ" required class="flex-grow cyber-input py-2 text-xs">
                    <button type="submit" class="btn-cyber-green px-4 text-xs font-bold font-display">LINK</button>
                </form>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center text-[10px] text-neutral-600 border-t border-[#4A4655]/20 pt-6 font-mono">
            NEO-GRAVE DIGITAL MODS CORP &copy; 2026 - LOGISTICAL FRAMEWORK COMPLETED.
        </div>
    </footer>

    <script>
        /**
         * Cyberpunk Streetwear Dataset
         */
        const INVENTORY_DB = [
            { id: 'ng-x01', name: 'CRT-PULSE MESH ANORAK', price: 310.00, category: 'SHELLS', images: ['https://images.unsplash.com/photo-1578587018452-892bacefd3f2?q=80&w=800&auto=format&fit=crop'], desc: 'Ultra-light high tensile technical mesh layered with reactive grid prints. Designed with a loose structural fit, modular asymmetric chest buckles, and elastic wrist anchors.', spec: 'Water-resistant matrix - 3M reflective line detail' },
            { id: 'ng-x02', name: 'MODULAR EXPANSION HARNESS CARGO', price: 245.00, category: 'BOTTOMS', images: ['https://images.unsplash.com/photo-1624378439575-d8705ad7ae80?q=80&w=800&auto=format&fit=crop'], desc: 'Heavyweight weatherized canvas paneling paired with structural layout strap harnesses. Multiple sub-compartment utility bags can be unclipped or attached modularly.', spec: '12-Pocket Configuration - Reinforced belt webbing' },
            { id: 'ng-x03', name: 'EM-SHIELD DISTORTED CREWNECK', price: 165.00, category: 'MID-LAYERS', images: ['https://images.unsplash.com/photo-1512436991641-6745cdb1723f?q=80&w=800&auto=format&fit=crop'], desc: 'Milled french terry loopback cotton base treated with an vintage distressed oil wash. Inverted flat-lock seam stitching accents across sleeves and heavy drop neck.', spec: '520 GSM Heavy-Knit Cotton - Anti-shrink processing' },
            { id: 'ng-x04', name: 'GLITCH DETECTOR RADAR GLASSES', price: 90.00, category: 'HARDWARE', images: ['https://images.unsplash.com/photo-1511556532299-8f662fc26c06?q=80&w=800&auto=format&fit=crop'], desc: 'Polycarbonate wrap-around radar frames. Finished with an iridescent violet UV-shading visor and micro laser-etched branding code metrics on side hinges.', spec: 'UV-400 Filter Module - Impact shielding certified' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- SINGLE PAGE ROUTER MODULE ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                if (view === '#shop') { app.store.filterCatalog('all'); } 
                else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } 
                else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0, behavior: 'auto'});
            }
        };

        // --- DATA INVENTORY CONTROLLER ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="group bg-[var(--panel-bg)] border border-[#4A4655]/40 hover:border-[var(--neon-green)] transition-all duration-300 cursor-pointer flex flex-col h-full relative" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="absolute top-3 right-3 z-10 font-mono text-[9px] bg-black border border-[#4A4655]/60 px-2 py-0.5 text-neutral-400">
                            ${item.id}
                        </div>
                        <div class="aspect-[4/5] w-full overflow-hidden bg-neutral-900">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-300 mix-blend-screen">
                        </div>
                        <div class="p-4 border-t border-[#4A4655]/40 flex flex-col flex-grow justify-between gap-4">
                            <div>
                                <h3 class="font-display font-bold text-sm tracking-wide text-white group-hover:text-[var(--neon-green)] transition-colors leading-tight">${item.name}</h3>
                                <p class="font-mono text-[10px] text-neutral-500 mt-1">[${item.category}]</p>
                            </div>
                            <div class="font-mono text-xs text-[var(--neon-green)] font-bold">
                                $${item.price.toFixed(2)}
                            </div>
                        </div>
                    </div>`).join('');
                document.getElementById('catalog-count-string').innerText = ` -  CODES TRACKED: ${itemsToRender.length} UNITS`;
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB];
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="w-full aspect-[4/5] bg-black border border-[#4A4655]/50 overflow-hidden relative">
                        <div class="absolute top-4 left-4 z-10 font-mono text-[10px] bg-[#9D4EDD] text-white px-2 py-0.5 font-bold">
                            SYS_ID: ${item.id}
                        </div>
                        <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover opacity-70 mix-blend-screen">
                    </div>
                    <div class="flex flex-col justify-between">
                        <div class="space-y-4">
                            <span class="text-[10px] text-[var(--neon-purple)] font-bold block"> -  CATEGORY: ${item.category}</span>
                            <h1 class="font-display font-black text-2xl sm:text-3xl text-white tracking-wide uppercase leading-tight">${item.name}</h1>
                            <p class="font-mono text-xl text-[var(--neon-green)] font-bold">$${item.price.toFixed(2)}</p>
                            
                            <div class="border-t border-b border-[#4A4655]/30 py-4 font-mono text-xs text-neutral-400 normal-case leading-relaxed">
                                ${item.desc}
                            </div>
                        </div>
                        
                        <div class="mt-8 space-y-6">
                            <div class="bg-black/40 border border-dashed border-[#4A4655]/60 p-4 font-mono text-[11px] space-y-2 text-neutral-400">
                                <div><span class="text-white">SPEC_LOG_01:</span> ${item.spec}</div>
                                <div><span class="text-white">SHIELD STATUS:</span> MATRIX ARMED</div>
                            </div>
                            
                            <button onclick="app.cart.addItem('${item.id}')" class="w-full py-4 btn-cyber font-display text-xs font-bold tracking-widest flex justify-center items-center gap-2">
                                <i data-lucide="shield-alert" class="w-4 h-4"></i>
                                <span>APPEND CARGO STORAGE</span>
                            </button>
                        </div>
                    </div>`;
                lucide.createIcons();
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="p-4 bg-[var(--panel-bg)] hover:bg-neutral-900 border border-[#4A4655]/40 flex items-center justify-between cursor-pointer transition-all group">
                        <div class="flex items-center space-x-4">
                            <img src="${i.images[0]}" class="w-12 h-14 object-cover opacity-40 group-hover:opacity-100 transition-opacity mix-blend-screen">
                            <div>
                                <span class="block font-display font-bold text-xs tracking-wide text-white">${i.name}</span>
                                <span class="block font-mono text-[9px] text-neutral-500 mt-0.5">${i.id}</span>
                            </div>
                        </div>
                        <span class="font-mono text-xs text-[var(--neon-green)]">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- CARGO DATA FRAMEWORK (LOCAL STORAGE) ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('cyber_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`DECK ATTACHED: ${prod.id}`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) { const item = app.state.cart.find(i => i.product.id === id); if (!item) return; item.qty += val; if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id); this.sync(); },
            sync: function() { localStorage.setItem('cyber_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                badge.innerText = totalItems;
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-center font-mono text-xs text-neutral-600 py-16 tracking-widest"> -  NO CORE MODULES LINKED  - </div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex space-x-4 border border-[#4A4655]/40 p-4 bg-black/40 relative">
                            <img src="${item.product.images[0]}" class="w-14 h-16 object-cover opacity-60 mix-blend-screen">
                            <div class="flex flex-col justify-between flex-grow">
                                <div>
                                    <h4 class="font-display font-bold text-xs tracking-wide text-white leading-tight">${item.product.name}</h4>
                                    <p class="font-mono text-[9px] text-neutral-500 mt-1">${item.product.id}</p>
                                </div>
                                <div class="flex justify-between items-center mt-3">
                                    <div class="flex items-center space-x-3 border border-[#4A4655] px-2 py-0.5 font-mono text-[11px] bg-[var(--cyber-black)]">
                                        <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="text-neutral-500 hover:text-white">&minus;</button>
                                        <span class="text-white w-4 text-center">${item.qty}</span>
                                        <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="text-neutral-500 hover:text-white">&plus;</button>
                                    </div>
                                    <span class="font-mono text-xs text-[var(--neon-green)] font-bold">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>`).join('');
                }
            }
        };

        // --- PIPELINE VALIDATOR (CHECKOUT) ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex justify-between items-center py-2.5 border-b border-[#4A4655]/30 font-mono text-xs">
                        <div>
                            <span class="text-white block font-display font-bold">${i.product.name}</span>
                            <span class="text-neutral-500 text-[10px] mt-0.5">QTY: ${i.qty} - BATCH: ${i.product.id}</span>
                        </div>
                        <span class="text-[var(--neon-green)] font-bold">$${(i.product.price * i.qty).toFixed(2)}</span>
                    </div>`).join('');
                
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-[var(--neon-green)]" : "text-neutral-600";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-[var(--neon-green)]" : "text-neutral-600";

                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <input type="email" required placeholder="GRID DISPATCH COMMS (EMAIL)" class="w-full cyber-input text-xs mb-4">
                        <input type="text" required placeholder="SECTOR DESTINATION COORDINATE (ADDRESS)" class="w-full cyber-input text-xs">
                    `; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <input type="text" required placeholder="ENCRYPTED SECURE KEY (CARD NUM)" class="w-full cyber-input text-xs mb-4">
                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" required placeholder="EXP LOG [MM/YY]" class="w-full cyber-input text-xs">
                            <input type="text" required placeholder="AUTH_PIN [CVC]" class="w-full cyber-input text-xs">
                        </div>
                    `; 
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    app.ui.triggerToast("TRANSFER GRANTED - CLEAR"); 
                    app.router.navigate('home'); 
                } 
            }
        };

        // --- SUB CONSOLE INTERFACE DIRECTIVES ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    return; 
                }
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                }
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); 
                document.getElementById('toast-notif-message').innerText = msg;
                t.classList.remove('opacity-0', 'translate-y-6', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-y-6', 'pointer-events-none'); 
                }, 3000);
            }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
