<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LINus TERMINAL</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-green: #00FF66;
            --neon-purple: #9D4EDD;
            --cyber-black: #0D0C10;
            --panel-bg: #141218;
            --cyber-gray: #4A4655;
        }
        
        body { 
            font-family: 'Share Tech Mono', monospace; 
            background-color: var(--cyber-black); 
            color: #E2E0E7; 
        }
        .font-display { font-family: 'Orbitron', sans-serif; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: glitchGlance 0.3s ease-out forwards; }
        
        @keyframes glitchGlance {
            0% { opacity: 0; transform: skewX(-3deg); }
            50% { opacity: 0.8; transform: skewX(2deg); }
            100% { opacity: 1; transform: skewX(0); }
        }

        /* Scanline Overlay Effect */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 99999;
            background-size: 100% 4px, 6px 100%;
            pointer-events: none;
        }

        /* Cyberpunk Input Frames */
        .cyber-input { 
            border: 1px dashed var(--cyber-gray); 
            background-color: rgba(20, 18, 24, 0.7);
            color: #FFFFFF;
            border-radius: 0;
            padding: 12px;
            transition: all 0.2s ease;
        }
        .cyber-input:focus { 
            outline: none; 
            border-color: var(--neon-green);
            box-shadow: 0 0 8px rgba(0, 255, 102, 0.2);
        }
        
        /* Neon Button Styling */
        .btn-cyber {
            border: 1px solid var(--neon-purple);
            background: transparent;
            color: #FFFFFF;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
        }
        .btn-cyber:hover {
            background: var(--neon-purple);
            box-shadow: 0 0 15px var(--neon-purple);
            text-shadow: 0 0 5px #FFF;
        }

        .btn-cyber-green {
            border: 1px solid var(--neon-green);
            background: rgba(0, 255, 102, 0.05);
            color: var(--neon-green);
            transition: all 0.3s;
        }
        .btn-cyber-green:hover {
            background: var(--neon-green);
            color: var(--cyber-black);
            box-shadow: 0 0 15px var(--neon-green);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--cyber-black); }
        ::-webkit-scrollbar-thumb { background: var(--cyber-gray); border: 1px solid var(--neon-purple); }
        ::-webkit-scrollbar-thumb:hover { background: var(--neon-purple); }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between selection:bg-[#9D4EDD] selection:text-white uppercase tracking-wider">

    <div class="bg-purple-950/40 border-b border-[#9D4EDD]/30 py-1 text-[11px] text-purple-400 font-mono text-center relative overflow-hidden flex justify-center items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-purple-500 animate-ping"></span>
        [SYS.MSG]: OVERRIDE CODE ACTIVATED — SECURE CHECKOUT SHIELD ON
    </div>

    <header class="sticky top-0 bg-[#0D0C10]/80 backdrop-blur-md z-40 border-b border-[#4A4655]/40">
