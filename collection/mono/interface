<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MONO // Premium Fashion & Essentials</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFFFFF; color: #111111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        
        /* Shopify style input focus overrides */
        .shopify-input { 
            border: 1px solid #E5E5E5; 
            transition: border-color 0.2s ease;
        }
        .shopify-input:focus { 
            outline: none; 
            border-color: #111111; 
        }
        
        /* Smooth product card transitions */
        .product-card img {
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .product-card:hover img {
            transform: scale(1.04);
        }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between selection:bg-neutral-900 selection:text-white">

    <div class="bg-neutral-900 text-white py-2 text-xs font-medium tracking-wider text-center uppercase px-4">
        Complimentary worldwide shipping on all orders over $150
    </div>

    <header class="sticky top-0 bg-white/95 backdrop-blur-md z-40 border-b border-neutral-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-medium tracking-widest uppercase text-neutral-600">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-black transition-colors">Shop Collection</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-black transition-colors">Our Story</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="font-serif text-2xl font-medium tracking-tight text-neutral-900">
                MONO STUDIO
            </a>

            <div class="flex items-center space-x-4 sm:space-x-6">
                <button class="p-2 text-neutral-600 hover:text-black transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search Store">
                    <i data-lucide="search" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button class="p-2 text-neutral-600 hover:text-black transition-colors relative flex items-center" onclick="app.ui.toggleCartDrawer()" aria-label="Open Cart">
                    <i data-lucide="shopping-bag" class="w-5 h-5 stroke-[1.5]"></i>
                    <span id="global-cart-count" class="absolute -top-1 -right-1 text-[10px] font-bold text-white bg-neutral-900 w-4 h-4 rounded-full flex items-center justify-center transition-all transform scale-0">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="relative bg-neutral-50 border-b border-neutral-100 overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 items-center min-h-[calc(100vh-10rem)] py-12 lg:py-0">
                    <div class="lg:col-span-5 space-y-6 z-10 text-center lg:text-left">
                        <span class="text-xs font-semibold tracking-widest uppercase text-neutral-400">The New Season Collection</span>
                        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-neutral-900 leading-tight">
                            Timeless silhouettes, crafted for modern life.
                        </h1>
                        <p class="text-neutral-500 text-sm max-w-md mx-auto lg:mx-0 font-light leading-relaxed">
                            A curated capsule series stripping away the noise to emphasize premium premium textiles, tailored structural fits, and clean minimalism.
                        </p>
                        <div class="pt-4">
                            <button onclick="app.router.navigate('shop')" class="bg-neutral-900 text-white text-xs font-semibold tracking-widest uppercase px-8 py-4 hover:bg-neutral-800 transition-colors rounded-none">
                                Shop New Arrivals
                            </button>
                        </div>
                    </div>
                    <div class="lg:col-span-7 mt-8 lg:mt-0 h-[400px] sm:h-[550px] lg:h-[650px] w-full">
                        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover rounded-none" alt="Premium Lookbook Model Feature">
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div onclick="app.router.navigate('shop', {category: 'STRUCTURE'})" class="relative group cursor-pointer overflow-hidden aspect-[4/3] bg-neutral-100">
                    <img src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700">
                    <div class="absolute inset-0 bg-black/10 transition-colors group-hover:bg-black/20"></div>
                    <div class="absolute bottom-6 left-6 text-white">
                        <h3 class="font-serif text-2xl">Premium Apparel &rarr;</h3>
                    </div>
                </div>
                <div onclick="app.router.navigate('shop', {category: 'HARDWARE'})" class="relative group cursor-pointer overflow-hidden aspect-[4/3] bg-neutral-100">
                    <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700">
                    <div class="absolute inset-0 bg-black/10 transition-colors group-hover:bg-black/20"></div>
                    <div class="absolute bottom-6 left-6 text-white">
                        <h3 class="font-serif text-2xl">Utility Accessories &rarr;</h3>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between border-b border-neutral-200 pb-5 mb-10">
                <div>
                    <h2 class="font-serif text-3xl text-neutral-900 tracking-tight">All Collections</h2>
                    <p id="catalog-count-string" class="text-neutral-400 text-xs mt-1">Loading store items...</p>
                </div>
                <div class="mt-4 sm:mt-0 flex items-center space-x-4">
                    <label for="catalog-sort" class="text-xs text-neutral-400 uppercase tracking-wider font-medium">Sort by:</label>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="text-xs uppercase tracking-wider bg-transparent border border-neutral-200 text-neutral-800 rounded-none py-2 px-3 focus:outline-none focus:border-black">
                        <option value="featured">Featured Items</option>
                        <option value="price-low">Price: Low to High</option>
                        <option value="price-high">Price: High to Low</option>
                    </select>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-6">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-3xl mx-auto px-4 py-16 space-y-8 text-center">
            <div class="space-y-3">
                <span class="text-xs text-neutral-400 font-semibold tracking-widest uppercase">// Established 2018</span>
                <h2 class="font-serif text-3xl sm:text-4xl text-neutral-900">Crafting sustainable, luxury mainstays.</h2>
                <p class="text-neutral-500 text-sm font-light leading-relaxed">MONO STUDIO was founded on a simple premise: create high-end garments and functional goods built to last past seasonal trends, reducing consumer waste through pristine craftsmanship.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left pt-6">
                <div class="p-6 bg-neutral-50 space-y-2 border border-neutral-100">
                    <h3 class="text-neutral-900 text-xs font-semibold uppercase tracking-wider">Ethical Sourcing</h3>
                    <p class="text-neutral-500 text-xs leading-relaxed">We trace every yarn variant back to carbon-certified organic farms, prioritizing regional standard fair-wage labor above all else.</p>
                </div>
                <div class="p-6 bg-neutral-50 space-y-2 border border-neutral-100">
                    <h3 class="text-neutral-900 text-xs font-semibold uppercase tracking-wider">Circular Lifecycle</h3>
                    <p class="text-neutral-500 text-xs leading-relaxed">All active components are eligible for our store trade-in initiative programs, supporting continuous environmental recovery loops.</p>
                </div>
            </div>
        </section>

        <section id="view-faq" class="view-section max-w-2xl mx-auto px-4 py-16 space-y-8">
            <div class="text-center space-y-1">
                <h2 class="font-serif text-3xl text-neutral-900">Customer Support</h2>
                <p class="text-neutral-400 text-xs">Frequently asked order answers and policies</p>
            </div>
            <div class="border-t border-neutral-200 divide-y divide-neutral-100">
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-neutral-800 focus:outline-none">
                        <span>When will my order ship?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-neutral-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-neutral-500 text-xs leading-relaxed">
                        <p class="py-3 pr-4">Orders typically process within 1-2 business days. Standard domestic shipping takes 3-5 business days, while international transit timelines can span 7-14 business days depending on customs processing.</p>
                    </div>
                </div>
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-neutral-800 focus:outline-none">
                        <span>What is your returns policy?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-neutral-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-neutral-500 text-xs leading-relaxed">
                        <p class="py-3 pr-4">We accept returns of unworn, unwashed merchandise with all native tags attached within 14 days of delivery. Return shipments can easily be initiated through our automated online self-service support dashboard.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-contact" class="view-section max-w-4xl mx-auto px-4 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-neutral-50 p-8 sm:p-12 border border-neutral-100">
                <div class="space-y-6 flex flex-col justify-between">
                    <div class="space-y-3">
                        <h2 class="font-serif text-3xl text-neutral-900">Get In Touch</h2>
                        <p class="text-neutral-500 text-xs leading-relaxed">Have questions regarding fit specifications, order logistics or custom product batches? Drop our concierge agents a detailed brief.</p>
                    </div>
                    <div class="space-y-1 text-xs text-neutral-400">
                        <p>Support Matrix Email: assistance@monostudio.com</p>
                        <p>Corporate Fulfillment Hub: NY District Office, NY 10013</p>
                    </div>
                </div>
                <form onsubmit="app.ui.handleContactSubmit(event)" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <input type="text" required placeholder="Your Name" class="w-full p-3.5 text-xs bg-white shopify-input">
                        <input type="email" required placeholder="Email Address" class="w-full p-3.5 text-xs bg-white shopify-input">
                    </div>
                    <textarea required rows="5" placeholder="How can we help you?" class="w-full p-3.5 text-xs bg-white shopify-input"></textarea>
                    <button type="submit" class="w-full bg-neutral-900 text-white py-3.5 text-xs font-semibold tracking-widest uppercase hover:bg-neutral-800 transition-colors rounded-none">Send Message</button>
                </form>
            </div>
        </section>

        <section id="view-checkout" class="view-section max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-7 space-y-8">
                    <div class="flex items-center space-x-2 text-[10px] font-semibold text-neutral-400 uppercase tracking-wider">
                        <span id="step-nav-1" class="text-neutral-900 font-bold">1. Customer Info</span>
                        <i data-lucide="chevron-right" class="w-3 h-3"></i>
                        <span id="step-nav-2">2. Shipping Options</span>
                        <i data-lucide="chevron-right" class="w-3 h-3"></i>
                        <span id="step-nav-3">3. Secure Payment</span>
                    </div>
                    <form id="checkout-form" onsubmit="app.checkout.handleStepSubmit(event)" class="space-y-6 bg-white border border-neutral-100 p-6 sm:p-10 shadow-xs">
                        <div id="checkout-step-container"></div>
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center pt-6 border-t border-neutral-100 gap-4">
                            <a href="#shop" onclick="app.router.navigate('shop')" class="text-xs text-neutral-400 hover:text-black font-medium">&larr; Return to shopping</a>
                            <button type="submit" class="bg-neutral-900 text-white px-8 py-4 text-xs font-semibold tracking-widest uppercase hover:bg-neutral-800 transition-colors rounded-none">
                                Continue to <span id="checkout-btn-context">Shipping</span> &rarr;
                            </button>
                        </div>
                    </form>
                </div>
                <div class="lg:col-span-5 bg-neutral-50 border border-neutral-100 p-6 sm:p-8 space-y-6">
                    <h3 class="text-sm font-semibold text-neutral-900 uppercase tracking-wider">Order Summary</h3>
                    <div id="checkout-summary-items" class="space-y-4 divide-y divide-neutral-200/60 max-h-72 overflow-y-auto pr-1"></div>
                    <div class="space-y-2 pt-4 border-t border-neutral-200 text-xs font-medium text-neutral-500">
                        <div class="flex justify-between"><span>Subtotal</span><span id="chk-subtotal" class="text-neutral-900">$0.00</span></div>
                        <div class="flex justify-between text-neutral-900 font-bold pt-3 border-t border-neutral-200 text-sm"><span>Total</span><span id="chk-total">$0.00</span></div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-neutral-900/40 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-all duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white p-6 sm:p-8 flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-300 ease-in-out" onclick="event.stopPropagation()">
            <div class="flex flex-col min-h-0 flex-grow">
                <div class="flex items-center justify-between border-b border-neutral-100 pb-4 mb-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-900">Your Shopping Bag</h3>
                    <button onclick="app.ui.toggleCartDrawer()" class="p-1 text-neutral-400 hover:text-black transition-colors"><i data-lucide="x" class="w-5 h-5"></i></button>
                </div>
                <div id="cart-drawer-items" class="flex-grow overflow-y-auto space-y-4 pr-1"></div>
            </div>
            <div class="pt-6 border-t border-neutral-100 space-y-4 bg-white">
                <div class="flex justify-between text-sm font-semibold text-neutral-900"><span>Estimated Subtotal</span><span id="cart-drawer-subtotal">$0.00</span></div>
                <p class="text-[11px] text-neutral-400">Shipping fees and localized taxation weights calculated during checkout flow sequence paths.</p>
                <button onclick="app.checkout.initiateCheckout()" class="w-full py-4 bg-neutral-900 text-white font-semibold text-xs tracking-widest uppercase hover:bg-neutral-800 transition-colors rounded-none">Proceed to Checkout</button>
            </div>
        </div>
    </div>

    <div id="search-overlay" class="fixed inset-0 bg-white z-50 hidden items-center justify-center p-4 sm:p-6">
        <button onclick="app.ui.toggleSearchOverlay()" class="absolute top-6 right-6 p-2 text-neutral-400 hover:text-black transition-colors"><i data-lucide="x" class="w-6 h-6"></i></button>
        <div class="w-full max-w-3xl space-y-6">
            <h3 class="text-xs text-neutral-400 font-bold uppercase tracking-widest text-center">Search Our Store</h3>
            <div class="relative border-b border-neutral-200 pb-3">
                <input type="text" id="live-search-input" oninput="app.store.handleSearch(this.value)" placeholder="Search clothing, essentials, hardware objects..." class="w-full bg-transparent py-2 text-xl font-light focus:outline-none placeholder-neutral-300 text-neutral-900 tracking-tight">
            </div>
            <div id="search-results-output" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-96 overflow-y-auto pt-2"></div>
        </div>
    </div>

    <div id="toast-notif" class="fixed bottom-6 right-6 bg-neutral-900 text-white text-xs font-medium py-3.5 px-5 rounded-none shadow-xl z-50 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none flex items-center space-x-3">
        <i data-lucide="check" class="w-4 h-4 text-emerald-400"></i>
        <span id="toast-notif-message">Item successfully updated</span>
    </div>

    <footer class="bg-neutral-50 border-t border-neutral-100 pt-16 pb-12 text-xs text-neutral-500">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 border-b border-neutral-200 pb-12 mb-8">
            <div class="space-y-4">
                <h4 class="text-neutral-900 font-semibold tracking-wider uppercase text-[11px]">Shop Links</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('shop')">All Products</li></ul>
            </div>
            <div class="space-y-4">
                <h4 class="text-neutral-900 font-semibold tracking-wider uppercase text-[11px]">About Us</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('about')">Our Story</li></ul>
            </div>
            <div class="space-y-4">
                <h4 class="text-neutral-900 font-semibold tracking-wider uppercase text-[11px]">Customer Care</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('faq')">Fulfillment FAQ</li><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('contact')">Contact Support</li></ul>
            </div>
            <div class="space-y-3">
                <h4 class="text-neutral-900 font-semibold tracking-wider uppercase text-[11px]">Newsletter</h4>
                <p class="text-neutral-400 leading-relaxed font-light">Join to receive updates regarding exclusive seasonal drops, sales previews, and lookbook events.</p>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-[11px] text-neutral-400 font-light">
            <p>&copy; 2026 MONO STUDIO. Powered by optimized runtime client matrix deployment arrays.</p>
        </div>
    </footer>

    <script>
        /**
         * Clean, high-converting retail product database representation models
         */
        const INVENTORY_DB = [
            { id: 'mono-01', name: 'All-Weather Technical Shield Jacket', price: 420.00, category: 'STRUCTURE', images: ['https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=600&auto=format&fit=crop'], desc: 'A windproof, water-resistant outer shell jacket engineered from premium double-weave synthetic nylon fabric matrices. Built with clean heat-sealed seam tapes and adjustable custom storage toggles for extreme utility.' },
            { id: 'mono-02', name: 'Modular Tactical Cargo Backpack', price: 290.00, category: 'HARDWARE', images: ['https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=600&auto=format&fit=crop'], desc: 'Laser-cut high-tensile Cordura canvas architecture layout featuring ergonomic multi-compartment layouts, quick-release locking mechanisms, and water-resistant internal utility slots.' },
            { id: 'mono-03', name: 'Reinforced Titanium Diver Chronograph Watch', price: 680.00, category: 'UTILITY', images: ['https://images.unsplash.com/photo-1522312346375-d1a52e2b99b3?q=80&w=600&auto=format&fit=crop'], desc: 'Machined raw aerospace grade titanium chassis framework hosting automatic internal tracking movements, scratch-resistant sapphire protective watch faces, and 200m depth waterproof performance metrics.' },
            { id: 'mono-04', name: 'Premium Merino Seamless Balaclava Layer', price: 95.00, category: 'STRUCTURE', images: ['https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=600&auto=format&fit=crop'], desc: 'Extra-fine temperature regulating authentic Merino sheep wool blends designed for smooth zero-abrasion layering protection during high-intensity environmental traversal maneuvers.' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- SINGLE PAGE APPLICATION NAVIGATION IMPLEMENTATION ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                if (view === '#shop') { app.store.filterCatalog(queryParams.category || 'all'); } else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0});
            }
        };

        // --- E-COMMERCE CORE CATALOG RETAIL RENDER HANDLER ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="product-card flex flex-col justify-between cursor-pointer group" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[3/4] w-full overflow-hidden bg-neutral-50 border border-neutral-100 mb-3 relative">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover">
                        </div>
                        <div class="space-y-1 font-sans">
                            <div class="flex justify-between items-start text-xs font-medium text-neutral-900 gap-2">
                                <h3 class="group-hover:underline leading-snug">${item.name}</h3>
                                <p class="font-semibold whitespace-nowrap">$${item.price.toFixed(2)}</p>
                            </div>
                            <p class="text-[10px] text-neutral-400 uppercase tracking-widest">${item.category}</p>
                        </div>
                    </div>`).join('');
                document.getElementById('catalog-count-string').innerText = `Showing all ${itemsToRender.length} core collection designs`;
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB].filter(i => app.state.activeFilter === 'all' || i.category === app.state.activeFilter);
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="lg:col-span-7 aspect-[3/4] w-full bg-neutral-50 border border-neutral-100 overflow-hidden">
                        <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover">
                    </div>
                    <div class="lg:col-span-5 flex flex-col space-y-6 font-sans py-4">
                        <div class="border-b border-neutral-200 pb-5 space-y-2">
                            <span class="text-[10px] text-neutral-400 font-semibold tracking-widest uppercase">${item.category} COLLECTION</span>
                            <h1 class="font-serif text-3xl text-neutral-900 leading-tight">${item.name}</h1>
                            <p class="text-xl font-medium text-neutral-900 mt-2">$${item.price.toFixed(2)}</p>
                        </div>
                        <p class="text-neutral-500 text-xs leading-relaxed font-light">${item.desc}</p>
                        <div class="pt-4">
                            <button onclick="app.cart.addItem('${item.id}')" class="w-full py-4 bg-neutral-900 text-white text-xs font-semibold uppercase tracking-widest hover:bg-neutral-800 transition-colors rounded-none">Add to Cart Bag</button>
                        </div>
                        <div class="text-[11px] text-neutral-400 border-t border-neutral-100 pt-4 space-y-1">
                            <p>&bull; Free standard international delivery qualified.</p>
                            <p>&bull; 14-day hassle-free return window authorization.</p>
                        </div>
                    </div>`;
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="p-3 bg-white border border-neutral-100 flex items-center justify-between cursor-pointer hover:bg-neutral-50 transition-colors">
                        <div class="flex items-center space-x-3">
                            <img src="${i.images[0]}" class="w-10 h-10 object-cover border border-neutral-100">
                            <span class="text-xs text-neutral-800 font-medium">${i.name}</span>
                        </div>
                        <span class="text-xs font-semibold text-neutral-900">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- HIGH TRANSACTION SPEED CORE CUSTOM RETAIL CART SUB ENGINE ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('mono_retail_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`Added to your shopping bag`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) { const item = app.state.cart.find(i => i.product.id === id); if (!item) return; item.qty += val; if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id); this.sync(); },
            sync: function() { localStorage.setItem('mono_retail_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                if (totalItems > 0) { badge.innerText = totalItems; badge.classList.remove('scale-0'); } else { badge.classList.add('scale-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                if (app.state.cart.length === 0) { drawerContainer.innerHTML = `<div class="text-center text-neutral-400 py-16 text-xs uppercase tracking-widest"><i data-lucide="shopping-bag" class="w-6 h-6 mx-auto mb-3 opacity-40"></i>Your shopping bag is empty</div>`; } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex items-center space-x-4 border border-neutral-100 p-4 bg-neutral-50">
                            <img src="${item.product.images[0]}" class="w-14 h-14 object-cover border border-neutral-200">
                            <div class="flex-grow min-w-0 space-y-1">
                                <h4 class="text-xs font-semibold text-neutral-900 truncate uppercase">${item.product.name}</h4>
                                <div class="flex items-center space-x-3">
                                    <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="text-neutral-400 hover:text-black text-xs font-bold font-mono">-</button>
                                    <span class="text-xs text-neutral-800 font-medium font-mono">${item.qty}</span>
                                    <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="text-neutral-400 hover:text-black text-xs font-bold font-mono">+</button>
                                </div>
                            </div>
                        </div>`).join('');
                }
                lucide.createIcons();
            }
        };

        // --- SHOPIFY STYLE TRANSACTION CONSOLE MANAGEMENT MODULES ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const ctx = document.getElementById('checkout-btn-context');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-subtotal').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `<div class="flex justify-between text-xs py-1.5 text-neutral-500 font-sans"><span>${i.product.name} <span class="text-neutral-400 font-light">(x${i.qty})</span></span><span class="text-neutral-900 font-semibold">$${(i.product.price * i.qty).toFixed(2)}</span></div>`).join('');
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-neutral-900 font-bold" : "text-neutral-400";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-neutral-900 font-bold" : "text-neutral-400";
                document.getElementById('step-nav-3').className = app.state.activeCheckoutStep === 3 ? "text-neutral-900 font-bold" : "text-neutral-400";

                if (app.state.activeCheckoutStep === 1) { ctx.innerText = "Shipping Options"; container.innerHTML = `<h3 class="text-xs font-bold text-neutral-900 uppercase tracking-wider mb-2">Customer Shipping Details</h3><input type="email" required placeholder="Email Address for Order Updates" class="w-full p-3.5 text-xs bg-white shopify-input"><input type="text" required placeholder="Physical Delivery Shipping Address" class="w-full p-3.5 text-xs bg-white shopify-input">`; } else if (app.state.activeCheckoutStep === 2) { ctx.innerText = "Payment Portal"; container.innerHTML = `<h3 class="text-xs font-bold text-neutral-900 uppercase tracking-wider mb-2">Select Shipping Speed</h3><div class="border border-neutral-100 bg-neutral-50 text-xs p-4 flex items-center justify-between"><div class="flex items-center space-x-2"><input type="radio" checked class="accent-neutral-900"> <span>Standard Delivery Route</span></div> <span class="font-semibold text-neutral-900">Complimentary</span></div>`; } else if (app.state.activeCheckoutStep === 3) { ctx.innerText = "Complete Secure Order"; container.innerHTML = `<h3 class="text-xs font-bold text-neutral-900 uppercase tracking-wider mb-2">Payment Details</h3><input type="text" required placeholder="Secure Credit Card Processing Vault" class="w-full p-3.5 text-xs bg-white shopify-input">`; }
            },
            handleStepSubmit: function(e) { e.preventDefault(); if(app.state.activeCheckoutStep < 3) { app.state.activeCheckoutStep += 1; this.renderCurrentStep(); } else { app.state.cart = []; app.cart.sync(); app.state.activeCheckoutStep = 1; app.ui.triggerToast("Order placed successfully! Check email."); app.router.navigate('home'); } }
        };

        // --- GENERAL UX DECORATIVE OVERLAY LAYOUT TOGGLE UTILITIES ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                if (forceOpen === true) { overlay.classList.remove('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.remove('translate-x-full'); return; }
                if (forceOpen === false) { overlay.classList.add('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.add('translate-x-full'); return; }
                overlay.classList.toggle('opacity-0'); overlay.classList.toggle('pointer-events-none');
                overlay.firstElementChild.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { const s = document.getElementById('search-overlay'); s.classList.toggle('hidden'); s.classList.toggle('flex'); if(!s.classList.contains('hidden')) document.getElementById('live-search-input').focus(); },
            toggleAccordion: function(btn) { btn.querySelector('i').classList.toggle('rotate-180'); const panel = btn.nextElementSibling; if (panel.style.maxHeight && panel.style.maxHeight !== '0px') { panel.style.maxHeight = '0px'; } else { panel.style.maxHeight = panel.scrollHeight + "px"; } },
            handleContactSubmit: function(e) { e.preventDefault(); e.target.reset(); this.triggerToast("Message sent to customer service agent desk"); },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); document.getElementById('toast-notif-message').innerText = msg;
                t.className = "fixed bottom-6 right-6 bg-neutral-900 text-white text-xs font-medium py-3.5 px-5 rounded-none shadow-xl z-50 transform translate-y-0 opacity-100 transition-all duration-300 flex items-center space-x-3";
                setTimeout(() => { t.className = "fixed bottom-6 right-6 bg-neutral-900 text-white text-xs font-medium py-3.5 px-5 rounded-none shadow-xl z-50 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none flex items-center space-x-3"; }, 3500);
            }
        };
        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
