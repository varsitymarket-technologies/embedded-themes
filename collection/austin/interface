    <script>
        // --- 1. NEW THEMATIC DATABASE ---
        const DB = {
            currency: 'e(__SYSTEM_API__)',
            categories: ['All', 'Indoor Plants', 'Ceramics', 'Apothecary', 'Tools'],
            products: [
                { id: 1, title: 'Ficus Elastica', price: 45, category: 'Indoor Plants', img: 'FICUS_PLANT', desc: 'A stunning Rubber Tree with deep burgundy leaves. Easy to care for and perfect for bright indirect light.' },
                { id: 2, title: 'Monstera Deliciosa', price: 60, category: 'Indoor Plants', img: 'MONSTERA', desc: 'The classic Swiss Cheese plant. Fast-growing and provides an instant tropical feel to any room.' },
                { id: 3, title: 'Terracotta Planter', price: 35, category: 'Ceramics', img: 'PLANTER', desc: 'Hand-thrown unglazed terracotta. Provides excellent aeration for plant roots.' },
                { id: 4, title: 'Neem Oil Serum', price: 18, category: 'Apothecary', img: 'NEEM_BOTTLE', desc: 'Cold-pressed organic neem oil blended with peppermint. The ultimate natural leaf shine and protector.' },
                { id: 5, title: 'Brass Pruning Shears', price: 42, category: 'Tools', img: 'SHEARS', desc: 'Solid brass Japanese-style pruning scissors. Keeps your plants neatly manicured.' },
                { id: 6, title: 'Olive Tree', price: 110, category: 'Indoor Plants', img: 'OLIVE_TREE', desc: 'A Mediterranean classic adapted for indoor living. Requires bright, sunny windows.' }
            ]
        };

        // --- 2. CORE APPLICATION CLASS (Identical functionality) ---
        class StoreEngine {
            constructor() {
                this.root = document.getElementById('app-root');
                this.cart = JSON.parse(localStorage.getItem('verdant_cart')) || [];
                this.isLoggedIn = localStorage.getItem('verdant_auth') === 'true';
                
                this.initLayout();
                this.initRouter();
                this.updateCartCount();
            }

            initLayout() {
                const mobBtn = document.getElementById('mobile-menu-btn');
                const mobMenu = document.getElementById('mobile-menu');
                const mobClose = document.getElementById('mobile-close-btn');
                
                const toggle = () => mobMenu.classList.toggle('hidden');
                
                mobBtn.onclick = toggle;
                mobClose.onclick = toggle;
                document.querySelectorAll('.js-mobile-link').forEach(link => link.onclick = toggle);
            }

            showToast(msg) {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = 'bg-verdant-dark text-white px-6 py-3 rounded-full text-sm shadow-xl transition-all duration-300 transform translate-y-10 opacity-0';
                toast.textContent = msg;
                container.appendChild(toast);
                
                requestAnimationFrame(() => toast.classList.remove('translate-y-10', 'opacity-0'));
                setTimeout(() => {
                    toast.classList.add('translate-y-10', 'opacity-0');
                    setTimeout(() => toast.remove(), 300);
                }, 2500);
            }

            initRouter() {
                window.addEventListener('hashchange', () => this.route());
                this.route();
            }

            route() {
                const hash = window.location.hash.slice(1) || 'home';
                const parts = hash.split('/');
                const view = parts[0];
                const id = parts[1];

                this.root.classList.remove('fade-enter');
                void this.root.offsetWidth;
                this.root.classList.add('fade-enter');
                window.scrollTo(0, 0);

                switch(view) {
                    case 'shop': this.renderShop(id); break;
                    case 'product': this.renderProduct(id); break;
                    case 'cart': this.renderCart(); break;
                    case 'checkout': this.renderCheckout(); break;
                    case 'success': this.renderSuccess(); break;
                    case 'auth': this.isLoggedIn ? this.renderAccount() : this.renderTemplate('tpl-auth', this.bindAuth); break;
                    case 'search': this.renderSearch(); break;
                    case 'about': this.renderStatic('Our Roots', 'Founded on the principle that humans thrive when surrounded by nature. We partner with sustainable nurseries to bring life into your home.'); break;
                    default: this.renderTemplate('tpl-home'); break;
                }
            }

            renderTemplate(templateId, callback = null) {
                const tpl = document.getElementById(templateId);
                if (!tpl) return;
                this.root.innerHTML = '';
                this.root.appendChild(tpl.content.cloneNode(true));
                if (callback) callback.call(this, this.root);
            }

            renderShop(activeCategory = 'All') {
                activeCategory = decodeURI(activeCategory);
                this.renderTemplate('tpl-shop', (view) => {
                    const list = view.querySelector('.js-category-list');
                    const grid = view.querySelector('.js-product-grid');
                    const catTpl = document.getElementById('tpl-category-item');
                    const prodTpl = document.getElementById('tpl-product-card');

                    // Categories Logic
                    DB.categories.forEach(cat => {
                        const li = catTpl.content.cloneNode(true);
                        const link = li.querySelector('.js-cat-link');
                        link.textContent = cat;
                        if(cat === activeCategory) {
                            link.classList.add('bg-verdant-dark', 'text-white');
                            link.classList.remove('hover:text-verdant-accent');
                        }
                        link.onclick = () => window.location.hash = `shop/${cat}`;
                        list.appendChild(li);
                    });

                    // Product Grid Logic
                    const filtered = activeCategory === 'All' ? DB.products : DB.products.filter(p => p.category === activeCategory);
                    view.querySelector('.js-collection-title').textContent = activeCategory;
                    view.querySelector('.js-collection-count').textContent = `${filtered.length} Items Available`;

                    filtered.forEach(p => {
                        const card = prodTpl.content.cloneNode(true);
                        card.querySelector('.js-prod-link').href = `#product/${p.id}`;
                        card.querySelector('.js-title').textContent = p.title;
                        card.querySelector('.js-price').textContent = `${DB.currency}${p.price}`;
                        card.querySelector('.js-img-placeholder').textContent = p.img;
                        grid.appendChild(card);
                    });
                });
            }

            renderProduct(id) {
                const product = DB.products.find(p => p.id == id);
                if (!product) return window.location.hash = 'shop';

                this.renderTemplate('tpl-product', (view) => {
                    view.querySelector('.js-detail-title').textContent = product.title;
                    view.querySelector('.js-detail-price').textContent = `${DB.currency}${product.price}`;
                    view.querySelector('.js-detail-cat').textContent = product.category;
                    view.querySelector('.js-detail-desc').textContent = product.desc;
                    view.querySelector('.js-detail-img').textContent = product.img;

                    view.querySelector('.js-add-btn').onclick = () => {
                        this.cartAdd(product);
                        this.showToast(`${product.title} added to cart`);
                    };
                });
            }

            renderCart() {
                if (this.cart.length === 0) {
                    this.renderTemplate('tpl-cart-empty', (emptyView) => {
                        this.renderTemplate('tpl-cart', (mainView) => {
                            mainView.querySelector('.js-cart-container').appendChild(emptyView);
                        });
                    });
                    return;
                }

                this.renderTemplate('tpl-cart', (mainView) => {
                    const container = mainView.querySelector('.js-cart-container');
                    const layoutTpl = document.getElementById('tpl-cart-layout').content.cloneNode(true);
                    const listContainer = layoutTpl.querySelector('.js-cart-items');
                    const itemTpl = document.getElementById('tpl-cart-item');
                    
                    let total = 0;

                    this.cart.forEach((item, index) => {
                        total += (item.price * item.qty);
                        const row = itemTpl.content.cloneNode(true);
                        
                        row.querySelector('.js-item-title').textContent = item.title;
                        row.querySelector('.js-item-price').textContent = `${DB.currency}${item.price}`;
                        row.querySelector('.js-item-qty').textContent = item.qty;
                        row.querySelector('.js-item-img').textContent = item.img;

                        row.querySelector('.js-qty-add').onclick = () => this.cartUpdate(index, 1);
                        row.querySelector('.js-qty-sub').onclick = () => this.cartUpdate(index, -1);
                        row.querySelector('.js-item-remove').onclick = () => {
                            this.cart.splice(index, 1);
                            this.cartSave();
                            this.renderCart();
                        };

                        listContainer.appendChild(row);
                    });

                    layoutTpl.querySelector('.js-cart-subtotal').textContent = `${DB.currency}${total.toFixed(2)}`;
                    layoutTpl.querySelector('.js-cart-total').textContent = `${DB.currency}${total.toFixed(2)}`;
                    container.appendChild(layoutTpl);
                });
            }

            renderCheckout() {
                if(this.cart.length === 0) return window.location.hash = 'cart';
                this.renderTemplate('tpl-checkout', (view) => {
                    view.querySelector('.js-checkout-form').onsubmit = (e) => {
                        e.preventDefault();
                        this.cart = []; 
                        this.cartSave();
                        window.location.hash = 'success';
                    };
                });
            }

            renderSearch() {
                this.renderTemplate('tpl-search', (view) => {
                    const input = view.querySelector('.js-search-input');
                    const results = view.querySelector('.js-search-results');
                    const prodTpl = document.getElementById('tpl-product-card');

                    input.oninput = (e) => {
                        const query = e.target.value.toLowerCase();
                        results.innerHTML = '';
                        if(query.length < 2) return;

                        const hits = DB.products.filter(p => p.title.toLowerCase().includes(query) || p.category.toLowerCase().includes(query));
                        hits.forEach(p => {
                            const card = prodTpl.content.cloneNode(true);
                            card.querySelector('.js-prod-link').href = `#product/${p.id}`;
                            card.querySelector('.js-title').textContent = p.title;
                            card.querySelector('.js-price').textContent = `${DB.currency}${p.price}`;
                            card.querySelector('.js-img-placeholder').textContent = p.img;
                            results.appendChild(card);
                        });
                    };
                });
            }

            renderAccount() {
                this.renderTemplate('tpl-account', (view) => {
                    view.querySelector('.js-logout').onclick = () => {
                        this.isLoggedIn = false;
                        localStorage.removeItem('verdant_auth');
                        window.location.hash = 'home';
                        this.showToast("Signed Out");
                    };
                });
            }

            renderSuccess() { this.renderTemplate('tpl-success'); }
            
            renderStatic(title, content) {
                this.renderTemplate('tpl-static', (view) => {
                    view.querySelector('.js-static-title').textContent = title;
                    view.querySelector('.js-static-content').textContent = content;
                });
            }

            bindAuth(view) {
                view.querySelector('.js-auth-form').onsubmit = (e) => {
                    e.preventDefault();
                    this.isLoggedIn = true;
                    localStorage.setItem('verdant_auth', 'true');
                    window.location.hash = 'account';
                    this.showToast("Signed In Successfully");
                };
            }

            // Cart Data Mutators
            cartAdd(product) {
                const existing = this.cart.find(item => item.id === product.id);
                if (existing) { existing.qty += 1; } 
                else { this.cart.push({ ...product, qty: 1 }); }
                this.cartSave();
            }

            cartUpdate(index, amount) {
                this.cart[index].qty += amount;
                if (this.cart[index].qty <= 0) this.cart.splice(index, 1);
                this.cartSave();
                this.renderCart(); 
            }

            cartSave() {
                localStorage.setItem('verdant_cart', JSON.stringify(this.cart));
                this.updateCartCount();
            }

            updateCartCount() {
                const count = this.cart.reduce((sum, item) => sum + item.qty, 0);
                document.querySelectorAll('.js-cart-count').forEach(el => el.textContent = count);
            }
        }

        // --- 3. BOOTSTRAP ---
        document.addEventListener('DOMContentLoaded', () => { window.App = new StoreEngine(); });
    </script>
</body>
</html>