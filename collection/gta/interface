    <script>
        // --- 1. MOCK DATABASE (With Real Image Samples for Demo) ---
        const DB = {
            currency: '¤',
            products: [
                { id: 1, title: 'Archiv Ganton Tee // Green', price: 45, category: 'Apparel', respect: 85, durability: 95, style: 10, img: 'https://images.unsplash.com/photo-1521577352947-9bb58764b69a?q=80&w=600', desc: 'Raw cotton crew neck. Ganton Dist. Supply issue. 300GSM.' },
                { id: 2, title: 'Structure Pant 01', price: 180, category: 'Apparel', respect: 90, durability: 90, style: 5, img: 'https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?q=80&w=600', desc: 'Heavy weight technical canvas. Reinforced knees. Industrial pigment.' },
                { id: 3, title: 'Obsidian Tote G2', price: 90, category: 'Hardware', respect: 70, durability: 100, style: 0, img: 'https://images.unsplash.com/photo-1616110304325-177659424844?q=80&w=600', desc: 'Ballistic nylon construction. Archival carry system. Modular compatibility.' },
                { id: 4, title: 'VLT Cap // Safety', price: 55, category: 'Headwear', respect: 95, durability: 70, style: 15, img: 'https://images.unsplash.com/photo-1574633719262-67858c89a071?q=80&w=600', desc: 'Low profile crown. Safety orange pigment. RFID blocking lining.' },
                { id: 5, title: 'Field Monitor Core', price: 490, category: 'Hardware', respect: 100, durability: 80, style: 0, img: 'https://images.unsplash.com/photo-1510127034890-ba27508e9f1c?q=80&w=600', desc: 'Titanium frame HUD integration. 12hr battery. verified by VMTECH.' }
            ]
        };

        class GtaStoreEngine {
            constructor() {
                this.root = document.getElementById('app-root');
                this.cart = JSON.parse(localStorage.getItem('sa_cart')) || [];
                this.isLoggedIn = localStorage.getItem('sa_auth') === 'true';
                
                this.initRouter();
                this.updateCartCount();
            }

            // --- LAYOUT & TOASTS ---
            // using Mission Text style notification
            showToast(msg) {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = 'font-menu text-3xl uppercase text-white bg-black/80 px-10 py-4 border-2 border-white gta-reveal mb-2';
                toast.innerHTML = `<span class="text-sa-orange">Inventory:</span> ${msg}`;
                container.appendChild(toast);
                
                setTimeout(() => {
                    toast.remove();
                }, 3000);
            }

            // --- ROUTER LOGIC ---
            initRouter() {
                window.addEventListener('hashchange', () => this.route());
                this.route(); // Trigger on load
            }

            route() {
                const hash = window.location.hash.slice(1) || 'home';
                const [view, id] = hash.split('/');
                this.root.classList.remove('gta-reveal');
                void this.root.offsetWidth; // Trigger reflow
                this.root.classList.add('gta-reveal');
                // Removed window.scrollTo(0,0) as items render inside a scrollable panel

                // Update NAV highlights
                document.querySelectorAll('.js-nav-link').forEach(link => {
                    link.classList.remove('active');
                    if(link.getAttribute('href') === `#${view}`) link.classList.add('active');
                });

                // Routing Switchboard
                switch(view) {
                    case 'shop': this.renderShop(); break;
                    case 'product': this.renderProduct(id); break;
                    case 'cart': this.renderCart(); break;
                    case 'checkout': this.renderCheckout(); break;
                    case 'success': this.renderSuccess(); break;
                    case 'auth': this.isLoggedIn ? this.renderAccount() : this.renderTemplate('tpl-auth', this.bindAuth); break;
                    case 'account': this.isLoggedIn ? this.renderAccount() : window.location.hash = 'auth'; break;
                    case 'about': this.renderStatic('S.A. Supplies Manifesto', 'Validation of formal integrity and spatial dialogue. Artifacts designed for quiet presence in high-weight environments. Verified Supply // EST. 1992.'); break;
                    default: this.renderTemplate('tpl-home'); break;
                }
            }

            renderTemplate(templateId, callback = null) {
                const tpl = document.getElementById(templateId);
                if (!tpl) return;
                this.root.innerHTML = '';
                this.root.appendChild(tpl.content.cloneNode(true));
                if (callback) callback.call(this, this.root);
            }

            // --- VIEW CONTROLLERS ---

            renderShop() {
                this.renderTemplate('tpl-shop', (view) => {
                    const grid = view.querySelector('.js-product-grid');
                    const prodTpl = document.getElementById('tpl-product-card');
                    view.querySelector('.js-collection-count').textContent = DB.products.length;

                    DB.products.forEach(p => {
                        const card = prodTpl.content.cloneNode(true);
                        card.querySelector('.js-prod-link').href = `#product/${p.id}`;
                        card.querySelector('.js-title').textContent = p.title;
                        card.querySelector('.js-category').textContent = p.category;
                        card.querySelector('.js-price').textContent = `${DB.currency}${p.price}`;
                        
                        // Real product image
                        const imgEl = card.querySelector('.js-card-img');
                        imgEl.src = p.img;
                        imgEl.alt = `Photo of ${p.title}`;

                        grid.appendChild(card);
                    });
                });
            }

            renderProduct(id) {
                const product = DB.products.find(p => p.id == id);
                if (!product) return window.location.hash = 'shop';

                this.renderTemplate('tpl-product', (view) => {
                    view.querySelector('.js-detail-title').textContent = product.title;
                    view.querySelector('.js-detail-price').textContent = `${DB.currency}${product.price}`;
                    view.querySelector('.js-detail-desc').textContent = product.desc;
                    view.querySelector('.js-detail-cat').textContent = `Object ID: ${product.id}`;
                    
                    // Real PDP image
                    const imgEl = view.querySelector('.js-detail-img');
                    imgEl.src = product.img;
                    imgEl.alt = `High resolution photo of ${product.title}`;

                    // Render Stat Bars
                    view.querySelector('.js-stat-respect').style.width = `${product.respect}%`;
                    view.querySelector('.js-stat-durability').style.width = `${product.durability}%`;
                    view.querySelector('.js-stat-style').style.width = `${product.style}%`;

                    view.querySelector('.js-add-btn').onclick = () => {
                        this.cartAdd(product);
                        this.showToast(`Object Acquired: ${product.title}`);
                    };
                });
            }

            renderCart() {
                if (this.cart.length === 0) {
                    this.renderTemplate('tpl-cart', v => v.querySelector('.js-cart-container').appendChild(document.getElementById('tpl-cart-empty').content.cloneNode(true)));
                    return;
                }
                this.renderTemplate('tpl-cart', (mainView) => {
                    const container = mainView.querySelector('.js-cart-container');
                    const layout = document.getElementById('tpl-cart-layout').content.cloneNode(true);
                    const list = layout.querySelector('.js-cart-items');
                    let total = 0;

                    this.cart.forEach((item, index) => {
                        total += (item.price * item.qty);
                        const row = document.getElementById('tpl-cart-item').content.cloneNode(true);
                        
                        row.querySelector('.js-item-title').textContent = item.title;
                        row.querySelector('.js-item-price').textContent = `${DB.currency}${item.price}`;
                        row.querySelector('.js-item-qty').textContent = item.qty;
                        row.querySelector('.js-item-img').src = item.img;

                        // Cart Actions
                        row.querySelector('.js-qty-add').onclick = () => this.cartUpdate(index, 1);
                        row.querySelector('.js-qty-sub').onclick = () => this.cartUpdate(index, -1);
                        row.querySelector('.js-item-remove').onclick = () => { this.cart.splice(index, 1); this.cartSave(); this.renderCart(); };

                        list.appendChild(row);
                    });

                    layout.querySelector('.js-cart-total').textContent = `${DB.currency}${total.toFixed(2)}`;
                    container.appendChild(layout);
                });
            }

            renderCheckout() {
                this.renderTemplate('tpl-checkout', (view) => {
                    view.querySelector('.js-checkout-form').onsubmit = (e) => {
                        e.preventDefault();
                        this.cart = []; this.cartSave(); window.location.hash = 'success';
                    };
                });
            }

            renderSuccess() { this.renderTemplate('tpl-success'); }
            
            renderAccount() {
                this.renderTemplate('tpl-account', (view) => {
                    view.querySelector('.js-logout').onclick = () => {
                        this.isLoggedIn = false;
                        localStorage.removeItem('sa_auth');
                        window.location.hash = 'home';
                    };
                });
            }

            renderStatic(title, content) {
                this.renderTemplate('tpl-static', (view) => {
                    view.querySelector('.js-static-title').textContent = title;
                    view.querySelector('.js-static-content').textContent = content;
                });
            }

            bindAuth(view) {
                view.querySelector('.js-auth-form').onsubmit = (e) => {
                    e.preventDefault();
                    this.isLoggedIn = true;
                    localStorage.setItem('sa_auth', 'true');
                    window.location.hash = 'account';
                };
            }

            // --- CART DATA MUTATIONS ---
            cartAdd(product) {
                const existing = this.cart.find(item => item.id === product.id);
                if (existing) { existing.qty += 1; } else { this.cart.push({ ...product, qty: 1 }); }
                this.cartSave();
            }

            cartUpdate(index, amount) {
                this.cart[index].qty += amount;
                if (this.cart[index].qty <= 0) this.cart.splice(index, 1);
                this.cartSave();
                this.renderCart(); 
            }

            cartSave() {
                localStorage.setItem('sa_cart', JSON.stringify(this.cart));
                this.updateCartCount();
            }

            updateCartCount() {
                const count = this.cart.reduce((sum, item) => sum + item.qty, 0);
                document.querySelectorAll('.js-cart-count').forEach(el => el.textContent = count);
            }
        }

        // --- 3. BOOTSTRAP ---
        document.addEventListener('DOMContentLoaded', () => {
            window.App = new GtaStoreEngine();
        });
    </script>
</body>
</html>