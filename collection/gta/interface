<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>S.A. SUPPLIES // Curated Artifacts</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Bebas+Neue&family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        sa: {
                            black: '#0A0A0A',
                            white: '#FFFFFF',
                            orange: '#F2A900', // Iconic SA Menu Orange/Yellow
                            cyan: '#00F0FF',
                            gray: '#222222',
                            border: '#FFFFFF'
                        }
                    },
                    fontFamily: {
                        gothic: ['"UnifrakturMaguntia"', 'serif'], // Game Menu Gothic
                        menu: ['"Bebas Neue"', 'sans-serif'], // Game Option font
                        mono: ['"Roboto Mono"', 'monospace'] // Game details
                    }
                }
            }
        }
    </script>
    <style>
        body { 
            background-color: #0A0A0A; 
            background-image: linear-gradient(to bottom right, #000000 0%, #1A1A00 50%, #000000 100%);
            color: #FFFFFF; 
            font-family: 'Helvetica', sans-serif;
            letter-spacing: -0.01em; 
            overflow: hidden;
        }

        /* Mission/Page transition */
        .gta-reveal { animation: gtaIn 0.3s ease-out forwards; }
        @keyframes gtaIn { from { opacity: 0; transform: scale(1.05); } to { opacity: 1; transform: scale(1); } }
        .hidden { display: none !important; }

        /* The SA Vinewood Background Mockup */
        .vinewood-overlay {
            position: fixed; top: 32px; right: 32px; z-index: -1;
            font-size: 15rem; font-weight: 900; color: #FFFFFF;
            font-family: Arial, sans-serif; text-transform: uppercase;
            letter-spacing: -0.05em; line-height: 0.8;
            background-image: linear-gradient(to top, rgba(161, 161, 161, 0.4) 0%, rgba(255, 255, 255, 0) 100%);
            -webkit-background-clip: text; color: transparent;
            animation: slowScroll 60s linear infinite;
        }
        @keyframes slowScroll { from { transform: translate(0,0); } to { transform: translate(-200px,-20px); } }

        /* Icon: The unique cross/star from the menu */
        .selected-star {
            color: #F2A900; font-size: 2.5rem;
            position: absolute; left: -50px; top: 50%; transform: translateY(-50%);
            display: none;
        }

        /* Interactive Menu Selection */
        .menu-item {
            position: relative;
            cursor: pointer;
            transition: color 0.1s ease;
        }
        .menu-item:hover, .menu-item.active {
            color: #F2A900 !important;
        }
        .menu-item:hover .selected-star, .menu-item.active .selected-star {
            display: block;
        }

        /* Game stat bar container */
        .stat-bar-bg { background-color: #222222; height: 10px; width: 100%; position: relative; }
        .stat-bar-fill { background-color: #FFFFFF; height: 100%; position: absolute; top: 0; left: 0; }
        
        input { background: transparent; border-bottom: 2px solid white; color: white; padding: 10px; text-transform: uppercase; font-weight: bold; font-family: 'Roboto Mono', monospace;}
        input:focus { outline: none; border-color: #F2A900; }
    </style>
</head>
<body class="antialiased selection:bg-sa-orange selection:text-sa-black flex items-center justify-center min-h-screen">

    <div class="vinewood-overlay pointer-events-none">
        VI<span style="opacity:0.6">NEWO</span>OD
    </div>

    <div class="relative w-[95%] max-w-[1400px] h-[90vh] glass-panel bg-black border-4 border-sa-border p-16 flex gta-reveal">
        
