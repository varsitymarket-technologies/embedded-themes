    <script>
        /**
         * Authentic Culturally Rich Dataset
         */
        const INVENTORY_DB = [
            { id: 'imr-01', name: 'Agaseke Terracotta Storage Vase', price: 95.00, category: 'Homeware', origin: 'Rwanda Collective', images: ['https://images.unsplash.com/photo-1534349762230-e0cac37a3e1d?q=80&w=800&auto=format&fit=crop'], desc: 'Meticulously woven from natural sisal fibers and sweet grass by a cooperative of over 40 female artisans in southern Rwanda. Features the traditional geometric apex indicator.', spec: 'Handwoven / Organic Dyes / 12 inch height' },
            { id: 'imr-02', name: 'Cold-Pressed Shea & Marula Elixir', price: 62.00, category: 'Wellness', origin: 'Ghana Apothecary', images: ['https://images.unsplash.com/photo-1601049541289-9b1b7bbbfe19?q=80&w=800&auto=format&fit=crop'], desc: 'Highly restorative skin balm produced completely raw from northern Ghanaian wild-harvested shea trees, fortified with Ugandan marula kernel oil extracts. Rich in vitamins A and E.', spec: '100ml / Fair Trade Certified / Recycled Glass Jar' },
            { id: 'imr-03', name: 'Asymmetrical Hand-Spun Linen Wrap', price: 245.00, category: 'Apparel', origin: 'Lagos Design House', images: ['https://images.unsplash.com/photo-1590736969955-71cb91d3176d?q=80&w=800&auto=format&fit=crop'], desc: 'Tailored perfectly using breathable raw flax linen from local independent micro-weavers. Features modular tying mechanisms that fit gracefully on all silhouettes.', spec: 'One Size Adjustable / Natural Ochre Base / Dry Clean Only' },
            { id: 'imr-04', name: 'Hammered Brass Statement Torque', price: 115.00, category: 'Jewelry', origin: 'Kibera Metalsmiths', images: ['https://images.unsplash.com/photo-1611591437281-460bfbe1220a?q=80&w=800&auto=format&fit=crop'], desc: 'Individually sculpted and detailed using upcycled industrial brass parts by women metal smith collectives in Nairobi. Accents facial bone structures with minimalist luster.', spec: 'Polished Finish / Variable fit / Hypoallergenic' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- SPA ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                
                if (view === '#shop') { app.store.filterCatalog('all'); } 
                else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } 
                else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0, behavior: 'smooth'});
            }
        };

        // --- STORE CATALOG MODULE ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="group cursor-pointer flex flex-col bg-white border border-[var(--border-soft)] rounded-sm p-4 shadow-xs" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[4/5] w-full overflow-hidden bg-[var(--bg-warm)] mb-5 relative rounded-xs">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover object-center group-hover:scale-102 transition-transform duration-500">
                            <div class="absolute bottom-3 left-3 right-3 translate-y-[120%] group-hover:translate-y-0 transition-transform duration-300">
                                <button onclick="event.stopPropagation(); app.cart.addItem('${item.id}')" class="w-full bg-[#2C221E] text-white py-3 text-[10px] tracking-widest uppercase hover:bg-[var(--brand-terracotta)] shadow-md transition-colors">Acquire Item</button>
                            </div>
                        </div>
                        <div class="flex flex-col flex-grow text-left">
                            <div class="flex justify-between items-baseline mb-1">
                                <span class="text-[10px] text-[var(--brand-ochre)] font-bold tracking-wider uppercase">${item.origin}</span>
                                <span class="text-xs font-medium text-[var(--text-muted)]">$${item.price.toFixed(2)}</span>
                            </div>
                            <h3 class="font-serif text-base text-[var(--text-dark)] group-hover:text-[var(--brand-terracotta)] transition-colors line-clamp-1">${item.name}</h3>
                        </div>
                    </div>`).join('');
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB];
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="w-full lg:col-span-6 aspect-[4/5] overflow-hidden rounded-sm bg-white border border-[var(--border-soft)] p-4">
                        <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover rounded-xs">
                    </div>
                    <div class="w-full lg:col-span-6 flex flex-col justify-center">
                        <span class="text-xs font-bold text-[var(--brand-ochre)] tracking-widest uppercase mb-2 block">${item.origin} — ${item.category}</span>
                        <h1 class="font-serif text-3xl sm:text-4xl text-[var(--text-dark)] leading-tight mb-4">${item.name}</h1>
                        <p class="text-xl text-[var(--brand-terracotta)] font-semibold mb-8">$${item.price.toFixed(2)}</p>
                        
                        <div class="text-sm text-[var(--text-muted)] leading-relaxed mb-8 border-t border-b border-[var(--border-soft)] py-6 space-y-4">
                            <p>${item.desc}</p>
                            <p class="text-xs"><strong class="text-[var(--text-dark)] uppercase tracking-wider font-semibold">Specifications:</strong> ${item.spec}</p>
                        </div>
                        
                        <button onclick="app.cart.addItem('${item.id}')" class="w-full py-4 btn-terracotta text-xs tracking-widest uppercase shadow-md flex justify-center items-center gap-2">
                            <i data-lucide="lock" class="w-4 h-4"></i> Secure Allocation
                        </button>

                        <div class="mt-6 grid grid-cols-2 gap-4 text-[11px] text-[var(--text-muted)] pt-2">
                            <div class="flex items-center gap-2"><i data-lucide="shield-check" class="w-4 h-4 text-[var(--brand-ochre)]"></i> Direct Trade Certified</div>
                            <div class="flex items-center gap-2"><i data-lucide="package" class="w-4 h-4 text-[var(--brand-ochre)]"></i> Carbon Neutral Freight</div>
                        </div>
                    </div>`;
                lucide.createIcons();
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase()) || i.origin.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="flex items-center space-x-4 p-3 bg-white border border-[var(--border-soft)] hover:border-[var(--brand-terracotta)] rounded-sm cursor-pointer transition-all shadow-xs group">
                        <img src="${i.images[0]}" class="w-12 h-16 object-cover rounded-xs">
                        <div class="flex-grow">
                            <span class="block text-[10px] uppercase tracking-wider font-bold text-[var(--brand-ochre)]">${i.origin}</span>
                            <span class="block font-serif text-base text-[var(--text-dark)] group-hover:text-[var(--brand-terracotta)] transition-colors">${i.name}</span>
                        </div>
                        <span class="font-serif text-sm text-[var(--text-dark)]">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- CART LEDGER SYSTEM ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('imr_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`${prod.name} registered in ledger.`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) { const item = app.state.cart.find(i => i.product.id === id); if (!item) return; item.qty += val; if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id); this.sync(); },
            sync: function() { localStorage.setItem('imr_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                if (totalItems > 0) { badge.classList.remove('opacity-0'); badge.innerText = totalItems; } else { badge.classList.add('opacity-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-center text-[var(--text-muted)] text-xs py-16">Your artisan ledger is currently empty.</div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex space-x-4 bg-white border border-[var(--border-soft)] p-4 rounded-sm shadow-xs">
                            <img src="${item.product.images[0]}" class="w-16 h-20 object-cover rounded-xs shrink-0">
                            <div class="flex flex-col justify-between flex-grow">
                                <div>
                                    <h4 class="font-serif text-sm text-[var(--text-dark)] leading-tight mb-1">${item.product.name}</h4>
                                    <p class="text-[10px] text-[var(--brand-ochre)] font-bold uppercase tracking-wider">${item.product.origin}</p>
                                </div>
                                <div class="flex justify-between items-center mt-2">
                                    <div class="flex items-center space-x-3 border border-[var(--border-soft)] px-2.5 py-1 rounded-sm bg-[var(--bg-warm)]/40 text-xs">
                                        <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="text-[var(--text-muted)] hover:text-black font-bold">&minus;</button>
                                        <span class="text-xs font-semibold text-[var(--text-dark)] w-4 text-center">${item.qty}</span>
                                        <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="text-[var(--text-muted)] hover:text-black font-bold">&plus;</button>
                                    </div>
                                    <span class="text-xs font-medium text-[var(--text-muted)]">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>`).join('');
                }
            }
        };

        // --- CHECKOUT FORM LOGIC ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-sub').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex justify-between items-center py-3 border-b border-[var(--border-soft)]/60 last:border-0">
                        <div class="flex items-center space-x-3">
                            <div class="relative">
                                <img src="${i.product.images[0]}" class="w-10 h-14 object-cover rounded-xs">
                                <span class="absolute -top-1.5 -right-1.5 bg-[var(--brand-terracotta)] text-white text-[9px] w-4.5 h-4.5 rounded-full flex items-center justify-center font-bold">${i.qty}</span>
                            </div>
                            <span class="text-[var(--text-dark)] font-serif text-xs max-w-[160px] truncate">${i.product.name}</span>
                        </div>
                        <span class="text-[var(--text-muted)] text-xs font-medium">$${(i.product.price * i.qty).toFixed(2)}</span>
                    </div>`).join('');
                
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-[var(--brand-terracotta)] font-bold" : "text-[var(--text-muted)]";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-[var(--brand-terracotta)] font-bold" : "text-[var(--text-muted)]";

                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <div class="flex flex-col space-y-4">
                            <input type="email" required placeholder="Legal Email Address" class="imara-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="First Name" class="imara-input">
                                <input type="text" required placeholder="Last Name" class="imara-input">
                            </div>
                            <input type="text" required placeholder="Destination Street Address" class="imara-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="City / Settlement" class="imara-input">
                                <input type="text" required placeholder="Postal Code" class="imara-input">
                            </div>
                        </div>`; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <div class="flex flex-col space-y-4">
                            <div class="p-3 bg-emerald-50 text-emerald-800 text-xs font-medium rounded-sm border border-emerald-200 flex justify-between items-center">
                                <span>Delivery Address Documented Accurately</span>
                                <i data-lucide="check-circle" class="w-4 h-4 text-emerald-600"></i>
                            </div>
                            <input type="text" required placeholder="Credit Card Number" class="imara-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="Expiry Date (MM/YY)" class="imara-input">
                                <input type="text" required placeholder="Security Code (CVC)" class="imara-input">
                            </div>
                        </div>`; 
                    lucide.createIcons();
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    app.ui.triggerToast("Order secure. We honor your partnership."); 
                    app.router.navigate('home'); 
                } 
            }
        };

        // --- INTERFACE UTILITIES ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    return; 
                }
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                }
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); 
                document.getElementById('toast-notif-message').innerText = msg;
                t.classList.remove('opacity-0', 'translate-y-3', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-y-3', 'pointer-events-none'); 
                }, 3500);
            }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
