<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMARA | Modern Heritage</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prata&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-warm: #FAF6F0;
            --text-dark: #2C221E;
            --text-muted: #7A6E67;
            --brand-ochre: #D49B41;
            --brand-terracotta: #B95C38;
            --border-soft: #EAE3D8;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--bg-warm); 
            color: var(--text-dark); 
            -webkit-font-smoothing: antialiased;
        }
        .font-serif { font-family: 'Prata', serif; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: warmFade 0.6s cubic-bezier(0.215, 0.610, 0.355, 1) forwards; }
        
        @keyframes warmFade {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Earthy Premium Inputs */
        .imara-input { 
            border: 1px solid var(--border-soft); 
            background-color: #FFFFFF;
            color: var(--text-dark);
            border-radius: 2px;
            padding: 14px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        .imara-input:focus { 
            outline: none; 
            border-color: var(--brand-terracotta);
            box-shadow: 0 0 0 1px var(--brand-terracotta);
        }
        
        /* Artisan Buttons */
        .btn-terracotta {
            background-color: var(--brand-terracotta);
            color: #FFFFFF;
            font-weight: 500;
            letter-spacing: 0.05em;
            transition: all 0.3s ease;
        }
        .btn-terracotta:hover {
            background-color: #9C4B2C;
        }

        .btn-outline {
            border: 1px solid var(--text-dark);
            background-color: transparent;
            color: var(--text-dark);
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background-color: var(--text-dark);
            color: var(--bg-warm);
        }

        /* Delicate Custom Scrollbar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: var(--bg-warm); }
        ::-webkit-scrollbar-thumb { background: var(--border-soft); }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[#B95C38] selection:text-white">

