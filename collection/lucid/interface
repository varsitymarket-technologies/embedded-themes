    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-red: #E32726;
            --brand-black: #111111;
            --brand-gray: #F5F5F5;
        }
        
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #FFFFFF; 
            color: var(--brand-black); 
            -webkit-font-smoothing: antialiased;
        }
        .font-display { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: quickFade 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        
        @keyframes quickFade {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Sneaker Inputs */
        .lucid-input { 
            border: 1px solid #E5E5E5; 
            background-color: #FFFFFF;
            color: var(--brand-black);
            border-radius: 4px;
            padding: 16px;
            font-size: 14px;
            transition: border-color 0.2s ease;
        }
        .lucid-input:focus { 
            outline: none; 
            border-color: var(--brand-black); 
        }
        
        /* Athletic Buttons */
        .btn-black {
            background-color: var(--brand-black);
            color: #FFFFFF;
            border-radius: 9999px; /* Pill shape */
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .btn-black:hover {
            background-color: #333333;
            transform: scale(1.02);
        }

        .btn-outline {
            border: 1px solid #E5E5E5;
            background-color: #FFFFFF;
            color: var(--brand-black);
            border-radius: 9999px;
            transition: all 0.2s ease;
        }
        .btn-outline:hover {
            border-color: var(--brand-black);
        }

        .btn-size {
            border: 1px solid #E5E5E5;
            border-radius: 4px;
            transition: all 0.2s ease;
        }
        .btn-size:hover { border-color: var(--brand-black); }
        .btn-size.selected { border-color: var(--brand-black); box-shadow: inset 0 0 0 1px var(--brand-black); }

        /* Minimal Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #F5F5F5; }
        ::-webkit-scrollbar-thumb { background: #CCCCCC; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #999999; }
    </style>
</head>
