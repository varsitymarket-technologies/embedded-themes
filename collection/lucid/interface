    <script>
        /**
         * Athletic Sneaker Dataset
         */
        const INVENTORY_DB = [
            { id: 'ar-01', name: 'Lucid Retro 1 High', price: 180.00, category: "Men's Shoes", images: ['https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?q=80&w=800&auto=format&fit=crop'], desc: 'Familiar but always fresh, the iconic Lucid 1 is remastered for today\'s sneaker culture. This Retro High OG version features premium leather, comfortable cushioning and classic design details.' },
            { id: 'ar-02', name: 'Lucid React Vision', price: 140.00, category: "Men's Shoes", images: ['https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=800&auto=format&fit=crop'], desc: 'Inspired by the exaggerated proportions of 90s running shoes, the Lucid React features a lightweight upper and plush React foam for all-day comfort.' },
            { id: 'ar-03', name: 'Lucid Force Low', price: 110.00, category: "Women's Shoes", images: ['https://images.unsplash.com/photo-1551107696-a4b0c5a0d9a2?q=80&w=800&auto=format&fit=crop'], desc: 'The radiance lives on in the Lucid Force, the b-ball OG that puts a fresh spin on what you know best: crisply stitched overlays, bold colors and the perfect amount of flash.' },
            { id: 'ar-04', name: 'Lucid Max 95', price: 170.00, category: "Men's Shoes", images: ['https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=800&auto=format&fit=crop'], desc: 'Taking inspiration from the human body and running DNA, the Lucid Max 95 mixes unbelievable comfort with head-turning style. The iconic side panels represent muscles.' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1, selectedSize: null },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                if (view === '#shop') { app.store.filterCatalog('all'); } 
                else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } 
                else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0, behavior: 'auto'});
            }
        };

        // --- STORE ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="group cursor-pointer flex flex-col" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[4/5] bg-[#F5F5F5] rounded-xl overflow-hidden mb-4 p-8 flex items-center justify-center relative">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 mix-blend-multiply">
                        </div>
                        <div>
                            <div class="text-[var(--brand-red)] text-xs font-medium mb-1">Just In</div>
                            <h3 class="font-medium text-[16px] text-black leading-tight">${item.name}</h3>
                            <p class="text-[15px] text-neutral-500 mt-1">${item.category}</p>
                            <p class="font-medium text-[16px] mt-2">$${item.price.toFixed(2)}</p>
                        </div>
                    </div>`).join('');
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB];
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            selectSize: function(size) {
                app.state.selectedSize = size;
                document.querySelectorAll('.btn-size').forEach(btn => btn.classList.remove('selected'));
                event.target.classList.add('selected');
                document.getElementById('size-error').classList.add('hidden');
            },
            handleAddToCart: function(id) {
                if(!app.state.selectedSize) {
                    document.getElementById('size-error').classList.remove('hidden');
                    return;
                }
                app.cart.addItem(id, app.state.selectedSize);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                app.state.selectedSize = null; // Reset size selection

                const sizes = ['M 7 / W 8.5', 'M 7.5 / W 9', 'M 8 / W 9.5', 'M 8.5 / W 10', 'M 9 / W 10.5', 'M 9.5 / W 11', 'M 10 / W 11.5', 'M 10.5 / W 12', 'M 11 / W 12.5', 'M 11.5 / W 13', 'M 12 / W 13.5', 'M 12.5 / W 14'];

                document.getElementById('product-detail-target').innerHTML = `
                    <div class="space-y-4">
                        <div class="w-full aspect-square bg-[#F5F5F5] rounded-xl overflow-hidden p-8 lg:p-16 flex items-center justify-center sticky top-24">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover mix-blend-multiply hover:scale-105 transition-transform duration-700">
                        </div>
                    </div>
                    
                    <div class="flex flex-col py-4 lg:py-10 lg:pl-8">
                        <h1 class="font-display font-bold text-4xl lg:text-5xl uppercase tracking-tighter mb-2">${item.name}</h1>
                        <p class="font-medium text-lg mb-4">${item.category}</p>
                        <p class="font-medium text-xl mb-10">$${item.price.toFixed(2)}</p>
                        
                        <div class="mb-8">
                            <div class="flex justify-between items-end mb-4">
                                <span class="font-medium">Select Size</span>
                                <span class="text-neutral-500 font-medium text-sm cursor-pointer hover:text-black">Size Guide</span>
                            </div>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                                ${sizes.map(size => `<button onclick="app.store.selectSize('${size}')" class="btn-size py-3 font-medium text-sm hover:border-black focus:outline-none">${size}</button>`).join('')}
                            </div>
                            <p id="size-error" class="text-[var(--brand-red)] text-sm font-medium mt-3 hidden">Please select a size.</p>
                        </div>

                        <div class="space-y-3 mb-12">
                            <button onclick="app.store.handleAddToCart('${item.id}')" class="w-full py-5 btn-black text-lg">Add to Bag</button>
                            <button class="w-full py-5 btn-outline font-medium text-lg flex justify-center items-center gap-2">
                                Favorite <i data-lucide="heart" class="w-5 h-5"></i>
                            </button>
                        </div>
                        
                        <p class="text-neutral-700 leading-relaxed text-[15px] mb-8">
                            ${item.desc}
                        </p>
                        
                        <div class="border-t border-neutral-200">
                            <div class="py-6 border-b border-neutral-200 flex justify-between items-center cursor-pointer hover:text-neutral-600 font-medium text-lg">
                                <span>Shipping & Returns</span>
                                <i data-lucide="chevron-down" class="w-5 h-5"></i>
                            </div>
                            <div class="py-6 border-b border-neutral-200 flex justify-between items-center cursor-pointer hover:text-neutral-600 font-medium text-lg">
                                <span>Reviews (42)</span>
                                <div class="flex space-x-1 text-black">
                                    <i data-lucide="star" class="w-4 h-4 fill-current"></i>
                                    <i data-lucide="star" class="w-4 h-4 fill-current"></i>
                                    <i data-lucide="star" class="w-4 h-4 fill-current"></i>
                                    <i data-lucide="star" class="w-4 h-4 fill-current"></i>
                                    <i data-lucide="star-half" class="w-4 h-4 fill-current"></i>
                                </div>
                            </div>
                        </div>
                    </div>`;
                lucide.createIcons();
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="flex items-center space-x-4 p-4 hover:bg-[#F5F5F5] rounded-xl cursor-pointer transition-colors group">
                        <div class="w-20 h-20 bg-[#F5F5F5] rounded-md overflow-hidden flex items-center justify-center shrink-0">
                            <img src="${i.images[0]}" class="w-full h-full object-cover mix-blend-multiply">
                        </div>
                        <div>
                            <span class="block font-medium text-lg text-black">${i.name}</span>
                            <span class="block text-sm text-neutral-500 mt-1">${i.category}</span>
                        </div>
                        <div class="ml-auto font-medium">$${i.price}</div>
                    </div>`).join('');
            }
        };

        // --- CART SYSTEM ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('lucid_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id, size) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                // Check if same product AND size exists
                const exist = app.state.cart.find(item => item.product.id === id && item.size === size);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1, size: size });
                this.sync(); 
                app.ui.triggerToast(); 
                app.ui.toggleCartDrawer(true);
            },
            updateQty: function(index, val) { 
                const item = app.state.cart[index]; 
                if (!item) return; 
                item.qty += val; 
                if (item.qty <= 0) app.state.cart.splice(index, 1); 
                this.sync(); 
            },
            sync: function() { localStorage.setItem('lucid_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                if (totalItems > 0) { badge.classList.remove('opacity-0'); badge.innerText = totalItems; } else { badge.classList.add('opacity-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-neutral-500 text-[15px] py-10">There are no items in your bag.</div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map((item, index) => `
                        <div class="flex space-x-6">
                            <div class="w-24 h-24 bg-[#F5F5F5] rounded-md flex items-center justify-center shrink-0 p-2">
                                <img src="${item.product.images[0]}" class="w-full h-full object-cover mix-blend-multiply">
                            </div>
                            <div class="flex flex-col flex-grow">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h4 class="font-medium text-black leading-tight mb-1">${item.product.name}</h4>
                                        <p class="text-[15px] text-neutral-500 mb-1">${item.product.category}</p>
                                        <p class="text-[15px] text-neutral-500 mb-2">Size: ${item.size}</p>
                                    </div>
                                    <span class="font-medium">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                                <div class="flex items-center space-x-4 mt-auto">
                                    <div class="flex items-center space-x-4 bg-[#F5F5F5] rounded-full px-3 py-1">
                                        <button onclick="app.cart.updateQty(${index}, -1)" class="text-neutral-500 hover:text-black font-medium">&minus;</button>
                                        <span class="font-medium text-sm w-4 text-center">${item.qty}</span>
                                        <button onclick="app.cart.updateQty(${index}, 1)" class="text-neutral-500 hover:text-black font-medium">&plus;</button>
                                    </div>
                                    <button onclick="app.cart.updateQty(${index}, -99)" class="text-neutral-500 hover:text-black p-1">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>
                        </div>`).join('');
                }
                lucide.createIcons();
            }
        };

        // --- CHECKOUT ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-sub').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex items-start space-x-4 py-4 border-t border-neutral-300">
                        <div class="w-20 h-20 bg-white rounded-md shrink-0 flex items-center justify-center p-2">
                            <img src="${i.product.images[0]}" class="w-full h-full object-cover mix-blend-multiply">
                        </div>
                        <div class="text-sm">
                            <span class="font-medium block mb-1">${i.product.name}</span>
                            <span class="text-neutral-500 block mb-1">Qty: ${i.qty} | Size: ${i.size}</span>
                            <span class="font-medium text-neutral-500">$${(i.product.price * i.qty).toFixed(2)}</span>
                        </div>
                    </div>`).join('');
                
                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <div class="space-y-4">
                            <input type="email" required placeholder="Email" class="w-full lucid-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="First Name" class="w-full lucid-input">
                                <input type="text" required placeholder="Last Name" class="w-full lucid-input">
                            </div>
                            <input type="text" required placeholder="Address" class="w-full lucid-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="City" class="w-full lucid-input">
                                <input type="text" required placeholder="ZIP Code" class="w-full lucid-input">
                            </div>
                        </div>
                    `; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <div class="p-4 border border-green-500 rounded-md bg-green-50 text-sm font-medium text-green-800 mb-6 flex justify-between items-center">
                            <span>Shipping address saved</span>
                            <i data-lucide="check" class="w-4 h-4"></i>
                        </div>
                        <h3 class="font-medium text-xl mb-6">Payment</h3>
                        <div class="space-y-4">
                            <input type="text" required placeholder="Card Number" class="w-full lucid-input">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" required placeholder="MM/YY" class="w-full lucid-input">
                                <input type="text" required placeholder="CVV" class="w-full lucid-input">
                            </div>
                        </div>
                    `; 
                    lucide.createIcons();
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                    document.querySelector('#view-checkout button[type="submit"]').innerText = "Place Order";
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    alert("Order placed successfully. Got 'em."); 
                    app.router.navigate('home'); 
                } 
            }
        };

        // --- UI UTILS ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    document.body.style.overflow = 'hidden';
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    document.body.style.overflow = '';
                    return; 
                }
                const isOpening = overlay.classList.contains('opacity-0');
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
                document.body.style.overflow = isOpening ? 'hidden' : '';
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    document.body.style.overflow = 'hidden';
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                } else {
                    document.body.style.overflow = '';
                }
            },
            triggerToast: function() {
                const t = document.getElementById('toast-notif'); 
                t.classList.remove('opacity-0', 'translate-x-10', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-x-10', 'pointer-events-none'); 
                }, 3000);
            }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
