<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OASIS // Premium Goods Co. Enterprise</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #ffffff; color: #111111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        .shopify-input:focus { outline: none; border-color: #111111; box-shadow: 0 0 0 1px #111111; }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between">

    <div class="bg-black text-white text-center py-2 text-xs font-medium tracking-widest uppercase px-4">
        Complimentary worldwide shipping on orders over $150
    </div>

    <header class="sticky top-0 bg-white/90 backdrop-blur-md border-b border-gray-100 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            <a href="#home" onclick="app.router.navigate('home')" class="font-serif text-2xl font-bold tracking-tight text-gray-900">
                OASIS<span class="text-sm font-sans tracking-widest text-gray-400 font-light ml-2">STUDIOS</span>
            </a>

            <nav class="hidden md:flex space-x-8 text-xs font-medium tracking-wider uppercase text-gray-600">
                <a href="#home" onclick="app.router.navigate('home')" class="hover:text-black transition-colors">Home</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-black transition-colors">Shop All</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-black transition-colors">Our Story</a>
                <a href="#faq" onclick="app.router.navigate('faq')" class="hover:text-black transition-colors">FAQ</a>
                <a href="#contact" onclick="app.router.navigate('contact')" class="hover:text-black transition-colors">Contact</a>
            </nav>

            <div class="flex items-center space-x-4">
                <button class="p-2 text-gray-700 hover:text-black transition-colors" onclick="app.ui.toggleSearchOverlay()">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </button>
                <button class="p-2 text-gray-700 hover:text-black transition-colors relative" onclick="app.ui.toggleCartDrawer()">
                    <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                    <span id="global-cart-count" class="absolute top-1 right-1 bg-black text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold transition-all transform scale-0">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="relative bg-gray-50 overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                    <div class="space-y-6">
                        <span class="text-xs font-semibold tracking-widest text-gray-400 uppercase">New Season Archetypes</span>
                        <h1 class="font-serif text-5xl sm:text-6xl text-gray-900 leading-tight">Designed for purposeful living.</h1>
                        <p class="text-gray-500 text-base max-w-md font-light leading-relaxed">Monolithic forms, organic textures, and functional silhouettes engineered to anchor the modern environment.</p>
                        <div class="pt-4">
                            <button onclick="app.router.navigate('shop')" class="bg-black text-white px-8 py-4 text-xs font-medium tracking-widest uppercase hover:bg-gray-800 transition rounded-xs">
                                Explore Collection
                            </button>
                        </div>
                    </div>
                    <div class="relative h-[400px] w-full rounded-sm overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover grayscale" alt="Editorial Showcase">
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-gray-100 pb-6 mb-8">
                <div>
                    <h2 class="font-serif text-3xl font-semibold tracking-tight">Index Catalog</h2>
                    <p id="catalog-count-string" class="text-gray-400 text-sm mt-1">Showing items</p>
                </div>
                <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="text-xs border border-gray-200 rounded-sm py-2 px-3 focus:outline-none focus:border-black mt-4 md:mt-0">
                    <option value="featured">Featured</option>
                    <option value="price-low">Price: Low to High</option>
                    <option value="price-high">Price: High to Low</option>
                </select>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                <aside class="space-y-6 hidden lg:block">
                    <div>
                        <h4 class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-3">Categories</h4>
                        <div class="space-y-2 text-sm text-gray-600">
                            <label class="flex items-center space-x-2 cursor-pointer"><input type="radio" name="cat-filter" checked onclick="app.store.filterCatalog('all')"> <span>All Products</span></label>
                            <label class="flex items-center space-x-2 cursor-pointer"><input type="radio" name="cat-filter" onclick="app.store.filterCatalog('apparel')"> <span>Apparel</span></label>
                            <label class="flex items-center space-x-2 cursor-pointer"><input type="radio" name="cat-filter" onclick="app.store.filterCatalog('living')"> <span>Living</span></label>
                        </div>
                    </div>
                </aside>
                <div id="shop-items-grid" class="lg:col-span-3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-x-6"></div>
            </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16"></div>
        </section>

        <section id="view-about" class="view-section max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">
            <div class="text-center max-w-2xl mx-auto space-y-4">
                <span class="text-xs uppercase tracking-widest text-gray-400 font-semibold">// OUR MANIFESTO</span>
                <h2 class="font-serif text-4xl font-medium tracking-tight text-gray-900">Architecting spaces and silhouettes since 2018.</h2>
                <p class="text-gray-500 font-light leading-relaxed">We believe that human environments should express balance, restraint, and deliberate functionality.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=800&auto=format&fit=crop" class="rounded-sm grayscale w-full h-80 object-cover" alt="Workshop">
                <div class="space-y-4">
                    <h3 class="font-serif text-2xl font-medium">Sustainably Cast Materials</h3>
                    <p class="text-gray-500 text-sm leading-relaxed font-light">Every fabric run, container construction, and geometric form layer originates from verified carbon-neutral suppliers. We build slow so that the artifacts outlive temporary structural trends.</p>
                </div>
            </div>
        </section>

        <section id="view-faq" class="view-section max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-8">
            <div class="text-center space-y-2">
                <h2 class="font-serif text-4xl font-medium">Frequently Answered Queries</h2>
                <p class="text-gray-400 text-sm">Clear operational protocols for logistical clarity.</p>
            </div>
            <div class="border-t border-gray-200 divide-y divide-gray-200">
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left font-medium text-sm py-2 focus:outline-none">
                        <span>What is your distribution shipping policy?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-gray-500 text-xs leading-relaxed pt-0">
                        <p class="py-2">All orders exceeding $150 clear standard fulfillment pathways without charge. Domestic transit spans 3–5 operational cycles; international freight routes require up to 10 working cycles depending on terminal customs checks.</p>
                    </div>
                </div>
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left font-medium text-sm py-2 focus:outline-none">
                        <span>How are items authorized for returns or exchanges?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-gray-500 text-xs leading-relaxed pt-0">
                        <p class="py-2">We authorize complete processing updates within 14 sequence days post-delivery. Items must retain intact tags and match native packaging frameworks. Returns are subjected to verification inspections.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-contact" class="view-section max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
                <div class="md:col-span-5 space-y-6">
                    <h2 class="font-serif text-3xl font-medium">Connect With Us</h2>
                    <p class="text-gray-500 text-sm font-light leading-relaxed">Our operational triage desk answers all communications within 24 standard business hours.</p>
                    <div class="space-y-3 text-xs text-gray-600 font-mono">
                        <p class="flex items-center gap-2"><i data-lucide="mail" class="w-4 h-4"></i> support@oasisstudios.com</p>
                        <p class="flex items-center gap-2"><i data-lucide="map-pin" class="w-4 h-4"></i> Suite 404, Metropol Station, NY</p>
                    </div>
                </div>
                <form onsubmit="app.ui.handleContactSubmit(event)" class="md:col-span-7 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <input type="text" required placeholder="Name" class="w-full border border-gray-200 p-3 text-sm shopify-input">
                        <input type="email" required placeholder="Email" class="w-full border border-gray-200 p-3 text-sm shopify-input">
                    </div>
                    <input type="text" placeholder="Order ID (Optional)" class="w-full border border-gray-200 p-3 text-sm shopify-input">
                    <textarea required rows="5" placeholder="State your inquiry specification..." class="w-full border border-gray-200 p-3 text-sm shopify-input"></textarea>
                    <button type="submit" class="bg-black text-white px-6 py-3.5 text-xs font-medium tracking-widest uppercase hover:bg-gray-800 transition rounded-xs">Transmit Transmission</button>
                </form>
            </div>
        </section>

        <section id="view-track" class="view-section max-w-md mx-auto px-4 py-16 space-y-6">
            <div class="text-center space-y-2">
                <h2 class="font-serif text-3xl font-medium">Track Manifest Status</h2>
                <p class="text-gray-400 text-sm">Input your Shopify configuration values to check shipping nodes.</p>
            </div>
            <div class="border border-gray-100 p-6 bg-gray-50 rounded-xs space-y-4">
                <input type="text" id="track-id-input" placeholder="e.g. OS-9982" class="w-full border border-gray-200 bg-white p-3 text-sm shopify-input">
                <button onclick="app.ui.simulateTracking()" class="w-full bg-black text-white py-3 text-xs font-medium tracking-widest uppercase hover:bg-gray-800 transition rounded-xs">Query Node Status</button>
            </div>
            <div id="tracking-result-box" class="hidden p-4 border border-dashed border-gray-200 rounded-sm space-y-2 text-xs font-mono bg-white"></div>
        </section>

        <section id="view-checkout" class="view-section max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-7 space-y-8">
                    <div class="flex items-center space-x-4 text-xs font-medium uppercase tracking-wider text-gray-400">
                        <span id="step-nav-1" class="text-black font-semibold">Information</span>
                        <i data-lucide="chevron-right" class="w-3 h-3"></i>
                        <span id="step-nav-2">Shipping</span>
                        <i data-lucide="chevron-right" class="w-3 h-3"></i>
                        <span id="step-nav-3">Payment</span>
                    </div>
                    <form id="checkout-form" onsubmit="app.checkout.handleStepSubmit(event)" class="space-y-6">
                        <div id="checkout-step-container"></div>
                        <div class="flex justify-between items-center pt-4 border-t border-gray-100">
                            <a href="#shop" onclick="app.router.navigate('shop')" class="text-sm font-medium text-gray-500 hover:text-black">&larr; Return to shop</a>
                            <button type="submit" class="bg-black text-white px-6 py-3.5 text-xs font-medium tracking-widest uppercase hover:bg-gray-800 transition rounded-xs">
                                Continue <span id="checkout-btn-context">to Shipping</span>
                            </button>
                        </div>
                    </form>
                </div>
                <div class="lg:col-span-5 bg-gray-50 p-6 sm:p-8 rounded-sm h-fit space-y-6 border border-gray-100">
                    <h3 class="text-base font-serif font-medium">Order Summary</h3>
                    <div id="checkout-summary-items" class="space-y-4 divide-y divide-gray-100 max-h-64 overflow-y-auto"></div>
                    <div class="space-y-2 pt-4 border-t border-gray-200 text-sm text-gray-600">
                        <div class="flex justify-between"><span>Subtotal</span><span id="chk-subtotal">$0.00</span></div>
                        <div class="flex justify-between"><span>Shipping</span><span>Free</span></div>
                        <div class="flex justify-between text-base font-bold text-gray-900 pt-2 border-t border-gray-100"><span>Total</span><span id="chk-total">$0.00</span></div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-black/30 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-all duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-300 ease-in-out" onclick="event.stopPropagation()">
            <div class="p-6 flex-grow flex flex-col min-h-0">
                <div class="flex items-center justify-between border-b border-gray-100 pb-4 mb-4">
                    <h3 class="text-sm font-medium uppercase tracking-wider">Your Manifest</h3>
                    <button onclick="app.ui.toggleCartDrawer()" class="p-1 text-gray-400 hover:text-black"><i data-lucide="x" class="w-6 h-6"></i></button>
                </div>
                <div id="cart-drawer-items" class="flex-grow overflow-y-auto space-y-4 pr-1"></div>
            </div>
            <div class="p-6 border-t border-gray-100 bg-gray-50 space-y-4">
                <div class="flex justify-between font-medium text-base"><span>Estimated Subtotal</span><span id="cart-drawer-subtotal">$0.00</span></div>
                <button onclick="app.checkout.initiateCheckout()" class="w-full py-4 bg-black text-white font-medium text-xs tracking-widest uppercase hover:bg-gray-800 transition rounded-xs">Proceed to Checkout Flow</button>
            </div>
        </div>
    </div>

    <div id="search-overlay" class="fixed inset-0 bg-white/95 z-50 hidden items-center justify-center p-6">
        <button onclick="app.ui.toggleSearchOverlay()" class="absolute top-6 right-6 p-2 text-gray-400 hover:text-black"><i data-lucide="x" class="w-6 h-6"></i></button>
        <div class="w-full max-w-2xl text-center space-y-6">
            <h3 class="font-serif text-2xl">Search Catalog System</h3>
            <div class="relative">
                <input type="text" id="live-search-input" oninput="app.store.handleSearch(this.value)" placeholder="Search architecture, collections..." class="w-full border-b border-gray-300 py-4 px-2 text-xl font-light focus:outline-none focus:border-black placeholder-gray-300">
                <i data-lucide="search" class="absolute right-4 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-300"></i>
            </div>
            <div id="search-results-output" class="grid grid-cols-2 gap-4 text-left max-h-64 overflow-y-auto pt-4"></div>
        </div>
    </div>

    <div id="toast-notif" class="fixed bottom-6 right-6 bg-gray-900 text-white text-xs py-3.5 px-6 rounded-xs shadow-xl z-50 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none">
        <span id="toast-notif-message">System Update Triggered</span>
    </div>

    <footer class="bg-gray-50 border-t border-gray-100 pt-16 pb-12 text-xs text-gray-500">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 md:grid-cols-4 gap-8 border-b border-gray-200 pb-12 mb-8">
            <div class="space-y-3">
                <h4 class="text-gray-900 font-semibold tracking-wider uppercase">Shop</h4>
                <ul class="space-y-2"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('shop')">All Products</li><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('shop', {category: 'apparel'})">Apparel</li></ul>
            </div>
            <div class="space-y-3">
                <h4 class="text-gray-900 font-semibold tracking-wider uppercase">Corporate</h4>
                <ul class="space-y-2"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('about')">Our Story</li><li class="cursor-pointer hover:text-black">Sustainability</li></ul>
            </div>
            <div class="space-y-3">
                <h4 class="text-gray-900 font-semibold tracking-wider uppercase">Support</h4>
                <ul class="space-y-2"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('faq')">FAQ Portal</li><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('contact')">Contact Assistance</li></ul>
            </div>
            <div class="space-y-3">
                <h4 class="text-gray-900 font-semibold tracking-wider uppercase">Logistics</h4>
                <ul class="space-y-2"><li class="cursor-pointer hover:text-black" onclick="app.router.navigate('track')">Track Order Manifest</li></ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-[11px] tracking-wider uppercase text-gray-400">
            <p>&copy; 2026 Oasis Studios Inc. Built via clean core client runtime execution framework.</p>
        </div>
    </footer>

    <script>
        const INVENTORY_DB = [
            { id: 'item-101', name: 'Standard Raw Denim Jacket', price: 185.00, category: 'apparel', images: ['https://images.unsplash.com/photo-1576995853123-5a10305d93c0?q=80&w=600&auto=format&fit=crop'], desc: 'Rigid selvedge Japanese denim tailored for structural layering.' },
            { id: 'item-102', name: 'Heavyweight Pima Cotton Tee', price: 55.00, category: 'apparel', images: ['https://images.unsplash.com/photo-1521572267360-ee0c2909d518?q=80&w=600&auto=format&fit=crop'], desc: 'Loopwheel construct knit from luxurious extra-long staple Supima yarns.' },
            { id: 'item-103', name: 'Monolith Travertine Vessel', price: 220.00, category: 'living', images: ['https://images.unsplash.com/photo-1612196808214-b8e1d6145a8c?q=80&w=600&auto=format&fit=crop'], desc: 'Honed block stone sculpted with continuous micro-beveled radius execution.' },
            { id: 'item-104', name: 'Ribbed Merino Lounge Pant', price: 140.00, category: 'apparel', images: ['https://images.unsplash.com/photo-1551854838-212c50b4c184?q=80&w=600&auto=format&fit=crop'], desc: 'Superfine temperature-regulating Tasmanian sheep fleece comfort.' }
        ];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: function() { this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons(); }
        };

        // --- STATE MATRIX SPA ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                
                const targetId = `view-${view.replace('#', '')}`;
                const targetView = document.getElementById(targetId);
                if (targetView) targetView.classList.add('active');

                if (view === '#shop') {
                    app.store.filterCatalog(queryParams.category || 'all');
                } else if (view === '#product' && queryParams.id) {
                    app.store.renderProductDetail(queryParams.id);
                } else if (view === '#checkout') {
                    app.checkout.renderCurrentStep();
                }
                window.scrollTo({top:0});
            }
        };

        // --- CATALOG DATA HANDLER ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="group relative flex flex-col justify-between cursor-pointer" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-square w-full rounded-xs overflow-hidden bg-gray-100 mb-4">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-101">
                        </div>
                        <div class="flex justify-between text-sm">
                            <div><h3 class="text-gray-900 font-medium">${item.name}</h3><p class="text-gray-400 text-xs capitalize">${item.category}</p></div>
                            <p class="font-medium text-gray-900">$${item.price.toFixed(2)}</p>
                        </div>
                    </div>`).join('');
                document.getElementById('catalog-count-string').innerText = `Displaying ${itemsToRender.length} architectural items`;
            },
            filterCatalog: function(cat) {
                app.state.activeFilter = cat;
                this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat));
            },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB].filter(i => app.state.activeFilter === 'all' || i.category === app.state.activeFilter);
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="aspect-square w-full rounded-sm overflow-hidden bg-gray-50"><img src="${item.images[0]}" class="w-full h-full object-cover"></div>
                    <div class="flex flex-col justify-between py-2">
                        <div class="space-y-6">
                            <div><span class="text-xs uppercase tracking-widest text-gray-400 font-semibold">${item.category}</span><h1 class="font-serif text-3xl mt-1 font-medium">${item.name}</h1><p class="text-xl font-medium mt-3 text-gray-900">$${item.price.toFixed(2)}</p></div>
                            <p class="text-gray-500 text-sm leading-relaxed font-light">${item.desc}</p>
                        </div>
                        <button onclick="app.cart.addItem('${item.id}')" class="w-full mt-8 py-4 bg-black text-white text-xs font-medium uppercase tracking-widest hover:bg-gray-800 transition rounded-xs">Commit to Cart</button>
                    </div>`;
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="p-3 bg-gray-50 flex items-center space-x-3 cursor-pointer hover:bg-gray-100 transition">
                        <img src="${i.images[0]}" class="w-10 h-10 object-cover rounded-xs">
                        <div><p class="text-sm font-medium">${i.name}</p><p class="text-xs text-gray-400">$${i.price}</p></div>
                    </div>`).join('');
            }
        };

        // --- CART SYSTEM MANAGEMENT ---
        app.cart = {
            loadAndSync: function() {
                const stored = localStorage.getItem('oasis_cart');
                if (stored) app.state.cart = JSON.parse(stored);
                this.updateUI();
            },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`Added ${prod.name}`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) {
                const item = app.state.cart.find(i => i.product.id === id);
                if (!item) return; item.qty += val;
                if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id);
                this.sync();
            },
            sync: function() { localStorage.setItem('oasis_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);

                if (totalItems > 0) { badge.innerText = totalItems; badge.classList.remove('scale-0'); } else { badge.classList.add('scale-0'); }
                document.getElementById('cart-drawer-subtotal').innerText = `$${subtotal.toFixed(2)}`;

                if (app.state.cart.length === 0) {
                    drawerContainer.innerHTML = `<div class="text-center text-gray-400 py-12 text-xs uppercase tracking-wider"><i data-lucide="shopping-bag" class="w-6 h-6 mx-auto mb-2"></i>Cart is empty</div>`;
                } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex items-center space-x-4 border-b border-gray-100 pb-3">
                            <img src="${item.product.images[0]}" class="w-12 h-12 object-cover rounded-xs">
                            <div class="flex-grow min-w-0">
                                <h4 class="text-xs font-medium truncate">${item.product.name}</h4>
                                <div class="flex items-center space-x-2 mt-1">
                                    <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="w-5 h-5 border flex items-center justify-center text-xs">-</button>
                                    <span class="text-xs font-mono">${item.qty}</span>
                                    <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="w-5 h-5 border flex items-center justify-center text-xs">+</button>
                                </div>
                            </div>
                        </div>`).join('');
                }
                lucide.createIcons();
            }
        };

        // --- CHECKOUT ROUTINE PROCESSING ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const ctx = document.getElementById('checkout-btn-context');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                document.getElementById('chk-subtotal').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `<div class="flex justify-between text-xs py-1"><span>${i.product.name} (x${i.qty})</span><span>$${(i.product.price * i.qty).toFixed(2)}</span></div>`).join('');
                
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-black font-semibold" : "text-gray-400";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-black font-semibold" : "text-gray-400";
                document.getElementById('step-nav-3').className = app.state.activeCheckoutStep === 3 ? "text-black font-semibold" : "text-gray-400";

                if (app.state.activeCheckoutStep === 1) {
                    ctx.innerText = "to Shipping";
                    container.innerHTML = `<h3 class="text-sm font-medium">Contact Coordinates</h3><input type="email" required placeholder="Email Information" class="w-full border p-3 text-xs shopify-input"><input type="text" required placeholder="Fulfillment Shipping Address" class="w-full border p-3 text-xs shopify-input">`;
                } else if (app.state.activeCheckoutStep === 2) {
                    ctx.innerText = "to Payment";
                    container.innerHTML = `<h3 class="text-sm font-medium">Logistical Courier Velocity</h3><div class="border text-xs p-4 rounded-xs"><input type="radio" checked> Standard Freight Transport (Free)</div>`;
                } else if (app.state.activeCheckoutStep === 3) {
                    ctx.innerText = "and Complete Order Processing";
                    container.innerHTML = `<h3 class="text-sm font-medium">Secure Processing Core</h3><input type="text" required placeholder="Credit Card Mask Sequence" class="w-full border p-3 text-xs shopify-input">`;
                }
            },
            handleStepSubmit: function(e) {
                e.preventDefault();
                if(app.state.activeCheckoutStep < 3) { app.state.activeCheckoutStep += 1; this.renderCurrentStep(); }
                else { app.state.cart = []; app.cart.sync(); app.state.activeCheckoutStep = 1; app.ui.triggerToast("Order processed successfully!"); app.router.navigate('home'); }
            }
        };

        // --- GLOBAL INTERFACE UX DECORATIONS ---
        app.ui = {
            toggleCartDrawer: function(open = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const cond = open !== null ? !open : !overlay.classList.contains('opacity-0');
                if (cond) { overlay.classList.add('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.add('translate-x-full'); }
                else { overlay.classList.remove('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.remove('translate-x-full'); }
            },
            toggleSearchOverlay: function() {
                const s = document.getElementById('search-overlay'); s.classList.toggle('hidden'); s.classList.toggle('flex');
                if(!s.classList.contains('hidden')) document.getElementById('live-search-input').focus();
            },
            toggleAccordion: function(btn) {
                const icon = btn.querySelector('i');
                const panel = btn.nextElementSibling;
                icon.classList.toggle('rotate-180');
                if (panel.style.maxHeight && panel.style.maxHeight !== '0px') { panel.style.maxHeight = '0px'; } else { panel.style.maxHeight = panel.scrollHeight + "px"; }
            },
            handleContactSubmit: function(e) { e.preventDefault(); e.target.reset(); this.triggerToast("Transmission secure. Inquiry submitted."); },
            simulateTracking: function() {
                const id = document.getElementById('track-id-input').value;
                const out = document.getElementById('tracking-result-box');
                if(!id) return; out.classList.remove('hidden');
                out.innerHTML = `<p class="font-bold text-gray-900">Manifest Node ${id.toUpperCase()}</p><p class="text-gray-400 mt-1">&bull; Standard Route: IN TRANSIT via Processing Center</p><p class="text-[10px] text-gray-400 mt-2">Timestamp: ${new Date().toISOString()}</p>`;
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); document.getElementById('toast-notif-message').innerText = msg;
                t.className = "fixed bottom-6 right-6 bg-gray-900 text-white text-xs py-3.5 px-6 rounded-xs shadow-xl z-50 transform translate-y-0 opacity-100 transition-all duration-300";
                setTimeout(() => { t.className = "fixed bottom-6 right-6 bg-gray-900 text-white text-xs py-3.5 px-6 rounded-xs shadow-xl z-50 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none"; }, 3500);
            }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
